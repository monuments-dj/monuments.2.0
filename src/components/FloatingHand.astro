---
// FloatingHand — the brand's red "floating hand" signature element.
// A crafted inline SVG of a stylized open hand (palm + 4 fingers + thumb),
// filled with the signature red (var(--accent)) with a darker-red edge for a
// little dimension. It idle-floats (slow CSS bob + tilt) and ALSO reacts to
// scroll: a tiny rAF client script parallaxes + "deploys" it as it enters view.
// Position is absolute-in-section (drop it inside a position:relative parent),
// pointer-events:none. Respects prefers-reduced-motion (idle only, no scroll FX).
interface Props {
  side?: "left" | "right";
  top?: string;
  z?: number;
}
const { side = "right", top = "12vh", z = 3 } = Astro.props;
// A unique id so multiple hands on one page don't collide in the scroll script.
const uid = "fh-" + Math.random().toString(36).slice(2, 9);
---

<div
  class:list={["floating-hand", `fh-${side}`]}
  data-fh={uid}
  style={`--fh-top:${top}; --fh-z:${z};`}
  aria-hidden="true"
>
  <!-- DJ's real floating-hand asset (his own mark) -->
  <img class="fh-svg" src="/hand.png" alt="" />

</div>

<style>
  .floating-hand {
    position: absolute;
    top: var(--fh-top, 12vh);
    z-index: var(--fh-z, 3);
    width: clamp(140px, 16vw, 300px);
    pointer-events: none;
    will-change: transform;
    /* The idle bob/tilt lives here; the scroll script writes into --fh-sx/--fh-sy/--fh-sr. */
    transform: translate3d(var(--fh-sx, 0px), var(--fh-sy, 0px), 0)
      rotate(var(--fh-sr, 0deg));
  }
  .fh-right { right: clamp(-30px, 2vw, 40px); }
  .fh-left { left: clamp(-30px, 2vw, 40px); }

  .fh-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    filter: drop-shadow(0 22px 40px rgba(0, 0, 0, 0.35));
    /* The slow idle float: a gentle bob + tilt, layered under the scroll transform. */
    animation: fhFloat 7s ease-in-out infinite;
  }

  @keyframes fhFloat {
    0%,
    100% {
      transform: translateY(0) rotate(-3deg);
    }
    50% {
      transform: translateY(-16px) rotate(4deg);
    }
  }

  /* Reduced motion: kill the idle animation AND any scroll transform. */
  @media (prefers-reduced-motion: reduce) {
    .fh-svg {
      animation: none;
    }
    .floating-hand {
      transform: none;
    }
  }
</style>

<script>
  // Scroll-reactive parallax + "deploy" entrance for each FloatingHand.
  // Scrubbed every frame via rAF, reversible (math reads scroll position live).
  // No-ops under prefers-reduced-motion so the element only idle-floats.
  (function () {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;

    const hands = Array.from(document.querySelectorAll(".floating-hand"));
    if (!hands.length) return;

    let ticking = false;

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));

    function update() {
      ticking = false;
      const vh = window.innerHeight || 1;
      for (const el of hands) {
        const r = el.getBoundingClientRect();
        // Progress 0..1 as the element travels from just below the viewport
        // (center at bottom) up through it (center at top). Reversible.
        const center = r.top + r.height / 2;
        const p = clamp(1 - center / vh, 0, 1);

        // Deploy entrance: as it first enters (p small), it slides up + rotates
        // into place, then keeps a gentle parallax drift through the rest.
        const deploy = clamp(p / 0.35, 0, 1); // 0..1 over the first 35%
        const ease = deploy * deploy * (3 - 2 * deploy); // smoothstep

        // Parallax: travel further (slower than the page = deviates up to ~180px).
        const drift = (p - 0.5) * 240; // -120..+120 px
        const side = el.classList.contains("fh-left") ? -1 : 1;

        const sx = (1 - ease) * -40 * side; // deploy in from the edge
        const sy = (1 - ease) * 90 + -drift * 0.75; // deploy up + parallax
        const sr = (1 - ease) * 14 * side + (p - 0.5) * 10; // deploy tilt + drift tilt

        el.style.setProperty("--fh-sx", sx.toFixed(1) + "px");
        el.style.setProperty("--fh-sy", sy.toFixed(1) + "px");
        el.style.setProperty("--fh-sr", sr.toFixed(2) + "deg");
        el.style.opacity = String(clamp(0.2 + ease, 0, 1));
      }
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    addEventListener("scroll", onScroll, { passive: true });
    addEventListener("resize", onScroll, { passive: true });
    update(); // set initial state so it isn't a hard pop on first paint
  })();
</script>
