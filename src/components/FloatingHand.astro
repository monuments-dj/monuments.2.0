---
// FloatingHand — the brand's red hand mark, reimagined as a tiny "rocket" that
// flies DIAGONALLY through a section on scroll, behind the text. Small (about a
// headline's height), tilted (not upright), z below the copy. The scroll script
// reads the host SECTION (not the hand) so the long travel never feeds back.
// Respects prefers-reduced-motion (sits still, tucked in a corner).
interface Props {
  side?: "left" | "right";
  top?: string;
  z?: number;
}
const { side = "right", top = "16vh", z = 1 } = Astro.props;
const uid = "fh-" + Math.random().toString(36).slice(2, 9);
---
<div
  class:list={["floating-hand", `fh-${side}`]}
  data-fh={uid}
  style={`--fh-top:${top}; --fh-z:${z};`}
  aria-hidden="true"
>
  <img class="fh-img" src="/hand.png" alt="" />
</div>

<style>
  .floating-hand {
    position: absolute;
    top: var(--fh-top, 16vh);
    z-index: var(--fh-z, 1);          /* below the text (which sits z >= 2) */
    width: clamp(34px, 4.4vw, 66px);  /* tiny: about a headline's height */
    pointer-events: none;
    will-change: transform, opacity;
    transform: translate3d(var(--fh-x, 0px), var(--fh-y, 0px), 0) rotate(var(--fh-r, 24deg));
  }
  .fh-right { right: clamp(10px, 8vw, 130px); --fh-r-base: 24deg; }
  .fh-left { left: clamp(10px, 8vw, 130px); --fh-r-base: -24deg; }

  .fh-img {
    display: block; width: 100%; height: auto;
    filter: drop-shadow(0 10px 22px rgba(0, 0, 0, 0.4));
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-hand { transform: rotate(24deg); }
    .fh-left { transform: rotate(-24deg); }
  }
</style>

<script>
  (function () {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;
    const hands = Array.from(document.querySelectorAll(".floating-hand"));
    if (!hands.length) return;
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    let ticking = false;

    function update() {
      ticking = false;
      const vh = window.innerHeight || 1;
      const vw = window.innerWidth || 1;
      for (const el of hands) {
        // Progress is read off the HOST section, so the hand's own big travel
        // never creates a feedback loop. 0 = section entering from the bottom,
        // 1 = section fully above the viewport.
        const host = el.offsetParent || el.parentElement;
        if (!host) continue;
        const pr = host.getBoundingClientRect();
        const denom = vh + pr.height || 1;
        const p = clamp((vh - pr.top) / denom, 0, 1);
        const dir = el.classList.contains("fh-left") ? -1 : 1;

        // Diagonal rocket path: flies UP through the section and drifts outward,
        // tilted toward its direction of travel. Reversible (pure function of p).
        const x = dir * (p * 0.24 - 0.04) * vw;
        const y = (0.5 - p) * vh * 1.35;
        const r = dir * 24 + (p - 0.5) * 26;          // lean + a little arc
        const fade = clamp(Math.min(p, 1 - p) * 7 + 0.1, 0, 1);

        el.style.setProperty("--fh-x", x.toFixed(1) + "px");
        el.style.setProperty("--fh-y", y.toFixed(1) + "px");
        el.style.setProperty("--fh-r", r.toFixed(2) + "deg");
        el.style.opacity = fade.toFixed(2);
      }
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    addEventListener("scroll", onScroll, { passive: true });
    addEventListener("resize", onScroll, { passive: true });
    update();
  })();
</script>
