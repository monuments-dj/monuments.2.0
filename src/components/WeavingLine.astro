---
// Weaving line (lusion-style): an organic line that snakes down one edge of the
// page and DRAWS itself in time with scroll progress. Fixed, viewport-height,
// behind content. Subtle accent thread that ties the page together.
interface Props {
  side?: 'left' | 'right';
  color?: string;        // any CSS color / token, default var(--accent)
  width?: number;        // stroke px
  opacity?: number;
}
const { side = 'left', color = 'var(--accent)', width = 3, opacity = 0.5 } = Astro.props;
---
<div class:list={['weave', `weave-${side}`]} aria-hidden="true" style={`--wv-color:${color}; --wv-w:${width}px; --wv-o:${opacity}`}>
  <svg class="weave-svg" viewBox="0 0 120 1000" preserveAspectRatio="none" fill="none">
    <path class="weave-path"
      d="M60 0 C 8 90, 112 180, 60 270 C 8 360, 112 450, 60 540 C 8 630, 112 720, 60 810 C 18 890, 96 940, 60 1000" />
  </svg>
</div>

<style>
  .weave { position: fixed; top: 0; bottom: 0; width: clamp(60px, 7vw, 120px); z-index: 0; pointer-events: none; opacity: var(--wv-o); }
  .weave-left { left: 0; }
  .weave-right { right: 0; transform: scaleX(-1); }
  .weave-svg { width: 100%; height: 100%; display: block; overflow: visible; }
  .weave-path {
    stroke: var(--wv-color); stroke-width: var(--wv-w); stroke-linecap: round; fill: none;
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--wv-color) 45%, transparent));
    stroke-dasharray: var(--len, 3000);
    stroke-dashoffset: var(--off, 3000);
  }
  @media (max-width: 860px) { .weave { display: none; } }
  @media (prefers-reduced-motion: reduce) { .weave-path { stroke-dashoffset: 0; } }
</style>

<script>
  document.querySelectorAll('.weave').forEach((wrap) => {
    const path = wrap.querySelector('.weave-path');
    if (!path) return;
    const len = path.getTotalLength();
    path.style.setProperty('--len', String(len));
    path.style.setProperty('--off', String(len));
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) { path.style.setProperty('--off', '0'); return; }
    let ticking = false;
    const onScroll = () => {
      if (ticking) return; ticking = true;
      requestAnimationFrame(() => {
        const max = document.documentElement.scrollHeight - innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, (window.scrollY || document.documentElement.scrollTop) / max)) : 0;
        // keep a little drawn at rest so it reads as a thread, fill as you scroll
        path.style.setProperty('--off', String(len * (1 - (0.12 + p * 0.88))));
        ticking = false;
      });
    };
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  });
</script>
