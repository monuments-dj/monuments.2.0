---
// === CreditsVariants ===
// The 3 credits-bar directions to A/B (agency, DJ's role highlighted, other creators;
// black bar, white text). Rendered at the top of the /lab hub and on /lab/credits.
// SAMPLE DATA (Buck the Quo shape) — collaborator names are placeholders for the comp.
const data = {
  project: 'Buck the Quo',
  client: 'Albertson Family Foundation',
  agency: 'Drake Cooper',
  role: 'Director, Experiential',
  team: [
    { name: 'Kelsey Grant', role: 'Executive Creative Director' },
    { name: 'Marcus Reed', role: 'Producer' },
    { name: 'Ana Flores', role: 'Director of Photography' },
    { name: 'Sam Park', role: 'Editor' },
    { name: 'Riley Chen', role: 'Copywriter' },
  ],
};
---
<div class="crv">
  <!-- VARIANT 01 — INLINE BAR -->
  <div class="crv-block">
    <div class="crv-tag"><span>Variant 01</span> Inline bar — slim, quiet, one line</div>
    <div class="cr1">
      <span class="cr1-label">Credits</span>
      <div class="cr1-items">
        <span class="cr1-item"><em>Agency</em>{data.agency}</span>
        <span class="cr1-item cr1-mine"><em>My role</em>{data.role}</span>
        <span class="cr1-item"><em>Team</em>{data.team.map((t) => `${t.name} (${t.role})`).join(', ')}</span>
      </div>
    </div>
  </div>

  <!-- VARIANT 02 — COLUMNED BLOCK -->
  <div class="crv-block">
    <div class="crv-tag"><span>Variant 02</span> Columned block — structured, scannable</div>
    <div class="cr2">
      <div class="cr2-col"><span class="cr2-k">Client</span><span class="cr2-v">{data.client}</span></div>
      <div class="cr2-col"><span class="cr2-k">Agency</span><span class="cr2-v">{data.agency}</span></div>
      <div class="cr2-col cr2-mine"><span class="cr2-k">My role</span><span class="cr2-v">{data.role}</span></div>
      <div class="cr2-col cr2-team">
        <span class="cr2-k">Collaborators</span>
        <ul class="cr2-list">
          {data.team.map((t) => <li><b>{t.name}</b><i>{t.role}</i></li>)}
        </ul>
      </div>
    </div>
  </div>

  <!-- VARIANT 03 — END CREDITS -->
  <div class="crv-block">
    <div class="crv-tag"><span>Variant 03</span> End credits — editorial, role → name</div>
    <div class="cr3">
      <div class="cr3-head">
        <span class="cr3-eyebrow">Credits</span>
        <span class="cr3-project">{data.project}</span>
      </div>
      <dl class="cr3-list">
        <div class="cr3-row"><dt>Agency</dt><dd>{data.agency}</dd></div>
        <div class="cr3-row cr3-mine"><dt>{data.role}</dt><dd>DJ Ramirez</dd></div>
        {data.team.map((t) => <div class="cr3-row"><dt>{t.role}</dt><dd>{t.name}</dd></div>)}
      </dl>
    </div>
  </div>
</div>

<style>
  .crv { display: flex; flex-direction: column; gap: clamp(28px, 4vw, 48px); }
  .crv-tag { font-size: 12px; letter-spacing: 0.06em; color: rgb(var(--ink-rgb, 12 11 10) / 0.55); margin-bottom: 14px; }
  .crv-tag span { display: inline-block; margin-right: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent, #6b8cae); }

  /* shared: the black bar surface + accent for "my role" */
  .cr1, .cr2, .cr3 { --cr-accent: #8fa9c9; background: #0c0d10; color: #fff; border-radius: 12px; }

  /* ---------- V1 — inline bar ---------- */
  .cr1 { display: flex; align-items: baseline; gap: clamp(18px, 3vw, 40px); flex-wrap: wrap; padding: clamp(18px, 2vw, 24px) clamp(22px, 3vw, 34px); }
  .cr1-label { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(255 255 255 / 0.45); flex: 0 0 auto; }
  .cr1-items { display: flex; flex-wrap: wrap; gap: clamp(16px, 2.4vw, 34px); }
  .cr1-item { font-size: clamp(13px, 1.1vw, 15px); line-height: 1.5; color: rgb(255 255 255 / 0.92); }
  .cr1-item em { font-style: normal; display: inline-block; margin-right: 10px; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(255 255 255 / 0.42); }
  .cr1-mine { color: #fff; }
  .cr1-mine em { color: var(--cr-accent); }

  /* ---------- V2 — columned block ---------- */
  .cr2 { display: grid; grid-template-columns: 1fr 1fr 1fr 1.6fr; gap: clamp(20px, 3vw, 48px); padding: clamp(26px, 3.2vw, 40px) clamp(24px, 3vw, 40px); }
  .cr2-col { display: flex; flex-direction: column; gap: 9px; min-width: 0; }
  .cr2-k { font-size: 10.5px; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(255 255 255 / 0.42); }
  .cr2-v { font-size: clamp(15px, 1.3vw, 18px); letter-spacing: -0.01em; color: #fff; }
  .cr2-mine .cr2-k { color: var(--cr-accent); }
  .cr2-mine .cr2-v { color: var(--cr-accent); font-weight: 500; }
  .cr2-list { list-style: none; margin: 2px 0 0; padding: 0; display: grid; gap: 8px; }
  .cr2-list li { display: flex; justify-content: space-between; gap: 16px; font-size: 13.5px; border-bottom: 1px solid rgb(255 255 255 / 0.08); padding-bottom: 8px; }
  .cr2-list b { font-weight: 400; color: rgb(255 255 255 / 0.92); }
  .cr2-list i { font-style: normal; color: rgb(255 255 255 / 0.5); text-align: right; }

  /* ---------- V3 — end credits ---------- */
  .cr3 { padding: clamp(32px, 4vw, 56px) clamp(24px, 4vw, 60px) clamp(30px, 4vw, 48px); }
  .cr3-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; padding-bottom: clamp(20px, 2.4vw, 30px); border-bottom: 1px solid rgb(255 255 255 / 0.14); margin-bottom: clamp(8px, 1.4vw, 16px); }
  .cr3-eyebrow { font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--cr-accent); }
  .cr3-project { font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(18px, 2vw, 28px); letter-spacing: -0.02em; color: #fff; }
  .cr3-list { margin: 0; }
  .cr3-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: baseline; padding: clamp(11px, 1.3vw, 15px) 0; border-bottom: 1px solid rgb(255 255 255 / 0.08); }
  .cr3-row dt { font-size: clamp(12px, 1vw, 13.5px); letter-spacing: 0.04em; color: rgb(255 255 255 / 0.5); }
  .cr3-row dd { margin: 0; font-family: 'Inter', sans-serif; font-size: clamp(15px, 1.4vw, 19px); letter-spacing: -0.01em; color: rgb(255 255 255 / 0.94); text-align: right; }
  .cr3-mine dt { color: var(--cr-accent); font-weight: 500; }
  .cr3-mine dd { color: var(--cr-accent); font-weight: 500; }

  @media (max-width: 760px) {
    .cr2 { grid-template-columns: 1fr 1fr; }
    .cr2-team { grid-column: 1 / -1; }
    .cr3-row { grid-template-columns: 1fr; gap: 2px; }
    .cr3-row dd { text-align: left; }
  }
</style>
