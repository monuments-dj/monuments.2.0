---
// AttentionHourglass — a little hourglass that drains over the average online
// attention span (~8s), then flips and runs again. Sand = accent. The point:
// "8 seconds is the whole window. We design for it." Tokenized, reduced-motion
// safe (renders mid-drain, static). Self-contained.
interface Props {
  seconds?: number;
  heading?: string;
  body?: string;
}
const {
  seconds = 8,
  heading = '8 seconds.',
  body = "The average attention span online. That's the whole window we get to make someone feel something. We design for it.",
} = Astro.props;
---
<div class="hg" data-hg style={`--secs:${seconds}`}>
  <div class="hg-stage">
    <div class="hg-glass" data-hg-glass>
      <div class="hg-bulb hg-top"><span class="hg-sand"></span></div>
      <div class="hg-bulb hg-bot"><span class="hg-sand"></span></div>
      <span class="hg-stream"></span>
      <svg class="hg-frame" viewBox="0 0 120 156" aria-hidden="true">
        <path d="M12 6 H108 M12 6 L60 75 L12 150 M108 6 L60 75 L108 150 M12 150 H108"
          stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
        <path d="M12 6 H108 M12 150 H108" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
      </svg>
    </div>
    <span class="hg-count" data-hg-count>{seconds}</span>
  </div>
  <div class="hg-copy">
    <p class="hg-h split">{heading}</p>
    <p class="hg-body fade">{body}</p>
  </div>
</div>

<style>
  .hg { display: flex; align-items: center; gap: clamp(28px, 5vw, 72px); max-width: var(--wrap); margin: 0 auto; padding: clamp(70px, 9vw, 120px) var(--pad); flex-wrap: wrap; }
  .hg-stage { position: relative; flex: 0 0 auto; }
  .hg-glass { position: relative; width: 120px; height: 156px; color: var(--fg); transition: transform 0.85s cubic-bezier(0.7, 0, 0.2, 1); transform-origin: 50% 50%; }
  .hg-glass.flip { transform: rotate(180deg); }

  .hg-bulb { position: absolute; left: 12px; right: 12px; overflow: hidden; }
  .hg-top { top: 6px; height: 69px; clip-path: polygon(0% 0%, 100% 0%, 50% 100%); }
  .hg-bot { top: 81px; height: 69px; clip-path: polygon(50% 0%, 0% 100%, 100% 100%); }
  .hg-sand { position: absolute; inset: 0; background: var(--accent); display: block; }
  .hg-top .hg-sand { clip-path: inset(calc(var(--p, 0) * 100%) 0 0 0); }
  .hg-bot .hg-sand { clip-path: inset(calc((1 - var(--p, 0)) * 100%) 0 0 0); }

  .hg-stream { position: absolute; left: 50%; top: 70px; width: 2px; height: 16px; margin-left: -1px; background: var(--accent); opacity: 0; }
  .hg-glass.running .hg-stream { opacity: 1; animation: hgStream 0.5s linear infinite; }
  @keyframes hgStream { 0% { transform: scaleY(0.6); } 50% { transform: scaleY(1); } 100% { transform: scaleY(0.6); } }

  .hg-frame { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; pointer-events: none; }
  .hg-count { position: absolute; left: 50%; top: 100%; transform: translateX(-50%); margin-top: 14px; font-family: 'Inter', sans-serif; font-weight: 500; font-size: 14px; letter-spacing: 0.18em; color: rgb(var(--fg-rgb) / 0.55); font-variant-numeric: tabular-nums; }

  .hg-copy { flex: 1 1 320px; }
  .hg-h { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(34px, 5vw, 72px); letter-spacing: -0.03em; line-height: 1; color: var(--accent); }
  .hg-body { margin-top: 18px; max-width: 42ch; font-size: clamp(15px, 1.5vw, 19px); line-height: 1.6; font-weight: 300; }

  /* split + fade utils (match the system) */
  .hg :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .hg :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.7s cubic-bezier(0.16,1,0.3,1) calc(var(--wd) * 0.04s); }
  .hg :global(.split.on .wi) { transform: none; }

  /* On a light section the frame/copy should read as ink */
  :global(.on-paper) .hg-glass { color: var(--ink); }
  :global(.on-paper) .hg-count { color: rgb(var(--ink-rgb) / 0.55); }

  @media (prefers-reduced-motion: reduce) {
    .hg-glass { transition: none; }
    .hg-stream { display: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-hg]').forEach((root) => {
    const glass = root.querySelector('[data-hg-glass]');
    const count = root.querySelector('[data-hg-count]');
    const secs = Number(getComputedStyle(root).getPropertyValue('--secs')) || 8;
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!glass) return;

    if (reduced) { glass.style.setProperty('--p', '0.45'); if (count) count.textContent = String(Math.round(secs * 0.55)); return; }

    let startedAt = 0, raf = 0, running = false, flips = 0;
    const tick = (now) => {
      if (!startedAt) startedAt = now;
      const elapsed = (now - startedAt) / 1000;
      let p = Math.min(1, elapsed / secs);
      glass.style.setProperty('--p', String(p));
      if (count) count.textContent = String(Math.max(0, Math.ceil(secs - elapsed)));
      if (p >= 1) {
        // drain complete: flip the glass, then reset and run again
        glass.classList.remove('running');
        glass.classList.add('flip');
        flips++;
        setTimeout(() => {
          glass.classList.remove('flip');
          // remove transition jump: reset p to 0 under the (un-rotated) glass
          glass.style.setProperty('--p', '0');
          startedAt = 0;
          glass.classList.add('running');
          raf = requestAnimationFrame(tick);
        }, 900);
        return;
      }
      raf = requestAnimationFrame(tick);
    };

    const start = () => { if (running) return; running = true; glass.classList.add('running'); raf = requestAnimationFrame(tick); };
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { start(); io.disconnect(); } }), { threshold: 0.4 });
    io.observe(root);

    // reveal the split heading
    const io2 = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('on'); io2.unobserve(e.target); } }), { threshold: 0.4 });
    root.querySelectorAll('.split').forEach((el) => {
      // word-split
      const wrap = document.createDocumentFragment();
      (el.textContent || '').split(/(\s+)/).forEach((part, i) => {
        if (!part) return;
        if (/^\s+$/.test(part)) { wrap.appendChild(document.createTextNode(part)); return; }
        const w = document.createElement('span'); w.className = 'w';
        const wi = document.createElement('span'); wi.className = 'wi'; wi.style.setProperty('--wd', String(i)); wi.textContent = part;
        w.appendChild(wi); wrap.appendChild(w);
      });
      el.textContent = ''; el.appendChild(wrap); io2.observe(el);
    });
  });
</script>
