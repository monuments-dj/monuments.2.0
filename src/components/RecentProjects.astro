---
// RecentProjects.astro — homepage "Recent Work" slider.
// Promoted from the Lab's project-detail slider (/lab/project-detail). A pinned section
// whose horizontal track of framed project panels scrubs sideways as you scroll. Restyled
// LIGHT/white + more compact than the Lab version, one panel per recent project, navigated
// by a draggable/clickable SCRUBBER (no corner arrows). Reduced-motion + narrow screens
// fall back to a clean vertical stack. Self-contained (home has no LabFx tokens).

// Real case studies only — each links to its /work/<slug> page with a real hero image.
// `tail` carries the "Built ___" line (DJ-approved copy, moved here from the old reel).
const projects = [
  { brand: 'Turnstile',       tail: 'to take it to 11',      slug: 'turnstile',          img: '/case-studies/turnstile/bts/bts-01.jpg' },
  { brand: 'Blue Cross',      tail: 'for life',              slug: 'blue-cross',         img: '/case-studies/blue-cross/gallery/bci-10.jpg' },
  { brand: 'Sony',            tail: 'to chase the sun',      slug: 'sony-xperia-summer', img: '/case-studies/sony-xperia-summer/gallery/xp-01.jpg' },
  { brand: 'Sony',            tail: 'to capture the moment', slug: 'sony-this-moment',   img: '/case-studies/sony-this-moment/gallery/tm-01.jpg' },
  { brand: 'Flashpoint',      tail: 'to shape the light',    slug: 'flashpoint',         img: '/case-studies/flashpoint/gallery/fp-01.jpg' },
  { brand: 'Waffle Me Up',    tail: 'to be worth the wait',  slug: 'waffle-me-up',       img: '/case-studies/waffle-me-up/gallery/wmu-01.jpg' },
  { brand: 'Clothing & Merch', tail: 'to be worn',           slug: 'clothing-merch',     img: '/case-studies/clothing-merch/gallery/cm-01.jpg' },
];
const N = projects.length;
const pad2 = (n: number) => String(n).padStart(2, '0');
---
<section class="rp" data-rp aria-label="Recent work">
  <div class="rp-stage" data-rp-stage>
    <div class="rp-head">
      <span class="rp-eyebrow"><i aria-hidden="true">+</i>Recent Work</span>
      <a class="rp-all" href="/work">See all work <span aria-hidden="true">&rarr;</span></a>
    </div>

    <div class="rp-track" data-rp-track data-lenis-prevent>
      {projects.map((p, i) => (
        <article class="rp-panel">
          <div class="rp-panel-inner">
            <a class="rp-frame" href={`/work/${p.slug}`} aria-label={`View ${p.brand}`}>
              <span class="rp-frame-bar" aria-hidden="true">
                <span class="rp-dots"><i></i><i></i><i></i></span>
                <span class="rp-frame-label">monuments &middot; {p.brand}</span>
                <span class="rp-frame-go">&#8599;</span>
              </span>
              <span class="rp-frame-media">
                <img src={p.img} alt={`${p.brand}, built ${p.tail}`} loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />
                <span class="rp-frame-view">View project</span>
              </span>
            </a>
            <div class="rp-text">
              <span class="rp-index">{pad2(i + 1)}<i>&thinsp;/&thinsp;{pad2(N)}</i></span>
              <h3 class="rp-title">{p.brand}</h3>
              <p class="rp-desc">Built {p.tail}.</p>
              <a class="rp-view" href={`/work/${p.slug}`}>View project <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- minimal scrubber: a clickable / draggable progress line, number + active project -->
    <div class="rp-hud">
      <div class="rp-meta">
        <span class="rp-counter"><b data-rp-cur>01</b><span>&thinsp;/&thinsp;{pad2(N)}</span></span>
        <span class="rp-now" data-rp-now>{projects[0].brand}</span>
      </div>
      <div class="rp-scrub" data-rp-scrub role="slider" tabindex="0" aria-label="Scrub through projects"
           aria-valuemin="1" aria-valuemax={N} aria-valuenow="1">
        <span class="rp-scrub-track" aria-hidden="true"></span>
        <span class="rp-scrub-fill" data-rp-fill aria-hidden="true"></span>
        {projects.map((_, i) => (
          <span class="rp-tick" aria-hidden="true" style={`left:${(N === 1 ? 0 : i / (N - 1)) * 100}%`}></span>
        ))}
        <span class="rp-scrub-thumb" aria-hidden="true"></span>
      </div>
      <ul class="rp-dotnav" data-rp-dots aria-label="Choose project">
        {projects.map((p, i) => (
          <li>
            <button type="button" class="rp-dot" data-rp-dot={i}
              aria-current={i === 0 ? 'true' : 'false'}
              aria-label={`Show project ${i + 1} of ${N}: ${p.brand}`}></button>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .rp {
    --rp-paper: #fcfcfc;
    --rp-ink: #141519;
    --rp-mut: #777c83;
    --rp-line: rgba(20, 21, 25, 0.10);
    --rp-accent: #6b8cae; /* denim, matches the home's --accent on its other white sections */
    background: var(--rp-paper); color: var(--rp-ink); position: relative; overflow-x: clip;
  }

  /* ---------- pinned stage ---------- */
  .rp-stage { position: relative; height: 100vh; height: 100svh; overflow: hidden; }
  .rp-head {
    position: absolute; top: clamp(26px, 5vh, 56px); left: var(--pad); right: var(--pad); z-index: 4;
    display: flex; align-items: baseline; justify-content: space-between; gap: 16px; pointer-events: none;
  }
  .rp-eyebrow { display: inline-flex; align-items: baseline; font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--rp-mut); }
  .rp-eyebrow i { color: var(--rp-accent); font-style: normal; margin-right: 14px; }
  .rp-all { pointer-events: auto; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--rp-ink); text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: gap 0.3s ease, color 0.2s ease; }
  .rp-all:hover { color: var(--rp-accent); gap: 12px; }

  .rp-track { display: flex; flex-direction: row; height: 100%; width: max-content; will-change: transform; }
  .rp-panel { flex: 0 0 100vw; height: 100%; display: flex; align-items: center; }
  /* frame-left / text-right; centred cluster with breathing room (compact vs the Lab's full-bleed) */
  .rp-panel-inner {
    width: 100%; max-width: 1180px; margin: 0 auto; padding: 0 var(--pad);
    display: grid; grid-template-columns: 1.12fr 0.88fr; gap: clamp(32px, 4.4vw, 72px); align-items: center;
  }

  /* the framed "screen" */
  .rp-frame {
    display: block; text-decoration: none; color: inherit; border-radius: 12px; overflow: hidden;
    background: #fff; border: 1px solid var(--rp-line); box-shadow: 0 26px 64px rgba(20, 30, 50, 0.13);
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1), box-shadow 0.5s ease; max-width: 640px;
  }
  .rp-frame:hover { transform: translateY(-4px); box-shadow: 0 36px 80px rgba(20, 30, 50, 0.20); }
  .rp-frame-bar { display: flex; align-items: center; gap: 12px; padding: 11px 15px; border-bottom: 1px solid var(--rp-line); background: #f4f3f0; }
  .rp-dots { display: inline-flex; gap: 6px; }
  .rp-dots i { width: 9px; height: 9px; border-radius: 50%; background: rgba(20, 21, 25, 0.16); }
  .rp-frame-label { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rp-mut); margin: 0 auto 0 4px; }
  .rp-frame-go { font-size: 13px; color: rgba(20, 21, 25, 0.34); }
  .rp-frame-media { position: relative; display: block; aspect-ratio: 16 / 10; overflow: hidden; background: #e7e3db; }
  .rp-frame-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transform: scale(1.1); will-change: transform; }
  .rp-frame-view {
    position: absolute; left: 16px; bottom: 16px; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; background: rgba(20, 21, 25, 0.55); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    padding: 9px 16px; border-radius: 999px; opacity: 0; transform: translateY(8px); transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .rp-frame:hover .rp-frame-view { opacity: 1; transform: none; }

  /* the chapter/project text column */
  .rp-text { max-width: 42ch; }
  .rp-index { display: block; font-size: 13px; font-weight: 600; letter-spacing: 0.06em; color: var(--rp-accent); font-variant-numeric: tabular-nums; }
  .rp-index i { font-style: normal; color: rgba(20, 21, 25, 0.36); }
  .rp-title { font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(34px, 4.6vw, 68px); line-height: 1.02; letter-spacing: -0.035em; margin: 14px 0 0; }
  .rp-desc { margin: 16px 0 0; font-size: clamp(16px, 1.3vw, 20px); line-height: 1.5; font-weight: 300; color: rgba(20, 21, 25, 0.66); }
  .rp-view { display: inline-flex; align-items: center; gap: 9px; margin-top: 26px; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--rp-ink); text-decoration: none; border-bottom: 1px solid var(--rp-line); padding-bottom: 5px; transition: gap 0.3s ease, color 0.2s ease, border-color 0.2s ease; }
  .rp-view:hover { color: var(--rp-accent); border-color: var(--rp-accent); gap: 14px; }

  /* ---------- minimal scrubber HUD ---------- */
  .rp-hud { position: absolute; left: var(--pad); right: var(--pad); bottom: clamp(22px, 4vh, 46px); z-index: 5; display: flex; flex-direction: column; gap: 13px; }
  .rp-meta { display: flex; align-items: baseline; gap: 16px; }
  .rp-counter { font-size: 12px; letter-spacing: 0.06em; color: var(--rp-mut); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .rp-counter b { color: var(--rp-ink); font-weight: 600; font-size: 15px; }
  .rp-now { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rp-ink); font-weight: 500; }
  /* the scrub bar: a thin line with ticks + a fill + a draggable thumb; tall hit area */
  .rp-scrub { position: relative; height: 22px; display: flex; align-items: center; cursor: pointer; touch-action: none; }
  .rp-scrub-track { position: absolute; left: 0; right: 0; height: 2px; background: rgba(20, 21, 25, 0.14); border-radius: 2px; }
  .rp-scrub-fill { position: absolute; left: 0; height: 2px; width: calc(var(--p, 0) * 100%); background: var(--rp-accent); border-radius: 2px; }
  .rp-tick { position: absolute; top: 50%; width: 4px; height: 4px; border-radius: 50%; background: rgba(20, 21, 25, 0.22); transform: translate(-50%, -50%); }
  .rp-scrub-thumb { position: absolute; top: 50%; left: calc(var(--p, 0) * 100%); width: 13px; height: 13px; border-radius: 50%; background: var(--rp-accent); border: 2px solid var(--rp-paper); box-shadow: 0 2px 8px rgba(20, 30, 50, 0.3); transform: translate(-50%, -50%); transition: transform 0.18s ease; }
  .rp-scrub:hover .rp-scrub-thumb, .rp-scrub:focus-visible .rp-scrub-thumb { transform: translate(-50%, -50%) scale(1.25); }
  .rp-scrub:focus-visible { outline: none; }

  /* ---------- mobile dot indicator (base = hidden; shown only in the <=820px carousel) ---------- */
  .rp-dotnav { display: none; justify-content: center; align-items: center; gap: 10px; margin: 0; padding: 0; list-style: none; }
  .rp-dotnav li { display: flex; }
  .rp-dot { appearance: none; -webkit-appearance: none; border: 0; background: none; padding: 8px; cursor: pointer; line-height: 0; -webkit-tap-highlight-color: transparent; }
  .rp-dot::before { content: ''; display: block; width: 7px; height: 7px; border-radius: 999px; background: rgba(20,21,25,0.20); transition: background-color .25s ease, width .25s cubic-bezier(.16,1,.3,1); }
  .rp-dot[aria-current="true"]::before { background: var(--rp-accent); width: 18px; }
  .rp-dot:focus-visible { outline: 2px solid var(--rp-accent); outline-offset: 3px; border-radius: 999px; }

  /* ---------- mobile: horizontal scroll-snap carousel (autoplay in the script) ---------- */
  @media (max-width: 820px) {
    /* stage no longer pins — it just flows */
    .rp-stage { height: auto; overflow: visible; padding: clamp(64px,13vw,100px) 0 clamp(40px,9vw,72px); }
    .rp-head { position: static; padding: 0 var(--pad); margin-bottom: clamp(20px,5vw,30px); }

    /* the rail: track becomes a horizontal scroll-snap scroller */
    .rp-track {
      flex-direction: row; width: auto; max-width: none; margin: 0;
      transform: none !important; will-change: auto; position: relative;
      display: flex; gap: clamp(14px, 4vw, 22px);
      overflow-x: auto; overflow-y: visible;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;   /* swallow h-overscroll: no page chain / back-swipe */
      touch-action: pan-x;              /* h-drag stays in the rail, v-intent scrolls the page */
      padding-inline: calc((100vw - 86vw) / 2);
      scroll-padding-inline: calc((100vw - 86vw) / 2);
      scrollbar-width: none;
    }
    .rp-track::-webkit-scrollbar { display: none; }

    .rp-panel {
      flex: 0 0 86vw; width: 86vw; max-width: 460px; height: auto; padding: 0;
      border-top: 0; align-items: stretch;
      scroll-snap-align: center; scroll-snap-stop: always;
    }
    .rp-panel:first-child { padding: 0; border-top: 0; }

    .rp-panel-inner { grid-template-columns: 1fr; gap: clamp(16px, 4vw, 22px); max-width: none; padding: 0; height: 100%; align-content: start; }
    .rp-text { max-width: none; }
    .rp-frame { max-width: none; }
    .rp-frame-media { aspect-ratio: 4 / 3; }
    .rp-frame-media img { transform: none; }
    .rp-frame-view { opacity: 1; transform: none; }

    /* HUD becomes the dot rail */
    .rp-hud { display: block; position: static; padding: 0 var(--pad); margin-top: clamp(20px,5vw,28px); }
    .rp-meta, .rp-scrub { display: none; }
    .rp-dotnav { display: flex; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rp-stage { height: auto; overflow: visible; padding: 90px 0; }
    .rp-head { position: static; padding: 0 var(--pad); margin-bottom: 30px; }
    .rp-track { flex-direction: column; width: auto; max-width: var(--wrap); margin: 0 auto; transform: none !important; }
    .rp-panel { flex: none; width: auto; height: auto; padding: 56px 0; }
    .rp-panel-inner { grid-template-columns: 1fr; gap: 24px; }
    .rp-frame-media img { transform: none !important; }
    .rp-hud { display: none; }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/gsap-lenis.js';

  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const small = matchMedia('(max-width: 820px)').matches;
  const stage = document.querySelector('[data-rp-stage]') as HTMLElement | null;
  const track = document.querySelector('[data-rp-track]') as HTMLElement | null;

  if (stage && track && !reduced && !small) {
    const panels = [...track.querySelectorAll('.rp-panel')] as HTMLElement[];
    const medias = panels.map((p) => p.querySelector('.rp-frame-media img') as HTMLImageElement | null);
    const names = panels.map((p) => p.querySelector('.rp-title')?.textContent || '');
    const N = panels.length;
    const curEl = document.querySelector('[data-rp-cur]') as HTMLElement | null;
    const nowEl = document.querySelector('[data-rp-now]') as HTMLElement | null;
    const scrub = document.querySelector('[data-rp-scrub]') as HTMLElement | null;
    const amount = () => Math.max(0, track.scrollWidth - window.innerWidth);

    const tween = gsap.to(track, {
      x: () => -amount(),
      ease: 'none',
      scrollTrigger: {
        trigger: stage,
        start: 'top top',
        end: () => '+=' + amount(),
        pin: true,
        scrub: 0.8,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          const p = self.progress;
          const idx = Math.min(N - 1, Math.round(p * (N - 1)));
          if (scrub) {
            scrub.style.setProperty('--p', p.toFixed(4));
            scrub.setAttribute('aria-valuenow', String(idx + 1));
          }
          if (curEl) curEl.textContent = String(idx + 1).padStart(2, '0');
          if (nowEl && nowEl.textContent !== names[idx]) nowEl.textContent = names[idx];
          // subtle counter-parallax inside each frame as panels pass centre
          const vpc = window.innerWidth / 2;
          for (let i = 0; i < panels.length; i++) {
            const img = medias[i];
            if (!img) continue;
            const r = panels[i].getBoundingClientRect();
            const off = (r.left + r.width / 2 - vpc) / window.innerWidth;
            img.style.transform = `translate3d(${(-off * 6).toFixed(2)}%,0,0) scale(1.1)`;
          }
        },
      },
    });

    const st = tween.scrollTrigger!;
    const w = window as any;
    const scrollToFrac = (f: number, smooth = true) => {
      const ff = Math.max(0, Math.min(1, f));
      const target = st.start + ff * (st.end - st.start);
      if (w.lenis) w.lenis.scrollTo(target, smooth ? { duration: 0.7 } : { immediate: true });
      else window.scrollTo({ top: target, behavior: smooth ? 'smooth' : 'auto' });
    };
    const curIdx = () => Math.round(st.progress * (N - 1));
    const goTo = (k: number) => scrollToFrac(Math.max(0, Math.min(N - 1, k)) / (N - 1));

    if (scrub) {
      let dragging = false;
      const fracFromEvent = (e: PointerEvent) => {
        const r = scrub.getBoundingClientRect();
        return (e.clientX - r.left) / r.width;
      };
      scrub.addEventListener('pointerdown', (e) => {
        dragging = true;
        try { scrub.setPointerCapture(e.pointerId); } catch {}
        scrollToFrac(fracFromEvent(e), false);
      });
      scrub.addEventListener('pointermove', (e) => { if (dragging) scrollToFrac(fracFromEvent(e), false); });
      const end = (e: PointerEvent) => { if (dragging) { dragging = false; try { scrub.releasePointerCapture(e.pointerId); } catch {} } };
      scrub.addEventListener('pointerup', end);
      scrub.addEventListener('pointercancel', end);
      scrub.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(curIdx() - 1); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goTo(curIdx() + 1); }
      });
    }

    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  // ---------- mobile (<=820px): horizontal scroll-snap carousel + autoplay ----------
  // Mutually exclusive with the desktop block above (gated !small). Reuses reduced/small/stage/track.
  if (stage && track && small) {
    const panels = [...track.querySelectorAll('.rp-panel')] as HTMLElement[];
    const dots = [...document.querySelectorAll('[data-rp-dot]')] as HTMLButtonElement[];
    const N = panels.length;
    const DELAY = 4000;        // autoplay cadence
    const IDLE_RESUME = 3500;  // wait after the last gesture before resuming
    const PROG_GUARD = 2000;   // FALLBACK only: scrollend releases the flag; this covers engines without it

    track.setAttribute('data-lenis-prevent', ''); // belt-and-braces (also in markup)

    // geometry read live (vw widths reflow on rotate with no cached state)
    const targetFor = (i: number) => panels[i].offsetLeft - (track.clientWidth - panels[i].clientWidth) / 2;
    const nearestIndex = () => {
      const c = track.scrollLeft + track.clientWidth / 2;
      let best = 0, bd = Infinity;
      for (let i = 0; i < N; i++) {
        const pc = panels[i].offsetLeft + panels[i].clientWidth / 2;
        const d = Math.abs(pc - c);
        if (d < bd) { bd = d; best = i; }
      }
      return best;
    };

    let current = 0;
    const setActive = (i: number) => {
      if (i === current) { dots[i]?.setAttribute('aria-current', 'true'); return; }
      dots[current]?.setAttribute('aria-current', 'false');
      current = i;
      dots[current]?.setAttribute('aria-current', 'true');
    };

    // programmatic-scroll guard: our own scrollTo must not read as a user interrupt
    let programmatic = false, progTimer = 0;
    const goTo = (i: number, smooth = true) => {
      const idx = ((i % N) + N) % N;
      programmatic = true;
      clearTimeout(progTimer);
      track.scrollTo({ left: targetFor(idx), behavior: (smooth && !reduced) ? 'smooth' : 'auto' });
      setActive(idx);
      progTimer = window.setTimeout(() => { programmatic = false; }, PROG_GUARD);
    };

    // autoplay state machine: motionOK && inView && pageVisible && !interrupted
    let inView = false, pageVisible = !document.hidden, interrupted = false;
    let tick = 0, idle = 0;
    const canRun = () => !reduced && inView && pageVisible && !interrupted;
    const stop = () => { clearTimeout(tick); tick = 0; };
    const schedule = () => {
      stop();
      if (!canRun()) return;
      tick = window.setTimeout(() => {
        tick = 0;
        if (!canRun()) return;             // re-check at fire time: a gate may have flipped
        const next = nearestIndex() + 1;   // resume from where the user actually is
        goTo(next, next % N !== 0);        // smooth between panels; instant on the loop back to 0
        schedule();
      }, DELAY);
    };
    const resume = () => schedule();

    const interrupt = () => {
      interrupted = true;
      stop();
      clearTimeout(idle);
      idle = window.setTimeout(() => { interrupted = false; resume(); }, IDLE_RESUME);
    };

    // raw gestures interrupt instantly (wheel/trackpad don't always fire 'scroll' first)
    ['pointerdown', 'touchstart', 'wheel'].forEach((ev) => track.addEventListener(ev, interrupt, { passive: true }));

    // scroll: track the active dot live; a NON-programmatic scroll counts as interaction
    let scrollIdle = 0;
    track.addEventListener('scroll', () => {
      // user scroll: live dot tracking + interrupt autoplay. During our OWN smooth scroll
      // (programmatic) skip both, so the dot stays on goTo's destination (no rewind) and
      // autoplay never pauses itself.
      if (!programmatic) { setActive(nearestIndex()); interrupt(); }
      clearTimeout(scrollIdle);
      scrollIdle = window.setTimeout(() => {
        setActive(nearestIndex());   // settle the dot onto the snapped panel (manages `current`)
        programmatic = false;        // the scroll has stopped -> release the guard (every engine)
        clearTimeout(progTimer);
      }, 140);
    }, { passive: true });
    // snappier release where supported; the 140ms scroll-settle above is the cross-browser guarantee
    track.addEventListener('scrollend', () => {
      setActive(nearestIndex());
      programmatic = false; clearTimeout(progTimer);
    }, { passive: true } as any);

    // dots: tap to jump = explicit interrupt + go
    dots.forEach((d, i) => d.addEventListener('click', () => { interrupt(); goTo(i, true); }));

    // keyboard (no trap: dots stay in tab order, Tab still escapes)
    stage.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); interrupt(); goTo(current + 1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); interrupt(); goTo(current - 1); }
    });

    // gates: observe the TRACK (short) not the full-height stage, so a tall section still triggers
    const io = new IntersectionObserver((entries) => {
      inView = entries[0].isIntersecting;
      inView ? resume() : stop();
    }, { threshold: 0, rootMargin: '-20% 0px -20% 0px' });
    io.observe(track);

    const onVis = () => { pageVisible = !document.hidden; pageVisible ? resume() : stop(); };
    document.addEventListener('visibilitychange', onVis);

    goTo(0, false); // align panel 0 without animation; IO arms autoplay once on-screen

    // teardown: always clear timers; only sever the observers on a REAL unload. On a bfcache
    // freeze (pagehide persisted) keep the IO + visibilitychange so the page restores live.
    const teardown = (e?: PageTransitionEvent) => {
      stop(); clearTimeout(idle); clearTimeout(scrollIdle); clearTimeout(progTimer);
      if (e && e.persisted) return;
      io.disconnect();
      document.removeEventListener('visibilitychange', onVis);
    };
    window.addEventListener('pagehide', teardown);
    // bfcache restore (tap a card -> Back): the script does not re-run, so re-read the
    // visibility gate and re-arm autoplay.
    window.addEventListener('pageshow', (e) => {
      if (!e.persisted) return;
      pageVisible = !document.hidden;
      interrupted = false;
      resume();
    });
    // crossing the 820px line (tablet rotate / desktop resize) must re-init the matching
    // branch (mobile<->desktop); a reload is the simplest correct way and is rare on phones.
    const mq = matchMedia('(max-width: 820px)');
    mq.addEventListener?.('change', () => location.reload());
  }
</script>
