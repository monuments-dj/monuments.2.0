---
// Pattern library: the dial-able element library, rendered INLINE on the /lab hub
// (it lives on the labs page, no separate click-through). Sections alternate light
// (--paper) and dark (--bg) so the rhythm re-derives correctly under every color
// theme. Add an element = drop in another <section class="pl-sec pl-sec--*"> with a
// .pl-stage (the live element) + a .pl-ctrl (its dial). Keep them alternating.
---
<div class="pl">
  <!-- INTRO (light) -->
  <section class="pl-sec pl-sec--light pl-intro">
    <div class="pl-wrap">
      <p class="pl-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Pattern library</p>
      <h2 class="pl-title fade">Dial the building <em>blocks.</em></h2>
      <p class="pl-lead fade">Every reusable element in one place, each with its own live controls. Tune it here, then bake the winning settings into the real pages. Sections alternate light and dark on purpose: that contrast rhythm is going into the whole site as we go.</p>
      <p class="pl-note fade">The swatches bottom-left reskin everything live; the alternation flips with them.</p>
    </div>
  </section>

  <!-- ELEMENT 01: NEXT-PAGE SCROLLER (light) -->
  <section class="pl-sec pl-sec--light pl-el" id="next-page">
    <div class="pl-wrap">
      <div class="pl-el-head">
        <p class="pl-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span><span class="pl-num">01</span> Wayfinding</p>
        <h3 class="pl-el-title fade">Next-page scroller.</h3>
        <p class="pl-el-sub fade">A horizontal rail that fills as the reader moves down a page, then hands off to the next one. Pulled from the reference set. Scroll past it to watch it fill; dial the weight, width, fill color, and labels.</p>
      </div>

      <div class="pl-stage pl-stage--tall">
        <div class="np" data-np>
          <span class="np-keep" data-np-keep>Keep scrolling to learn more</span>
          <div class="np-row">
            <span class="np-section" data-np-section>About us</span>
            <a class="np-next" href="#next-page" aria-label="Next page">
              <span class="np-label">Next page</span>
              <span class="np-bar"><span class="np-fill" data-np-fill></span></span>
              <span class="np-arrow" aria-hidden="true">
                <svg viewBox="0 0 34 16" width="42" height="16" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="0" y1="8" x2="31" y2="8" /><path d="M24 2 L31 8 L24 14" /></svg>
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="pl-ctrl" data-np-ctrl>
        <label class="pl-field">
          <span class="pl-field-l">Bar weight <b data-np-hval>4</b> px</span>
          <input class="pl-range" type="range" min="2" max="14" value="4" step="1" data-np-h aria-label="Bar weight" />
        </label>
        <label class="pl-field">
          <span class="pl-field-l">Rail width <b data-np-wval>320</b> px</span>
          <input class="pl-range" type="range" min="160" max="540" value="320" step="10" data-np-w aria-label="Rail width" />
        </label>
        <div class="pl-seg" role="group" aria-label="Fill color">
          <button class="pl-seg-btn on" type="button" data-np-fillc="accent">Accent</button>
          <button class="pl-seg-btn" type="button" data-np-fillc="lime">Lime</button>
          <button class="pl-seg-btn" type="button" data-np-fillc="fg">Mono</button>
        </div>
        <label class="pl-check"><input type="checkbox" data-np-togglekeep checked /> Caption</label>
        <label class="pl-check"><input type="checkbox" data-np-togglesection checked /> Section label</label>
      </div>
    </div>
  </section>

  <!-- ELEMENT 02: REEL REVEAL (dark, pinned GSAP ScrollTrigger reveal) -->
  <section class="rr-section" id="reel-reveal" aria-label="Reel reveal">
    <div class="rr-stage" data-rr-stage>
      <p class="rr-kicker"><span class="lab-kicker-mark" aria-hidden="true">+</span>Work in motion</p>
      <button class="rr-panel" type="button" data-cursor="Play" aria-label="Play reel" data-rr-panel>
        <img class="rr-poster" src="/case-studies/sony-this-moment/gallery/tm-04.jpg" alt="Showreel still" />
      </button>
      <span class="rr-play" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z" /></svg></span>
      <span class="rr-word rr-word-l">Play</span>
      <span class="rr-word rr-word-r">Reel</span>
      <p class="rr-cap">Press play, and turn it up. Half the story is in the sound.</p>
    </div>
  </section>

  <!-- ON THE BENCH (light) -->
  <section class="pl-sec pl-sec--light pl-soon">
    <div class="pl-wrap">
      <p class="pl-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>On the bench</p>
      <p class="pl-soon-list fade">Next into this library: the photography galleries, the next-project teaser (and its reimagining), and the project-detail slider. Each will arrive with its own dial.</p>
    </div>
  </section>
</div>

<style>
  /* ---------- page frame + light/dark alternation ---------- */
  .pl { --pl-pad: clamp(64px, 9vw, 132px); background: var(--bg); }
  .pl-sec { padding: var(--pl-pad) var(--pad); }
  .pl-sec--dark { background: var(--bg); color: var(--fg); }
  .pl-sec--light { background: var(--paper); color: var(--ink); }
  .pl-wrap { max-width: var(--wrap); margin: 0 auto; }

  /* ---------- intro ---------- */
  /* kicker: inline-flex with the accent "+" marker; label muted via token alpha
     (so the "+" stays full accent, not dimmed by element opacity) */
  .pl-kicker { display: inline-flex; align-items: baseline; gap: 22px; font-size: 12px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; margin: 0 0 18px; color: rgb(var(--ink-rgb) / 0.75); }
  .pl-sec--dark .pl-kicker { color: rgb(var(--fg-rgb) / 0.75); }
  .lab-kicker-mark { color: var(--accent); font-weight: 500; }
  .pl-num { color: var(--accent); margin-right: 6px; }
  .pl-title { font-weight: 600; font-size: clamp(34px, 5vw, 72px); line-height: 1.0; letter-spacing: -0.03em; margin: 0 0 24px; }
  .pl-title em { font-style: italic; color: var(--accent); }
  .pl-lead { max-width: 62ch; font-size: clamp(16px, 1.4vw, 20px); font-weight: 300; line-height: 1.55; opacity: 0.9; margin: 0 0 14px; }
  .pl-note { font-size: 13px; opacity: 0.55; margin: 0; }

  /* ---------- per-element scaffold ---------- */
  .pl-el-head { max-width: 640px; margin: 0 0 clamp(40px, 5vw, 72px); }
  .pl-el-title { font-weight: 600; font-size: clamp(28px, 4vw, 54px); line-height: 1.02; letter-spacing: -0.02em; margin: 0 0 18px; }
  .pl-el-sub { font-size: clamp(15px, 1.3vw, 18px); font-weight: 300; line-height: 1.55; opacity: 0.82; margin: 0; }
  .pl-stage { position: relative; }
  .pl-stage--tall { min-height: 44vh; display: flex; align-items: center; }

  /* ---------- control panel (the dial) ---------- */
  .pl-ctrl { margin-top: clamp(34px, 4vw, 56px); display: flex; flex-wrap: wrap; align-items: center; gap: 14px 26px;
    padding: 16px 18px; border-radius: 14px; border: 1px solid color-mix(in srgb, currentColor 22%, transparent); background: color-mix(in srgb, currentColor 5%, transparent); }
  .pl-field { display: flex; flex-direction: column; gap: 7px; min-width: 168px; }
  .pl-field-l { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; }
  .pl-field-l b { font-weight: 700; opacity: 1; }
  .pl-range { -webkit-appearance: none; appearance: none; width: 100%; height: 3px; border-radius: 3px; background: color-mix(in srgb, currentColor 28%, transparent); cursor: pointer; }
  .pl-range::-webkit-slider-thumb { -webkit-appearance: none; width: 15px; height: 15px; border-radius: 50%; background: var(--accent); border: 2px solid var(--bg); cursor: pointer; }
  .pl-range::-moz-range-thumb { width: 15px; height: 15px; border-radius: 50%; background: var(--accent); border: 2px solid var(--bg); cursor: pointer; }
  .pl-seg { display: inline-flex; border: 1px solid currentColor; border-radius: 999px; overflow: hidden; }
  .pl-seg-btn { font: 600 12px/1 'Inter', sans-serif; letter-spacing: 0.04em; padding: 9px 15px; border: 0; background: transparent; color: currentColor; cursor: pointer; opacity: 0.62; transition: opacity 0.2s, background 0.2s; }
  .pl-seg-btn.on { opacity: 1; background: color-mix(in srgb, currentColor 14%, transparent); }
  .pl-check { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 400; cursor: pointer; user-select: none; }
  .pl-check input { accent-color: var(--accent); width: 15px; height: 15px; }

  /* ---------- ELEMENT 01: next-page scroller ---------- */
  .np { --np-h: 4px; --np-w: 320px; --np-fill-color: var(--accent); width: 100%; }
  .np-keep { display: block; font-size: 13px; font-weight: 400; letter-spacing: 0.04em; opacity: 0.6; margin: 0 0 clamp(36px, 6vw, 72px); text-transform: uppercase; }
  .np.np--nokeep .np-keep { display: none; }
  .np-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 28px; flex-wrap: wrap; }
  .np-section { font-weight: 600; font-size: clamp(30px, 5vw, 64px); line-height: 0.92; letter-spacing: -0.02em; text-transform: uppercase; }
  .np.np--nosection .np-section { display: none; }
  .np-next { display: inline-flex; align-items: center; gap: 16px; text-decoration: none; color: inherit; margin-left: auto; }
  .np-label { font-size: 13px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; }
  .np-bar { display: block; width: var(--np-w); max-width: 46vw; height: var(--np-h); border-radius: 999px; background: color-mix(in srgb, currentColor 22%, transparent); overflow: hidden; }
  .np-fill { display: block; height: 100%; width: calc(var(--np-progress, 0) * 100%); background: var(--np-fill-color); border-radius: 999px; transition: width 0.08s linear; }
  .np-arrow { display: inline-flex; transition: transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  .np-next:hover .np-arrow { transform: translateX(8px); }

  /* ---------- ELEMENT 02: reel reveal ---------- */
  /* ---------- ELEMENT 02: reel reveal (pinned GSAP ScrollTrigger) ---------- */
  /* Full-bleed dark stage that PINS; scroll scrubs the reveal. The film panel is
     base-sized to cover the viewport and starts scaled DOWN (scale 0.26), so it
     stays crisp when it scales back to full takeover. Words slide in from the
     sides as absolute layers. All animation is transform/opacity only. */
  .rr-section { background: var(--bg); color: var(--fg); }
  .rr-stage { position: relative; min-height: 100vh; min-height: 100svh; overflow: hidden; }
  .rr-kicker { position: absolute; top: clamp(28px, 6vh, 64px); left: 0; right: 0; z-index: 4; display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 13px; letter-spacing: 0.04em; color: rgb(var(--fg-rgb) / 0.7); margin: 0; }
  .rr-panel { position: absolute; inset: 0; margin: auto; width: 100vw; aspect-ratio: 16 / 10; padding: 0; border: 0; cursor: pointer; overflow: hidden; border-radius: 8px; background: #000;
    transform: scale(0.26); transform-origin: center center; will-change: transform; z-index: 2; box-shadow: 0 30px 70px rgb(0 0 0 / 0.5); }
  .rr-poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .rr-play { position: absolute; inset: 0; margin: auto; width: 60px; height: 60px; border-radius: 50%; z-index: 3; pointer-events: none; display: flex; align-items: center; justify-content: center; color: var(--fg); background: rgb(var(--fg-rgb) / 0.16); border: 1px solid rgb(var(--fg-rgb) / 0.55); backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px); }
  .rr-word { position: absolute; top: 50%; z-index: 3; font-weight: 400; font-size: clamp(40px, 10vw, 144px); line-height: 0.9; letter-spacing: -0.035em; white-space: nowrap; opacity: 0; will-change: transform, opacity; }
  .rr-word-l { left: clamp(16px, 8vw, 150px); }
  .rr-word-r { right: clamp(16px, 8vw, 150px); }
  .rr-cap { position: absolute; bottom: clamp(28px, 6vh, 64px); left: 0; right: 0; z-index: 4; text-align: center; max-width: 42ch; margin: 0 auto; padding: 0 var(--pad); font-size: clamp(15px, 1.3vw, 18px); font-weight: 300; line-height: 1.5; opacity: 0.72; }
  @media (max-width: 640px) { .rr-word { font-size: clamp(30px, 12vw, 72px); } }

  /* ---------- on-the-bench note ---------- */
  .pl-soon-list { max-width: 64ch; font-size: clamp(15px, 1.3vw, 18px); font-weight: 300; line-height: 1.6; opacity: 0.7; margin: 14px 0 0; }

  @media (max-width: 720px) {
    .np-row { align-items: flex-start; }
    .np-next { margin-left: 0; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ---- ELEMENT 01: next-page scroller ----
  (function () {
    const np = document.querySelector('[data-np]');
    if (!np) return;
    const section = np.closest('.pl-el') || np;
    const hVal = document.querySelector('[data-np-hval]');
    const wVal = document.querySelector('[data-np-wval]');

    // Fill tracks how far the element's section has travelled through the viewport.
    const LIME = '#c8ff00';
    let raf = 0;
    const update = () => {
      raf = 0;
      const r = section.getBoundingClientRect();
      const vh = window.innerHeight || 1;
      const p = (vh - r.top) / (vh + r.height);
      np.style.setProperty('--np-progress', String(Math.max(0, Math.min(1, p))));
    };
    const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
    addEventListener('scroll', onScroll, { passive: true });
    addEventListener('resize', onScroll, { passive: true });
    update();

    // Dial controls
    const hRange = document.querySelector('[data-np-h]');
    hRange && hRange.addEventListener('input', () => { np.style.setProperty('--np-h', hRange.value + 'px'); if (hVal) hVal.textContent = hRange.value; });
    const wRange = document.querySelector('[data-np-w]');
    wRange && wRange.addEventListener('input', () => { np.style.setProperty('--np-w', wRange.value + 'px'); if (wVal) wVal.textContent = wRange.value; });

    document.querySelectorAll('[data-np-fillc]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const v = btn.getAttribute('data-np-fillc');
        np.style.setProperty('--np-fill-color', v === 'lime' ? LIME : v === 'fg' ? 'currentColor' : 'var(--accent)');
        document.querySelectorAll('[data-np-fillc]').forEach((b) => b.classList.toggle('on', b === btn));
      });
    });
    const keep = document.querySelector('[data-np-togglekeep]');
    keep && keep.addEventListener('change', () => np.classList.toggle('np--nokeep', !keep.checked));
    const sec = document.querySelector('[data-np-togglesection]');
    sec && sec.addEventListener('change', () => np.classList.toggle('np--nosection', !sec.checked));
  })();

  // ---- ELEMENT 02: reel reveal (pinned scroll-scrub: words in from the sides, film takes over) ----
  (function () {
    const stage = document.querySelector('[data-rr-stage]');
    if (!stage) return;
    const panel = stage.querySelector('[data-rr-panel]');
    const wordL = stage.querySelector('.rr-word-l');
    const wordR = stage.querySelector('.rr-word-r');

    // Bridge GSAP <-> the existing Lenis so ScrollTrigger tracks the SMOOTHED scroll
    // position (one shared rAF loop, per the Lenis docs). window.lenis is set by Base
    // and is absent under reduced-motion; Base's standalone loop self-stops via the flag.
    function bridgeLenis() {
      if (window.__lenisGsapBridged) return true;
      if (!window.lenis) return false;        // Base sets window.lenis in a separate
      window.__lenisGsapBridged = true;       // script; in the prod bundle THIS script
      window.lenis.on('scroll', ScrollTrigger.update); // can run first, so wait for it.
      gsap.ticker.add((t) => window.lenis.raf(t * 1000));
      gsap.ticker.lagSmoothing(0);
      ScrollTrigger.refresh();
      return true;
    }
    if (!bridgeLenis()) {
      const iv = setInterval(() => { if (bridgeLenis()) clearInterval(iv); }, 50);
      setTimeout(() => clearInterval(iv), 4000);
    }

    const mm = gsap.matchMedia();
    // Full motion: pin the stage and scrub the reveal as the user scrolls through it.
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      gsap.set([wordL, wordR], { yPercent: -50 });
      const tl = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          trigger: stage,
          start: 'top top',
          end: () => '+=' + Math.round(window.innerHeight * 2.2),
          pin: true,
          scrub: 0.6,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });
      tl.fromTo(wordL, { xPercent: -260, autoAlpha: 0 }, { xPercent: 0, autoAlpha: 1, duration: 0.45 }, 0)
        .fromTo(wordR, { xPercent: 260, autoAlpha: 0 }, { xPercent: 0, autoAlpha: 1, duration: 0.45 }, 0)
        .fromTo(panel, { scale: 0.26 }, { scale: 1, duration: 0.55 }, 0.45)
        .to([wordL, wordR], { autoAlpha: 0, duration: 0.25 }, 0.62);
    });
    // Reduced motion: no pin/scroll animation, just a calm resting state.
    mm.add('(prefers-reduced-motion: reduce)', () => {
      gsap.set([wordL, wordR], { yPercent: -50, xPercent: 0, autoAlpha: 1 });
      gsap.set(panel, { scale: 0.42 });
    });

    // Recompute pin start/end after fonts + images settle.
    window.addEventListener('load', () => ScrollTrigger.refresh());
    ScrollTrigger.refresh();
  })();
</script>
