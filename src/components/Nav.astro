---
// Fixed top nav. The menu button toggles the fullscreen Menu component.
---
<!-- Wordmark lives OUTSIDE <nav>: the fixed nav's z-index makes a stacking
     context that would trap mix-blend-mode, so it must blend from its own layer. -->
<a class="nav-wm" href="/" aria-label="Monuments home">M<span class="nav-spark" aria-hidden="true">✳</span>NUMENTS</a>
<nav>
  <button class="nav-menu-btn" onclick="toggleMenu()" aria-label="Toggle menu">
    <span class="nav-btn-label">
      <span class="nav-btn-text nav-btn-menu">menu</span>
      <span class="nav-btn-text nav-btn-close">close</span>
    </span>
  </button>
</nav>
