---
// The monuments brand system (brand book v0.8), woven into the lab as one dark band:
// the M-eye-NUMENTS wordmark (eye blinks, spark pupil spins), the four-colour palette,
// the symbol family (auto-cycles, pauses on hover), a soft eye-sun, the voice lines and
// a Space Mono colophon. Brand colours are FIXED (ink/denim/rose) so the band reads as
// the brand regardless of the LabFx preset. Archivo + Space Mono load globally (Base).
// Source concept: tools/snaps/brand + the brand-into-lab workflow; brand file is at
// ~/Downloads/monuments-brand-book.html.
---
<section class="bw" id="brand" aria-label="Monuments brand system">
  <div class="field" aria-hidden="true">
    <div class="sun s1" id="sun-a"></div>
    <div class="sun s2" id="sun-b"></div>
  </div>

  <div class="inner">
    <p class="eyebrow">
      <span class="ic" aria-hidden="true">
        <svg viewBox="0 0 100 100"><g transform="translate(50,50)" fill="currentColor"><rect x="-3" y="-38" width="6" height="76" rx="3"/><rect x="-3" y="-38" width="6" height="76" rx="3" transform="rotate(60)"/><rect x="-3" y="-38" width="6" height="76" rx="3" transform="rotate(120)"/></g></svg>
      </span>
      <span>Lab &middot; The brand system, alive</span>
      <span class="rule"></span>
      <span class="no">NO. 004259</span>
    </p>

    <div class="hero">
      <div class="wordmark" aria-label="Monuments">
        <span>M</span>
        <span class="mk" aria-hidden="true">
          <svg viewBox="0 0 100 100">
            <path class="wm-eye" d="M8 50 C30 24 70 24 92 50 C70 76 30 76 8 50 Z" fill="none" stroke="currentColor" stroke-width="7"/>
            <g class="wm-spark" transform="translate(50,50)" fill="currentColor">
              <rect x="-3" y="-17" width="6" height="34" rx="3"/>
              <rect x="-3" y="-17" width="6" height="34" rx="3" transform="rotate(60)"/>
              <rect x="-3" y="-17" width="6" height="34" rx="3" transform="rotate(120)"/>
            </g>
          </svg>
        </span>
        <span>NUMENTS</span>
      </div>
      <div class="taglinerow">
        <p class="tagline">Built to be remembered<span class="dot">.</span></p>
        <p class="subline">One eye. One spark. Four colours. A small family of marks that knows what it is. This is the system, woven into the lab.</p>
      </div>
    </div>

    <div class="grid">
      <div>
        <p class="block-title"><span class="idx">01</span> <b>The palette</b> &middot; four colours, no negotiation</p>
        <div class="swatches">
          <div class="swatch">
            <div class="chip c-ink"><span class="role">Ground</span></div>
            <div class="meta"><div class="nm">Ink</div><div class="hex">#0A0A0A</div></div>
          </div>
          <div class="swatch">
            <div class="chip c-paper"><span class="role">Paper</span></div>
            <div class="meta"><div class="nm">Paper</div><div class="hex">#F4F4F2</div></div>
          </div>
          <div class="swatch">
            <div class="chip c-denim"><span class="role">Voice</span></div>
            <div class="meta"><div class="nm">Denim</div><div class="hex">#3E6E94</div></div>
          </div>
          <div class="swatch acc">
            <div class="chip c-rose"><span class="role">Accent</span></div>
            <div class="meta"><div class="nm">Rose</div><div class="hex">#EFA1AD</div></div>
          </div>
        </div>
        <p class="legend"><b>Rose is punctuation.</b> It ends a sentence. It never fills a paragraph. White space does the rest.</p>
      </div>

      <div>
        <p class="block-title"><span class="idx">02</span> <b>The symbol family</b> &middot; one grid, one weight</p>
        <div class="symbols" id="symbols">
          <div class="sym" data-name="spark"><svg viewBox="0 0 100 100"><path d="M50 6 C54 36 64 46 94 50 C64 54 54 64 50 94 C46 64 36 54 6 50 C36 46 46 36 50 6 Z" fill="currentColor"/></svg><span class="lab">Spark</span></div>
          <div class="sym" data-name="asterisk"><svg viewBox="0 0 100 100"><g transform="translate(50,50)" fill="currentColor"><rect x="-3" y="-38" width="6" height="76" rx="3"/><rect x="-3" y="-38" width="6" height="76" rx="3" transform="rotate(60)"/><rect x="-3" y="-38" width="6" height="76" rx="3" transform="rotate(120)"/></g></svg><span class="lab">Asterisk</span></div>
          <div class="sym" data-name="burst"><svg viewBox="0 0 100 100"><g transform="translate(50,50)" fill="currentColor"><rect x="-3" y="-40" width="6" height="80" rx="3"/><rect x="-3" y="-40" width="6" height="80" rx="3" transform="rotate(45)"/><rect x="-3" y="-40" width="6" height="80" rx="3" transform="rotate(90)"/><rect x="-3" y="-40" width="6" height="80" rx="3" transform="rotate(135)"/></g></svg><span class="lab">Burst</span></div>
          <div class="sym" data-name="eye"><svg viewBox="0 0 100 100"><path d="M14 50 C32 28 68 28 86 50 C68 72 32 72 14 50 Z" fill="none" stroke="currentColor" stroke-width="7"/><circle cx="50" cy="50" r="9" fill="currentColor"/></svg><span class="lab">Eye</span></div>
          <div class="sym" data-name="plus"><svg viewBox="0 0 100 100"><g transform="translate(50,50)" fill="currentColor"><rect x="-30" y="-5" width="60" height="10" rx="5"/><rect x="-5" y="-30" width="10" height="60" rx="5"/></g></svg><span class="lab">Plus</span></div>
          <div class="sym" data-name="obelisk"><svg viewBox="0 0 100 100"><path d="M40 90 L40 36 L50 16 L60 36 L60 90 Z" fill="currentColor"/><rect x="33" y="90" width="34" height="6" rx="2" fill="currentColor"/></svg><span class="lab">Obelisk</span></div>
          <div class="sym" data-name="aperture"><svg viewBox="0 0 100 100" id="ap-svg"></svg><span class="lab">Aperture</span></div>
          <div class="sym" data-name="eye-sun"><svg viewBox="0 0 100 100" id="es-sym"></svg><span class="lab">Eye-sun</span></div>
        </div>
        <p class="legend"><b>Same weight, same grid.</b> The spark is the pupil. The asterisk is the spark, unfurled. Hover any mark<span class="rosepunc"> &middot;</span> the lab cycles the family on its own.</p>
      </div>
    </div>

    <div class="foot">
      <div class="left">
        <span class="eyesun" id="eyesun" aria-hidden="true"></span>
        <div class="say">
          <div class="big">We build things worth remembering<span class="dot">.</span></div>
          <div class="small">Block out the noise. Keep the eye open.</div>
        </div>
      </div>
      <div class="colophon">
        MONUMENTS © 2026 <span class="star">&middot;</span> NO. 004259<br>
        EST. MMXXVI <span class="star">&middot;</span> LA / NY
      </div>
    </div>
  </div>
</section>

<style>
  .bw {
    --ink:#0A0A0A; --paper:#F4F4F2; --denim:#3E6E94; --rose:#EFA1AD;
    --panel:#121212; --line:#262626; --dim:#8A8A88;
    --grot:'Archivo',Helvetica,Arial,sans-serif; --mono:'Space Mono',monospace;
    position:relative; width:100%; overflow:hidden; background:var(--ink); color:var(--paper);
    font-family:var(--grot); padding:clamp(64px,10vw,130px) clamp(20px,5vw,72px); -webkit-font-smoothing:antialiased;
  }
  .bw .field{position:absolute;inset:0;pointer-events:none;z-index:0;overflow:hidden}
  .bw .field .sun{position:absolute;opacity:.05;will-change:transform}
  .bw .field .s1{top:-90px;right:-70px;width:340px;color:var(--denim);animation:bwDrift 38s linear infinite}
  .bw .field .s2{bottom:-130px;left:-90px;width:300px;color:var(--rose);opacity:.045;animation:bwDrift 52s linear infinite reverse}
  @keyframes bwDrift{to{transform:rotate(360deg)}}

  .bw .inner{position:relative;z-index:1;max-width:1180px;margin:0 auto}

  .bw .eyebrow{display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--dim);margin:0 0 30px}
  .bw .eyebrow .ic{width:15px;height:15px;color:var(--rose);flex:none}
  .bw .eyebrow .rule{flex:1;height:1px;background:var(--line)}

  .bw .hero{display:grid;grid-template-columns:1fr;gap:34px;padding-bottom:clamp(44px,6vw,68px);border-bottom:1px solid var(--line);margin-bottom:clamp(44px,6vw,68px)}
  .bw .wordmark{display:flex;align-items:center;gap:.06em;font-weight:900;line-height:.84;font-size:clamp(48px,12vw,164px);letter-spacing:-.02em;color:var(--paper)}
  .bw .wordmark .mk{display:inline-flex;width:.92em;height:.92em;color:var(--paper);position:relative;top:.02em;flex:none}
  .bw .wordmark .mk svg{width:100%;height:100%;overflow:visible}
  .bw .wm-eye{transform-box:fill-box;transform-origin:center;animation:bwBlink 7.2s ease-in-out infinite}
  @keyframes bwBlink{0%,92%,100%{transform:scaleY(1)}95.5%{transform:scaleY(.08)}}
  .bw .wm-spark{transform-box:fill-box;transform-origin:center;animation:bwSpin 11s linear infinite}
  @keyframes bwSpin{to{transform:rotate(360deg)}}

  .bw .taglinerow{display:flex;flex-wrap:wrap;align-items:baseline;gap:18px 30px}
  .bw .tagline{font-weight:800;font-size:clamp(20px,3.1vw,38px);letter-spacing:-.01em;color:var(--paper);margin:0}
  .bw .tagline .dot,.bw .rosepunc{color:var(--rose)}
  .bw .subline{font-family:var(--mono);font-size:13px;color:var(--dim);letter-spacing:.02em;max-width:34ch;line-height:1.55;margin:0}

  .bw .grid{display:grid;grid-template-columns:1fr;gap:clamp(40px,5vw,56px)}
  @media(min-width:880px){.bw .grid{grid-template-columns:1.05fr 1fr}}

  .bw .block-title{font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--dim);margin:0 0 22px;display:flex;align-items:center;gap:10px}
  .bw .block-title b{color:var(--paper);font-weight:700}
  .bw .block-title .idx{color:var(--rose)}

  .bw .swatches{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
  @media(min-width:540px){.bw .swatches{grid-template-columns:repeat(4,1fr)}}
  .bw .swatch{position:relative;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--panel);transition:transform .35s cubic-bezier(.2,.7,.2,1),border-color .35s;will-change:transform}
  .bw .swatch:hover{transform:translateY(-5px);border-color:#3a3a3a}
  .bw .swatch .chip{height:104px;width:100%;position:relative}
  .bw .swatch .meta{padding:11px 12px 13px;border-top:1px solid var(--line)}
  .bw .swatch .nm{font-weight:800;font-size:14px;letter-spacing:.01em;color:var(--paper)}
  .bw .swatch .hex{font-family:var(--mono);font-size:11.5px;color:var(--dim);margin-top:3px;text-transform:uppercase}
  .bw .swatch .role{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--dim);position:absolute;top:10px;left:11px}
  .bw .chip.c-ink{background:var(--ink)} .bw .chip.c-ink .role{color:var(--dim)}
  .bw .chip.c-paper{background:var(--paper)} .bw .chip.c-paper .role{color:var(--ink)}
  .bw .chip.c-denim{background:var(--denim)} .bw .chip.c-denim .role{color:#0f2335}
  .bw .chip.c-rose{background:var(--rose)} .bw .chip.c-rose .role{color:#5a2730}

  .bw .symbols{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .bw .sym{aspect-ratio:1;border:1px solid var(--line);border-radius:12px;background:var(--panel);display:flex;align-items:center;justify-content:center;position:relative;cursor:pointer;transition:border-color .3s,background .3s;color:var(--paper)}
  .bw .sym svg{width:46%;height:46%;overflow:visible;transition:transform .5s cubic-bezier(.2,.7,.2,1)}
  .bw .sym .lab{position:absolute;bottom:8px;left:0;right:0;text-align:center;font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);transition:color .3s}
  .bw .sym:hover{border-color:#3a3a3a;background:#161616}
  .bw .sym:hover svg{transform:scale(1.12) rotate(8deg)}
  .bw .sym:hover .lab{color:var(--paper)}
  .bw .sym.active{border-color:var(--rose)}
  .bw .sym.active .lab{color:var(--rose)}
  .bw .sym.active svg{transform:scale(1.14)}

  .bw .legend{font-family:var(--mono);font-size:11px;color:var(--dim);line-height:1.7;margin-top:18px;letter-spacing:.02em}
  .bw .legend b{color:var(--paper);font-weight:700}

  .bw .foot{margin-top:clamp(48px,6vw,72px);padding-top:clamp(32px,4vw,44px);border-top:1px solid var(--line);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:28px}
  .bw .foot .left{display:flex;align-items:center;gap:22px}
  .bw .eyesun{width:78px;height:78px;color:var(--denim);flex:none}
  .bw .eyesun svg{width:100%;height:100%;overflow:visible}
  .bw .eyesun .petals{transform-box:view-box;transform-origin:120px 120px;animation:bwSpin 60s linear infinite}
  .bw .foot .say{max-width:30ch}
  .bw .foot .say .big{font-weight:800;font-size:clamp(17px,2vw,22px);color:var(--paper);letter-spacing:-.01em;line-height:1.15}
  .bw .foot .say .big .dot{color:var(--rose)}
  .bw .foot .say .small{font-family:var(--mono);font-size:11.5px;color:var(--dim);margin-top:7px;line-height:1.55}
  .bw .colophon{font-family:var(--mono);font-size:11px;color:var(--dim);letter-spacing:.04em;text-align:right;line-height:1.7}
  .bw .colophon .star{color:var(--rose)}
  @media(max-width:560px){.bw .colophon{text-align:left}.bw .foot{justify-content:flex-start}}

  @media(prefers-reduced-motion:reduce){
    .bw .wm-eye,.bw .wm-spark,.bw .field .sun,.bw .eyesun .petals,.bw .sym.active svg{animation:none!important}
    .bw .swatch,.bw .sym svg{transition:none!important}
  }
</style>

<script>
  (function () {
    function petalPath(w, L) {
      return 'M0 0 C ' + (-w) + ' ' + (-L * 0.25) + ', ' + (-w) + ' ' + (-L * 0.78) + ', 0 ' + (-L) +
             ' C ' + w + ' ' + (-L * 0.78) + ', ' + w + ' ' + (-L * 0.25) + ', 0 0 Z';
    }
    function buildSun(opts) {
      var n = opts.n || 9, base = opts.base || 24, len = opts.len || 66, seed = opts.seed || 1;
      var rnd = function () { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };
      var g = '';
      for (var i = 0; i < n; i++) {
        var deg = (360 / n) * i + (rnd() - 0.5) * 6;
        var w = base * (0.62 + rnd() * 0.14);
        var L = len * (0.9 + rnd() * 0.2);
        g += '<g transform="translate(120,120) rotate(' + deg.toFixed(2) + ') translate(0,' + (-base) + ')">' +
             '<path d="' + petalPath(w, L) + '" fill="currentColor"/></g>';
      }
      return g;
    }
    function ambientSun(seed) {
      return '<svg viewBox="0 0 240 240" style="width:100%;height:auto;display:block">' +
             '<g>' + buildSun({ n: 9, base: 24, len: 66, seed: seed }) + '</g>' +
             '<circle cx="120" cy="120" r="34" fill="currentColor"/></svg>';
    }
    var sa = document.getElementById('sun-a'), sb = document.getElementById('sun-b');
    if (sa) sa.innerHTML = ambientSun(7);
    if (sb) sb.innerHTML = ambientSun(31);

    var es = document.getElementById('eyesun');
    if (es) {
      var petals = buildSun({ n: 9, base: 26, len: 62, seed: 17 });
      var coreEye = '<g transform="translate(120,120) scale(1.5)"><path d="M-36 0 C-18 -22 18 -22 36 0 C18 22 -18 22 -36 0 Z" fill="none" stroke="currentColor" stroke-width="7"/><circle cx="0" cy="0" r="10" fill="currentColor"/>' +
        '<g fill="#141414"><rect x="-2.2" y="-11" width="4.4" height="22" rx="2.2"/><rect x="-2.2" y="-11" width="4.4" height="22" rx="2.2" transform="rotate(60)"/><rect x="-2.2" y="-11" width="4.4" height="22" rx="2.2" transform="rotate(120)"/></g></g>';
      es.innerHTML = '<svg viewBox="0 0 240 240" style="width:100%;height:auto;display:block;overflow:visible"><g class="petals">' + petals + '</g>' + coreEye + '</svg>';
    }

    var esSym = document.getElementById('es-sym');
    if (esSym) {
      var p = '', n = 9, base = 11, len = 27, seed = 5;
      var rnd = function () { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };
      for (var i = 0; i < n; i++) {
        var deg = (360 / n) * i + (rnd() - 0.5) * 6, w = base * (0.62 + rnd() * 0.14), L = len * (0.9 + rnd() * 0.2);
        p += '<g transform="translate(50,50) rotate(' + deg.toFixed(2) + ') translate(0,' + (-base) + ')"><path d="' + petalPath(w, L) + '" fill="currentColor"/></g>';
      }
      esSym.innerHTML = p + '<circle cx="50" cy="50" r="9" fill="currentColor"/>';
    }

    var ap = document.getElementById('ap-svg');
    if (ap) {
      var s = '';
      for (var k = 0; k < 8; k++) {
        var a = k / 8 * 2 * Math.PI, cx = 50 + Math.cos(a) * 32, cy = 50 + Math.sin(a) * 32;
        s += '<circle cx="' + cx.toFixed(2) + '" cy="' + cy.toFixed(2) + '" r="5" fill="currentColor"/>';
      }
      ap.innerHTML = s + '<circle cx="50" cy="50" r="7" fill="none" stroke="currentColor" stroke-width="4"/>';
    }

    var syms = [].slice.call(document.querySelectorAll('#symbols .sym'));
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion:reduce)').matches;
    if (syms.length && !reduce) {
      var idx = 0, paused = false;
      syms.forEach(function (el) {
        el.addEventListener('mouseenter', function () { paused = true; });
        el.addEventListener('mouseleave', function () { paused = false; });
      });
      setInterval(function () {
        if (paused) return;
        syms.forEach(function (e) { e.classList.remove('active'); });
        idx = (idx + 1) % syms.length;
        syms[idx].classList.add('active');
      }, 1500);
      syms[0].classList.add('active');
    }
  })();
</script>
