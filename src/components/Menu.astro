---
// Fullscreen overlay menu. Links use local routes so navigation works in dev.
const links = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/photography', label: 'Photography' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/giving', label: 'Giving Back' },
  { href: '/contact', label: 'Contact' },
];
---
<div class="fullscreen-menu" id="fullscreen-menu">
  <ul class="menu-links">
    {links.map((l) => (
      <li>
        <a href={l.href} onclick="toggleMenu()">
          <span class="menu-link-text">{l.label}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="menu-footer">
    <div class="menu-contact">monuments.cc@gmail.com</div>
    <div class="menu-socials">
      <a href="http://instagram.com/djthecd" target="_blank">Instagram</a>
      <a href="http://threads.net/djthecd" target="_blank">Threads</a>
      <a href="http://linkedin.com/in/djthecd/" target="_blank">LinkedIn</a>
    </div>
  </div>

  <div class="menu-patches" aria-hidden="true">
    <span class="patch patch-ai"><svg class="pai-svg" viewBox="0 0 100 100" aria-hidden="true">
      <defs>
        <path id="aiTop" d="M22,50 A28,28 0 0 1 78,50" />
        <path id="aiBot" d="M24,54 A26,26 0 0 0 76,54" />
      </defs>
      <text class="pai-arc" text-anchor="middle"><textPath href="#aiTop" startOffset="50%">HUMAN + MACHINE</textPath></text>
      <text class="pai-arc pai-arc-b" text-anchor="middle"><textPath href="#aiBot" startOffset="50%">AI ENABLED</textPath></text>
      <g fill="none" stroke="#1d2f4a" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round">
        <!-- human forearm (left) + knuckle bumps -->
        <path d="M16,72 L39,59" />
        <path d="M18,68 L22,75" />
        <path d="M39,59 q4,-3 8,-1 q3,1.5 6,1.5" />
        <!-- robot forearm (right) — segmented + rivet -->
        <path d="M84,72 L61,59" />
        <path d="M70,64 l3,-5" /><path d="M76,67 l3,-5" />
        <circle cx="82" cy="70" r="2" fill="#1d2f4a" stroke="none" />
        <!-- robot blocky hand -->
        <path d="M61,59 l-6,-2 l1.5,5 l6,1" />
        <!-- clasp -->
        <path d="M47,60 q6,2.5 10,0" />
      </g>
    </svg></span>
    <span class="patch patch-story"><span class="ps-line">No Risk</span><span class="ps-line">No Story</span></span>
    <span class="patch patch-digital"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#0d0f14" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><polygon points="12,7 14,12 12,17 10,12" fill="#0d0f14" stroke="none"/><circle cx="12" cy="12" r="1.3" fill="#0d0f14" stroke="none"/></svg>Digital Native</span>
    <span class="patch patch-vibes"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M8.5 14a4.5 4.5 0 0 0 7 0" stroke-linecap="round"/><circle cx="9" cy="10" r="0.8" fill="#14181f" stroke="none"/><circle cx="15" cy="10" r="0.8" fill="#14181f" stroke="none"/></svg>Good<br>Vibes</span>
    <span class="patch patch-emmy"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h12v4a6 6 0 0 1-12 0V4z"/><path d="M6 5H4a2.5 2.5 0 0 0 2.6 3.6"/><path d="M18 5h2a2.5 2.5 0 0 1-2.6 3.6"/><line x1="12" y1="14" x2="12" y2="17"/><path d="M8.5 20h7l-1-3h-5z"/></svg>Emmy<br>Award<br>Winning</span>
    <span class="patch patch-camera"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><circle cx="12" cy="12" r="4.6"/><circle cx="12" cy="12" r="1.6" fill="#14181f" stroke="none"/><path d="M9.2 6.6a6 6 0 0 0-2.6 2.6" stroke-linecap="round"/></svg>Good at<br>camera<br>stuff</span>
    <span class="patch patch-idaho">
      <span class="pi-top">Outdoor Tradition</span>
      <span class="pi-mid">
        <span class="pi-script">Idaho</span>
        <svg class="pi-moose" viewBox="0 0 34 26" fill="#1c2f4a" aria-hidden="true"><path d="M6 25V14l-2-1-1-4 3 1 2 3h7l3-5 2 1-1 4 4 2 1-6 2 0-1 8-3 1v7h-2v-6h-9v6H8v-6z"/><path d="M22 9l3-5 1 1-2 5zM27 9l3-4 1 1-2 4z"/></svg>
      </span>
      <span class="pi-bot">Since 1890</span>
    </span>
    <span class="patch patch-california">
      <span class="pc-script">Los Angeles</span>
      <svg class="pc-city" viewBox="0 0 120 30" aria-hidden="true">
        <g fill="#16294a">
          <rect x="34" y="16" width="7" height="14"/><rect x="42" y="10" width="6" height="20"/><rect x="49" y="18" width="8" height="12"/>
          <rect x="58" y="7" width="6" height="23"/><rect x="65" y="14" width="9" height="16"/><rect x="75" y="11" width="6" height="19"/><rect x="82" y="17" width="7" height="13"/>
          <rect x="60.5" y="2" width="1.2" height="6"/>
        </g>
        <g stroke="#16294a" stroke-width="1.6" stroke-linecap="round" fill="none">
          <path d="M20 30V17"/><path d="M20 17c-3-2-6-1-8 0M20 17c3-2 6-1 8 0M20 17c-2-3-1-5 0-7M20 17c2-2 5-2 7-1M20 17c-2-2-5-2-7-1"/>
          <path d="M100 30V18"/><path d="M100 18c-3-2-6-1-8 0M100 18c3-2 6-1 8 0M100 18c-1-3-1-5 0-7M100 18c2-2 5-2 6-1M100 18c-2-2-5-2-6-1"/>
        </g>
      </svg>
    </span>
  </div>
</div>
