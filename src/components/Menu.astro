---
// Fullscreen overlay menu. Links use local routes so navigation works in dev.
const links = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/photography', label: 'Photography' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/giving', label: 'Giving Back' },
  { href: '/contact', label: 'Contact' },
];
---
<div class="fullscreen-menu" id="fullscreen-menu">
  <ul class="menu-links">
    {links.map((l) => (
      <li>
        <a href={l.href} onclick="toggleMenu()">
          <span class="menu-link-text">{l.label}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="menu-footer">
    <div class="menu-contact">monuments.cc@gmail.com</div>
    <div class="menu-socials">
      <a href="http://instagram.com/djthecd" target="_blank">Instagram</a>
      <a href="http://threads.net/djthecd" target="_blank">Threads</a>
      <a href="http://linkedin.com/in/djthecd/" target="_blank">LinkedIn</a>
    </div>
  </div>

  <div class="menu-patches" aria-hidden="true">
    <span class="patch patch-ai"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3.4V6"/><circle cx="12" cy="2.4" r="1.1" fill="#14181f" stroke="none"/><rect x="4.5" y="6" width="15" height="12" rx="3.5"/><circle cx="9.5" cy="11.4" r="1.2" fill="#14181f" stroke="none"/><circle cx="14.5" cy="11.4" r="1.2" fill="#14181f" stroke="none"/><path d="M9.8 14.7a2.6 2.6 0 0 0 4.4 0"/><path d="M2.6 10.5v3M21.4 10.5v3"/></svg>AI<br>Enabled!</span>
    <span class="patch patch-story"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.6" stroke-linejoin="round"><path d="M12 6c-2-1.4-5-1.4-7 0v12c2-1.4 5-1.4 7 0 2-1.4 5-1.4 7 0V6c-2-1.4-5-1.4-7 0z"/><path d="M12 6v12"/></svg>Storyteller<br>Certified</span>
    <span class="patch patch-digital"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#0d0f14" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><polygon points="12,7 14,12 12,17 10,12" fill="#0d0f14" stroke="none"/><circle cx="12" cy="12" r="1.3" fill="#0d0f14" stroke="none"/></svg>Digital Native</span>
    <span class="patch patch-vibes"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M8.5 14a4.5 4.5 0 0 0 7 0" stroke-linecap="round"/><circle cx="9" cy="10" r="0.8" fill="#14181f" stroke="none"/><circle cx="15" cy="10" r="0.8" fill="#14181f" stroke="none"/></svg>Good<br>Vibes</span>
    <span class="patch patch-emmy"><svg class="patch-icon" viewBox="0 0 24 24" fill="none" stroke="#14181f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h12v4a6 6 0 0 1-12 0V4z"/><path d="M6 5H4a2.5 2.5 0 0 0 2.6 3.6"/><path d="M18 5h2a2.5 2.5 0 0 1-2.6 3.6"/><line x1="12" y1="14" x2="12" y2="17"/><path d="M8.5 20h7l-1-3h-5z"/></svg>Emmy<br>Award<br>Winning</span>
  </div>
</div>
