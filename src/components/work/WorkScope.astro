---
// "What I did for them" — heading + body copy (left) + a services/scope list (right).
// Self-contained: owns its markup + styles so it drops into any template/category.
interface Props { heading: string; body: string[]; services: string[]; }
const { heading, body, services } = Astro.props;
---
<section class="wk-scope fade">
  <div class="wk-scope-left">
    <h2 class="wk-scope-h">{heading}</h2>
    {body.map((p) => <p class="wk-scope-p">{p}</p>)}
  </div>
  <ul class="wk-scope-services">
    {services.map((s) => <li>{s}</li>)}
  </ul>
</section>

<style>
  .wk-scope { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(40px, 6vw, 90px); align-items: start; max-width: var(--wrap); margin: 0 auto; padding: clamp(72px, 9vw, 120px) var(--pad); background: var(--white); }
  .wk-scope-h { font-family: 'Inter', sans-serif; font-weight: 600; font-size: clamp(28px, 3.6vw, 50px); letter-spacing: -0.025em; line-height: 1.04; color: #141519; margin-bottom: 30px; }
  .wk-scope-p { font-size: 15px; line-height: 1.75; font-weight: 300; color: rgba(20,21,25,0.78); max-width: 48ch; }
  .wk-scope-p + .wk-scope-p { margin-top: 1.1em; }
  .wk-scope-services { list-style: none; padding: 0; margin: 6px 0 0; }
  .wk-scope-services li { font-size: clamp(16px, 1.5vw, 20px); color: #141519; padding: 18px 0; border-bottom: 1px solid rgba(20,21,25,0.12); }
  .wk-scope-services li:last-child { border-bottom: 0; }
  @media (max-width: 820px) { .wk-scope { grid-template-columns: 1fr; gap: 36px; padding: 64px var(--pad); } }
</style>
