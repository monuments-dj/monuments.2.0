---
// Contained single-image slider cloned from the live portfolio pages' Elementor
// carousel: centered 946px stage, inset chevron arrows mid-image, 6px dot
// pagination below, 5s autoplay (pauses on hover), loops. Self-contained.
interface Props { images: string[]; alt: string; }
const { images, alt } = Astro.props;
---
<section class="ws fade" data-ws>
  <div class="ws-stage">
    <div class="ws-track">
      {images.map((src) => (
        <figure class="ws-slide"><img src={src} alt={alt} loading="lazy" /></figure>
      ))}
    </div>
    <button class="ws-btn ws-prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 4 L7 12 L15 20" /></svg>
    </button>
    <button class="ws-btn ws-next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 4 L17 12 L9 20" /></svg>
    </button>
  </div>
  <div class="ws-dots" role="tablist" aria-label="Slides"></div>
</section>

<style>
  .ws { width: min(946px, 76vw); margin: 0 auto; padding: clamp(70px, 8vw, 120px) 0 clamp(60px, 7vw, 90px); }
  .ws-stage { position: relative; overflow: hidden; }
  .ws-track { display: flex; transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1); }
  .ws-slide { flex: 0 0 100%; margin: 0; }
  .ws-slide img { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; display: block; }
  .ws-btn { position: absolute; top: 50%; transform: translateY(-50%); z-index: 2; border: 0; background: none; padding: 6px; cursor: pointer; color: rgba(252,252,252,0.9); filter: drop-shadow(0 1px 4px rgba(0,0,0,0.45)); transition: opacity 0.2s; opacity: 0.8; }
  .ws-btn:hover { opacity: 1; }
  .ws-prev { left: 4px; }
  .ws-next { right: 4px; }
  .ws-dots { display: flex; justify-content: center; gap: 12px; margin-top: 14px; }
  .ws-dots :global(button) { width: 6px; height: 6px; border-radius: 50%; border: 0; padding: 0; background: rgba(20,21,25,0.25); cursor: pointer; transition: background 0.2s; }
  .ws-dots :global(button.on) { background: #141519; }
  @media (max-width: 820px) { .ws { width: calc(100% - 2 * var(--pad)); } }
</style>

<script>
  document.querySelectorAll('[data-ws]').forEach((root) => {
    const track = root.querySelector('.ws-track');
    const slides = [...track.children];
    const dotsBox = root.querySelector('.ws-dots');
    let i = 0, timer;

    const dots = slides.map((_, n) => {
      const d = document.createElement('button');
      d.setAttribute('aria-label', `Slide ${n + 1}`);
      d.addEventListener('click', () => { go(n); restart(); });
      dotsBox.appendChild(d);
      return d;
    });

    const go = (n) => {
      i = (n + slides.length) % slides.length;
      track.style.transform = `translateX(-${i * 100}%)`;
      dots.forEach((d, k) => d.classList.toggle('on', k === i));
    };
    const restart = () => {
      clearInterval(timer);
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches)
        timer = setInterval(() => go(i + 1), 5000);
    };

    root.querySelector('.ws-prev').addEventListener('click', () => { go(i - 1); restart(); });
    root.querySelector('.ws-next').addEventListener('click', () => { go(i + 1); restart(); });
    root.addEventListener('mouseenter', () => clearInterval(timer));
    root.addEventListener('mouseleave', restart);
    go(0); restart();
  });
</script>
