---
import Base from '../../layouts/Base.astro';

// === Sony — This Moment — faithful rebuild of monuments.cc/portfolio/sony-this-moment ===
// Real campaign stills pulled from the live site into /public/case-studies/sony-this-moment.
const g = Array.from({ length: 9 }, (_, i) => `/case-studies/sony-this-moment/gallery/tm-${String(i + 1).padStart(2, '0')}.jpg`);
const meta = [
  { k: 'Client', v: 'Sony Audio' },
  { k: 'Agency', v: 'Art of Visuals' },
  { k: 'Production', v: 'MGX Creative' },
  { k: 'Director', v: 'Daniel Malikyar' },
  { k: 'Creative Direction', v: 'DJ Ramirez' },
  { k: 'Stills', v: 'Claire LeJune' },
];
---
<Base title="Sony — This Moment — monuments">
  <article class="bc-page">

    <!-- WORK HEADER (full-bleed image, big title, client logo + circled role, intro) -->
    <header class="wh" style="--wh-circle:#e0322d">
      <img class="wh-img" src={g[8]} alt="Sony — This Moment campaign" />
      <div class="wh-scrim"></div>
      <div class="wh-inner">
        <h1 class="wh-title">This<br>Moment</h1>
        <div class="wh-brandrow">
          <img class="wh-logo" src="/logos/sony.png" alt="Sony" />
          <span class="wh-role">
            creative direction
            <svg class="wh-circle" viewBox="0 0 240 92" aria-hidden="true" preserveAspectRatio="none">
              <path d="M116 11 C40 5, 12 28, 18 50 C25 74, 104 86, 162 82 C214 78, 232 56, 221 37 C209 17, 142 7, 60 14 C30 18, 15 33, 22 49" />
            </svg>
          </span>
        </div>
        <p class="wh-lede">Feeling overwhelmed shouldn't be the norm, but it's a feeling we can all relate to. When the world gets noisy, headphones aren't just a piece of tech, they're a device for creating an environment, a moment of peace and serenity no matter where you are or what may be happening around you. Along with Art of Visuals, I teamed up with Sony to highlight this moment. This moment is for you.</p>
        <a class="wh-all" href="/work">All Work <span aria-hidden="true">↗</span></a>
      </div>
    </header>

    <!-- INTRO: 2x2 photo grid + heading & copy (matches reference) -->
    <section class="wk-intro fade">
      <div class="wk-grid">
        <img src={g[0]} alt="Sony — This Moment" loading="lazy" />
        <img src={g[1]} alt="Sony — This Moment" loading="lazy" />
        <img src={g[2]} alt="Sony — This Moment" loading="lazy" />
        <img src={g[3]} alt="Sony — This Moment" loading="lazy" />
      </div>
      <div class="wk-intro-text">
        <h2 class="wk-intro-h">This Moment</h2>
        <p>Sony partnered with Art of Visuals to craft a campaign that underscores the value of taking time, trusting the process, and rediscovering inspiration. This initiative encourages creators to embrace moments of pause, demonstrating that true creativity flourishes when given the space to breathe and align with the natural flow of inspiration.</p>
        <p>As the creative director on this project, I helped shape the story, wrote the briefs, directed the stills, and made sure everything on set matched Sony's brand guides. I also worked closely with the production team through post, giving feedback on edits and prepping files for delivery. We cut the videos down from one minute to 30- and 15-second ads, and the stills were used for display ads.</p>
      </div>
    </section>

    <!-- WIDE PAIR -->
    <div class="bc-duo fade">
      <img src={g[4]} alt="Sony — This Moment" loading="lazy" />
      <img src={g[5]} alt="Sony — This Moment" loading="lazy" />
    </div>

    <!-- INSIGHT QUOTE -->
    <section class="bc-quote fade">
      <p>True creativity flourishes when given <span class="bc-quote-em">the space to breathe</span> and align with the natural flow of inspiration.</p>
      <p class="bc-quote-attr">The idea behind the campaign.</p>
    </section>

    <!-- FINAL SHOT -->
    <figure class="bc-shot fade">
      <img src={g[7]} alt="Sony — This Moment" loading="lazy" />
    </figure>

    <!-- META -->
    <div class="bc-meta fade">
      {meta.map((m) => (
        <div class="cs-meta-item">
          <span class="cs-meta-k">{m.k}</span>
          <span class="cs-meta-v">{m.v}</span>
        </div>
      ))}
    </div>

    <!-- NEXT -->
    <a class="cs-next" href="/work/sony-flow-state">
      <span class="cs-next-k">Next project</span>
      <span class="cs-next-t">Sony — Flow State <span class="cs-next-arrow">→</span></span>
    </a>

  </article>
</Base>
