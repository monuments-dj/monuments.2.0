---
import Base from '../../layouts/Base.astro';

// === Sony: Flow State, faithful rebuild of monuments.cc/portfolio/sony-flow-state-2 ===
// Real campaign stills pulled from the live site into /public/case-studies/sony-flow-state.
const g = Array.from({ length: 15 }, (_, i) => `/case-studies/sony-flow-state/gallery/fs-${String(i + 1).padStart(2, '0')}.jpg`);
const meta = [
  { k: 'Client', v: 'Sony Audio' },
  { k: 'Agency', v: 'Art of Visuals' },
  { k: 'Directors', v: 'Krizia Vega + DJ Ramirez' },
  { k: 'Creative Director', v: 'DJ Ramirez' },
  { k: 'DP', v: 'Joachim Zunke' },
  { k: 'Stills', v: 'Claire LeJune' },
];
---
<Base title="Sony: Flow State · monuments">
  <article class="bc-page">

    <!-- HERO (full-bleed image) -->
    <header class="bc-hero">
      <img class="bc-hero-img" src={g[1]} alt="Sony: Flow State campaign" />
      <div class="bc-hero-inner">
        <p class="bc-hero-eyebrow">Sony Audio · Creative Direction</p>
        <h1 class="bc-hero-title">Flow State</h1>
        <p class="bc-hero-lede">Find your flow.</p>
      </div>
    </header>

    <!-- INTRO -->
    <section class="bc-intro fade">
      <p>Sony partnered with Art of Visuals to craft a campaign that underscores the value of taking time, trusting the process, and rediscovering inspiration. This initiative encourages creators to embrace moments of pause, demonstrating that true creativity flourishes when given the space to breathe and align with the natural flow of inspiration.</p>
    </section>

    <!-- CAMPAIGN SHOT -->
    <figure class="bc-shot fade">
      <img src={g[0]} alt="Sony: Flow State" loading="lazy" />
    </figure>

    <!-- CAMPAIGN PAIR -->
    <div class="bc-duo fade">
      <img src={g[2]} alt="Sony: Flow State" loading="lazy" />
      <img src={g[3]} alt="Sony: Flow State" loading="lazy" />
    </div>

    <!-- INSIGHT QUOTE -->
    <section class="bc-quote fade">
      <p>Casting, creative briefs, even helping compose the music, <span class="bc-quote-em">every aspect aligned to Sony's identity.</span></p>
      <p class="bc-quote-attr">Creative Director + Co-Director.</p>
    </section>

    <!-- CAMPAIGN PAIR 2 -->
    <div class="bc-duo fade">
      <img src={g[4]} alt="Sony: Flow State" loading="lazy" />
      <img src={g[5]} alt="Sony: Flow State" loading="lazy" />
    </div>

    <!-- EXECUTION -->
    <section class="bc-exec fade">
      <h2 class="bc-exec-h">A crew of thirty, one vision.</h2>
      <div class="bc-exec-b">
        <p>As the Creative Director and Co-Director of this campaign, my responsibilities included developing the initial pitch, managing a film crew of 30+, and overseeing both video and still photography. This included casting, creative briefs, and helping compose the music.</p>
        <p>I ensured that every aspect of the production aligned with Sony's brand identity and that the products were showcased in their best light, from the first frame to final delivery.</p>
      </div>
    </section>

    <!-- SHOT -->
    <figure class="bc-shot fade">
      <img src={g[7]} alt="Sony: Flow State, on set" loading="lazy" />
    </figure>

    <!-- CAMPAIGN PAIR 3 -->
    <div class="bc-duo fade">
      <img src={g[8]} alt="Sony: Flow State" loading="lazy" />
      <img src={g[9]} alt="Sony: Flow State" loading="lazy" />
    </div>

    <!-- CAMPAIGN PAIR 4 -->
    <div class="bc-duo fade">
      <img src={g[11]} alt="Sony: Flow State" loading="lazy" />
      <img src={g[13]} alt="Sony: Flow State" loading="lazy" />
    </div>

    <!-- FINAL SHOT -->
    <figure class="bc-shot fade">
      <img src={g[14]} alt="Sony: Flow State" loading="lazy" />
    </figure>

    <!-- META -->
    <div class="bc-meta fade">
      {meta.map((m) => (
        <div class="cs-meta-item">
          <span class="cs-meta-k">{m.k}</span>
          <span class="cs-meta-v">{m.v}</span>
        </div>
      ))}
    </div>

    <!-- NEXT -->
    <a class="cs-next" href="/work/sony-xperia-summer">
      <span class="cs-next-k">Next project</span>
      <span class="cs-next-t">Sony: Summer w/ Xperia <span class="cs-next-arrow">→</span></span>
    </a>

  </article>
</Base>
