---
import Base from '../../layouts/Base.astro';

// === Waffle Me Up — faithful rebuild of monuments.cc/portfolio/waffle-me-up ===
// Real assets pulled from the live site into /public/case-studies/waffle-me-up.
const gallery = Array.from({ length: 8 }, (_, i) => `/case-studies/waffle-me-up/gallery/wmu-${String(i + 1).padStart(2, '0')}.jpg`);
const services = ['Brand Identity', 'Logo Design', 'Photography', 'E-Commerce', 'Web Design'];
const tags = ['Brand Refresh'];
---
<Base title="Waffle Me Up — monuments">
  <article class="cs2">

    <!-- HERO -->
    <header class="cs2-hero">
      <div class="cs2-hero-bg" style={`background-image:url(${gallery[2]})`}></div>
      <div class="cs2-hero-scrim"></div>
      <div class="cs2-hero-inner">
        <h1 class="cs2-hero-title">Waffle<br>Me Up</h1>
        <div class="cs2-hero-foot">
          <div class="cs2-tags">{tags.map((t) => <span class="cs2-tag">{t}</span>)}</div>
          <a class="cs2-allwork" href="/work">All Work <span aria-hidden="true">↗</span></a>
        </div>
      </div>
      <img class="cs2-hero-mark" src="/case-studies/waffle-me-up/logo.png" alt="Waffle Me Up mark" />
    </header>

    <!-- INTRO: services sidebar + lead -->
    <section class="cs2-intro fade">
      <aside class="cs2-side">
        <h2 class="cs2-side-h">Elevating the art of waffles — a brand refresh for Waffle Me Up.</h2>
        <ul class="cs2-services">{services.map((s) => <li>{s}</li>)}</ul>
      </aside>
      <div class="cs2-intro-body">
        <p>Waffle Me Up creates some of the best waffles in the world, and they wanted a brand that captured the passion, quality, and joy they bring to every bite. I initially designed their logo when they opened their first storefront, establishing a welcoming look that matched the warmth of their product. Years later, as they grew and needed a brand refresh, they came back to me to reimagine their identity and expand into e-commerce.</p>
        <p class="cs2-intro-kick">A returning client, a growing brand, and a product worth the wait.</p>
      </div>
    </section>

    <!-- LOGO CARD + note -->
    <section class="cs2-logo fade">
      <div class="cs2-logo-card">
        <img src="/case-studies/waffle-me-up/logo.png" alt="Waffle Me Up — World's Best Waffle" />
      </div>
      <div class="cs2-logo-aside">
        <p class="cs2-logo-note">World's best waffle, and a mark to match — warm, confident, and built to scale from the storefront to the shipping box.</p>
      </div>
    </section>

    <!-- PHOTO GRID -->
    <section class="cs2-gallery">
      <div class="cs2-gallery-badge" aria-hidden="true">
        <svg viewBox="0 0 100 100"><defs><path id="wmuBadge" d="M50,50 m-34,0 a34,34 0 1,1 68,0 a34,34 0 1,1 -68,0" /></defs>
          <text><textPath href="#wmuBadge" startOffset="0%">EDITORIAL · MADE FRESH · LOVINGLY CRAFTED · </textPath></text>
        </svg>
      </div>
      <div class="cs2-grid">
        {gallery.map((src, i) => <figure class={`cs2-cell c-${i % 6}`}><img src={src} alt="" loading="lazy" /></figure>)}
      </div>
    </section>

    <!-- CONCEPT / DESIGN / DELIVER -->
    <section class="cs2-cdd fade">
      <h2 class="cs2-cdd-head"><span class="on">Concept</span> <span>Design</span> <span>Deliver</span></h2>
      <div class="cs2-cdd-cols">
        <div class="cs2-cdd-col">
          <p>Working closely with the team, we took a deep dive into their brand story, focusing on the artistry and care behind each waffle. I designed new, elevated packaging and custom boxes to bring their product to life — from the moment it leaves the store to the first bite at home.</p>
          <p>Then we tackled the digital space, building out a streamlined online store that let them sell and ship waffles directly to customers nationwide. To strengthen the brand's visual identity, I directed and shot a series of editorial-style brand images, plus a behind-the-scenes video showing the hands-on care that goes into every batch.</p>
        </div>
        <div class="cs2-cdd-col">
          <p class="cs2-obj-h">Objectives</p>
          <ul class="cs2-obj">
            <li>Refresh a beloved identity without losing the warmth that made it work.</li>
            <li>Design elevated packaging that carries the experience from store to doorstep.</li>
            <li>Build an e-commerce store so the best waffles in the world could ship nationwide.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CREDITS -->
    <div class="cs2-credits fade">
      <div><span>Client</span>Waffle Me Up</div>
      <div><span>Creative Direction</span>DJ Ramirez</div>
      <div><span>Discipline</span>Brand · Photo · E-Commerce</div>
    </div>

    <!-- PRODUCT / EDITORIAL GRID -->
    <section class="cs2-products">
      <span class="cs2-check" aria-hidden="true">FRESH FRESH</span>
      <div class="cs2-prod-grid">
        {gallery.slice(0, 6).map((src) => <figure class="cs2-prod"><img src={src} alt="" loading="lazy" /></figure>)}
      </div>
    </section>

    <!-- NEXT PROJECT -->
    <a class="cs2-next" href="/work/flashpoint">
      <div class="cs2-next-bg" style={`background-image:url(${gallery[5]})`}></div>
      <div class="cs2-next-scrim"></div>
      <div class="cs2-next-inner">
        <span class="cs2-next-k">Next project</span>
        <span class="cs2-next-t">Flashpoint <span aria-hidden="true">→</span></span>
      </div>
    </a>

    <!-- CTA -->
    <section class="cs2-cta">
      <p>Let's build something great together.</p>
      <a href="/contact" class="cs2-cta-link">Let's Talk <span aria-hidden="true">↗</span></a>
    </section>

  </article>
</Base>
