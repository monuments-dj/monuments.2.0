---
import Base from '../layouts/Base.astro';

// Services, built from the source-of-truth brief. Creative direction leads;
// production is assumed, never the pitch. Studio "we" voice. No em dashes.
const services = [
  {
    n: '01',
    t: 'Creative Direction',
    d: "The reason brands bring us in. We set the idea, the look, and the story, then protect it through every decision that follows. Everything else serves this.",
  },
  {
    n: '02',
    t: 'Direction',
    d: "We direct commercials, brand films, and campaigns from first concept to final cut. One point of view, carried the whole way through.",
  },
  {
    n: '03',
    t: 'Brand Campaigns',
    d: "Not one-off clips. We concept and produce multi-asset campaigns with a through-line that holds across every placement.",
  },
  {
    n: '04',
    t: 'Creative Consulting',
    d: "Sometimes you don't need a crew, you need a sharper point of view. We help brands and teams clarify what they're making and why.",
  },
  {
    n: '05',
    t: 'End-to-End Production',
    d: "Full production and post, scaled to the job. The capability is assumed. We bring it so the idea never gets watered down on the way out.",
  },
];

// Craft that comes standard. Table stakes, not the headline.
const caps = [
  'Concept & Story', 'Commercials', 'Brand Films', 'Multi-Asset Campaigns',
  'Casting & Crew', 'Post & Finish', 'Color & Sound', 'Delivery',
];
---
<Base title="SERVICES · monuments">
  <article class="ip">

    <!-- HERO -->
    <header class="ip-hero fade">
      <span class="ip-eyebrow">What we do</span>
      <h1 class="ip-title">We come in at the<br><span class="acc">thinking layer.</span></h1>
      <p class="ip-lead">Creative direction and direction first. Production is assumed. We lead brand campaigns and films from the idea all the way to delivery, built for brands that need a point of view, not just a crew.</p>
    </header>

    <!-- POSITIONING -->
    <section class="band band-sand">
      <div class="sv-pos fade">
        <p class="band-kicker">How to think about us</p>
        <p class="sv-pos-lead">Monuments is a boutique studio. Selective and senior, with a team that scales around the work. Big brand or a single film, the same level of thinking shows up either way.</p>
      </div>
    </section>

    <!-- THE FIVE -->
    <section class="band band-slate">
      <p class="band-kicker fade">What we do</p>
      <div class="sv-list">
        {services.map((s) => (
          <a class="sv-row fade" href="/contact">
            <span class="sv-n">{s.n}</span>
            <div class="sv-main">
              <h2 class="sv-t">{s.t}</h2>
              <p class="sv-d">{s.d}</p>
            </div>
            <span class="sv-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- CAPABILITIES -->
    <section class="band band-cream">
      <p class="band-kicker fade">Comes standard</p>
      <div class="sv-caps fade">
        {caps.map((c) => <span class="sv-cap">{c}</span>)}
      </div>
    </section>

    <!-- FOCUS QUOTE -->
    <section class="band band-sand sv-focus">
      <blockquote class="sv-focus-q fade">
        <p>A man who chases two rabbits <span class="acc">doesn't eat.</span></p>
        <span class="sv-focus-sub">One idea, led all the way through. That is the whole job.</span>
      </blockquote>
    </section>

    <!-- CTA -->
    <section class="band band-black ip-cta">
      <div class="fade">
        <h2 class="ip-cta-h">Got something worth making?<br><span class="acc">Let's start the conversation.</span></h2>
        <div class="ip-cta-row">
          <a href="/work" class="ip-btn ip-btn-ghost">See the Work <span aria-hidden="true">→</span></a>
          <a href="/contact" class="ip-btn ip-btn-solid">Start a Project <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

  </article>
</Base>
