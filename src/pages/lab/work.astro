---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import BrandTicker from '../../components/BrandTicker.astro';

// === WORK V3 — /lab/work ===
// DJ: the horizontal-scroll version "looked nothing like the example" (exoape).
// Reworked to exoape's work model: a clean VERTICAL reel of large, staggered
// project cards. Each has inner-image parallax, the contextual "View" cursor on
// hover (data-cursor), and a "Brand — descriptor" caption. Tokenized colors.

const projects = [
  { slug: 'sony-this-moment',   brand: 'Sony',                desc: 'This Moment',            img: '/case-studies/sony-this-moment/gallery/tm-01.jpg',  align: 'left'  },
  { slug: 'blue-cross',         brand: 'Blue Cross of Idaho', desc: 'A campaign built on people', img: '/case-studies/blue-cross/gallery/bci-02.jpg',  align: 'right' },
  { slug: 'sony-xperia-summer', brand: 'Sony Xperia',         desc: 'Chase the sun',          img: '/case-studies/sony-xperia-summer/gallery/xp-01.jpg', align: 'left'  },
  { slug: 'turnstile',          brand: 'Turnstile',           desc: 'Built to be heard',      img: '/case-studies/turnstile/bts/bts-01.jpg',           align: 'right' },
  { slug: 'sony-flow-state',    brand: 'Sony',                desc: 'Flow State',             img: '/case-studies/sony-flow-state/gallery/fs-01.jpg',   align: 'left'  },
  { slug: 'flashpoint',         brand: 'Flashpoint',          desc: 'Shape the light',        img: '/case-studies/flashpoint/gallery/fp-01.jpg',        align: 'right' },
  { slug: 'waffle-me-up',       brand: 'Waffle Me Up',        desc: 'Worth the wait',         img: '/case-studies/waffle-me-up/gallery/wmu-01.jpg',     align: 'left'  },
  { slug: 'clothing-merch',     brand: 'Clothing & Merch',    desc: 'Built to be worn',       img: '/case-studies/clothing-merch/gallery/cm-01.jpg',    align: 'right' },
];
---
<Base title="Work — monuments">
  <main class="wk">
    <!-- INTRO -->
    <header class="wk-intro">
      <p class="wk-eyebrow fade">Selected work</p>
      <h1 class="wk-h1 split">The work, <em>in motion.</em></h1>
      <p class="wk-lead fade">Brand campaigns and commercials, concept through delivery. A few we are proud of.</p>
      <span class="wk-scrollcue" aria-hidden="true">Scroll</span>
    </header>

    <!-- SHOWREEL — the actual reel (DJ's YouTube). Muted ambient loop; click to
         play with sound. The contextual cursor reads "Play" over it. -->
    <section class="wk-showreel" data-cursor="Play">
      <div class="wk-reel-frame" data-reel>
        <iframe id="wkReel"
          src="https://www.youtube.com/embed/VMubUUZ2tdU?autoplay=1&mute=1&loop=1&playlist=VMubUUZ2tdU&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&start=6&iv_load_policy=3&fs=0&disablekb=1"
          frameborder="0" allow="autoplay; encrypted-media; fullscreen" title="Monuments showreel"></iframe>
        <button class="wk-reel-play" type="button" aria-label="Play the reel with sound">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
          <span>Play with sound</span>
        </button>
      </div>
      <p class="wk-reel-cap">The reel</p>
    </section>

    <!-- THE REEL — staggered vertical project cards w/ View cursor + parallax -->
    <section class="wk-reel">
      {projects.map((p, i) => (
        <a class={`wk-card wk-${p.align}`} href={`/work/${p.slug}`} data-card>
          <figure class="wk-card-media">
            <img src={p.img} alt={`${p.brand} — ${p.desc}`} loading={i < 2 ? 'eager' : 'lazy'} data-pimg />
            <span class="wk-card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          </figure>
          <div class="wk-card-meta">
            <span class="wk-card-name">{p.brand} <em>— {p.desc}</em></span>
            <span class="wk-card-go" aria-hidden="true">View <span>↗</span></span>
          </div>
        </a>
      ))}
    </section>

    <!-- CLOSING -->
    <section class="wk-end">
      <p class="wk-end-big split">Your brand belongs <em>in this reel.</em></p>
      <a class="wk-cta" href="/contact">Start a conversation <span aria-hidden="true">↗</span></a>
    </section>

    <BrandTicker tone="white" />
  </main>
  <LabFx />
</Base>

<style>
  .wk { position: relative; background: var(--bg); color: var(--fg); overflow-x: clip; }
  .wk-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }

  .wk-intro { position: relative; z-index: 1; min-height: 78vh; display: flex; flex-direction: column; justify-content: flex-end; max-width: var(--wrap); margin: 0 auto; padding: 168px var(--pad) 9vh; }
  .wk-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(46px, 8vw, 128px); line-height: 1; letter-spacing: -0.035em; margin-top: 20px; }
  .wk-h1 em, .wk-card-name em, .wk-end-big em { font-style: italic; color: var(--accent); }
  .wk-lead { margin-top: 26px; max-width: 460px; font-size: 16px; line-height: 1.7; font-weight: 300; color: rgb(var(--fg-rgb) / 0.78); }
  .wk-scrollcue { margin-top: 40px; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }

  /* SHOWREEL */
  .wk-showreel { position: relative; z-index: 1; max-width: 1500px; margin: 0 auto; padding: 2vh var(--pad) clamp(40px, 6vw, 80px); }
  .wk-reel-frame { position: relative; width: 100%; aspect-ratio: 16 / 9; overflow: hidden; border-radius: 6px; background: var(--deep); box-shadow: 0 40px 120px rgb(var(--ink-rgb) / 0.55); }
  .wk-reel-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; pointer-events: none; }
  .wk-reel-play { position: absolute; left: 50%; bottom: 22px; transform: translateX(-50%); z-index: 2; display: inline-flex; align-items: center; gap: 10px; padding: 13px 22px 13px 18px; border: 0; border-radius: 999px; cursor: pointer; background: rgb(var(--ink-rgb) / 0.55); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); color: var(--fg); font: 600 12px/1 'Inter', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; transition: background 0.25s ease, transform 0.25s ease; }
  .wk-reel-play:hover { background: var(--accent); color: var(--bg); transform: translateX(-50%) translateY(-2px); }
  .wk-reel-frame.playing .wk-reel-play { opacity: 0; pointer-events: none; }
  .wk-reel-frame.playing iframe { pointer-events: auto; }
  .wk-reel-cap { margin-top: 16px; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }

  /* THE REEL */
  .wk-reel { position: relative; z-index: 1; max-width: 1500px; margin: 0 auto; padding: 4vh var(--pad) clamp(80px, 10vw, 140px); display: flex; flex-direction: column; gap: clamp(80px, 14vh, 200px); }
  .wk-card { display: block; text-decoration: none; color: var(--fg); width: min(74%, 1040px); }
  .wk-left { align-self: flex-start; }
  .wk-right { align-self: flex-end; }
  .wk-card-media { position: relative; margin: 0; overflow: hidden; border-radius: 5px; aspect-ratio: 16 / 10.5; background: var(--deep); }
  .wk-card-media img { width: 100%; height: 122%; object-fit: cover; display: block; transform: translateY(var(--py, -11%)); transition: transform 0.9s cubic-bezier(0.16,1,0.3,1); will-change: transform; }
  .wk-card:hover .wk-card-media img { transform: translateY(var(--py, -11%)) scale(1.04); }
  .wk-card-num { position: absolute; left: 22px; top: 16px; font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(40px, 5vw, 80px); line-height: 1; color: rgb(var(--fg-rgb) / 0.85); mix-blend-mode: difference; }
  .wk-card-meta { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-top: 20px; }
  .wk-card-name { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(22px, 2.6vw, 40px); letter-spacing: -0.02em; }
  .wk-card-go { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.55); white-space: nowrap; transition: color 0.25s, transform 0.3s; }
  .wk-card:hover .wk-card-go { color: var(--accent); transform: translateX(5px); }

  /* CLOSING */
  .wk-end { position: relative; z-index: 1; min-height: 60vh; display: flex; flex-direction: column; gap: 40px; align-items: center; justify-content: center; text-align: center; padding: 60px var(--pad) 100px; }
  .wk-end-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(34px, 5vw, 72px); letter-spacing: -0.025em; line-height: 1.06; max-width: 16ch; }
  .wk-cta { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--bg); background: var(--fg); padding: 18px 30px; border-radius: 999px; text-decoration: none; transition: gap 0.3s ease, transform 0.3s ease; }
  .wk-cta:hover { gap: 18px; transform: translateY(-2px); }

  /* word masks (type-clip safe) */
  .wk :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .wk :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .wk :global(.split.on .wi) { transform: none; }

  @media (max-width: 860px) {
    .wk-card { width: 100%; align-self: stretch; }
    .wk-reel { gap: 60px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wk-card-media img { transform: none !important; }
    .wk :global(.split .wi) { transform: none !important; transition: none !important; }
  }
</style>

<script>
  // word splitter for masked headings
  const splitWords = (root, counter) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !node.closest('svg')) splitWords(node, counter);
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); } }), { threshold: 0.3 });
  document.querySelectorAll('.split').forEach((el) => io.observe(el));

  // inner-image parallax: each card image drifts at its own rate vs. the frame
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const imgs = [...document.querySelectorAll('[data-pimg]')];
  let ticking = false;
  const onScroll = () => {
    if (ticking) return; ticking = true;
    requestAnimationFrame(() => {
      const vh = innerHeight;
      imgs.forEach((img) => {
        const r = img.getBoundingClientRect();
        if (r.bottom < -100 || r.top > vh + 100) return;
        const c = (r.top + r.height / 2 - vh / 2) / vh; // -.. center .. +
        img.style.setProperty('--py', `${-11 + c * -7}%`);
      });
      ticking = false;
    });
  };
  if (!reduced) { addEventListener('scroll', onScroll, { passive: true }); onScroll(); }

  // Showreel: click to play with sound (swap the iframe to an unmuted, controllable embed)
  const reelFrame = document.querySelector('[data-reel]');
  const reelBtn = reelFrame && reelFrame.querySelector('.wk-reel-play');
  const reelIframe = document.getElementById('wkReel');
  if (reelBtn && reelIframe) {
    reelBtn.addEventListener('click', () => {
      reelIframe.src = 'https://www.youtube.com/embed/VMubUUZ2tdU?autoplay=1&mute=0&loop=1&playlist=VMubUUZ2tdU&controls=1&rel=0&modestbranding=1&playsinline=1&start=6';
      reelFrame.classList.add('playing');
    });
  }
</script>
