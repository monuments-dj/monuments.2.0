---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import BrandTicker from '../../components/BrandTicker.astro';

// === WORK LANDING V3 — /lab/work ===
// The signature SCROLL FEATURE: a horizontal-scroll gallery driven by vertical
// scroll. A tall pinned section holds a sticky 100vh viewport; inside, a .track
// of oversized project frames laid left-to-right. Vertical scroll progress p
// through the parent drives translateX = -(p * (trackWidth - viewportWidth)),
// computed on scroll via rAF, fully reversible. Each frame parallaxes its inner
// image, lifts on hover, carries a ghost NUMBER and a brand-tinted scrim, and
// links to /work/<slug>. Before: a bold "Selected work" intro. After: a
// vertical hover-preview INDEX with a cursor-following preview image, a closing
// CTA, and the BrandTicker. Reduced-motion collapses to a clean vertical stack.

const projects = [
  { slug: 'sony-this-moment',   brand: 'Sony',                title: 'This Moment',       role: 'Creative direction',   year: '2024',        img: '/case-studies/sony-this-moment/gallery/tm-01.jpg' },
  { slug: 'blue-cross',         brand: 'Blue Cross of Idaho', title: 'Built for life',    role: 'Creative direction',   year: '2020 – 2024', img: '/case-studies/blue-cross/gallery/bci-02.jpg' },
  { slug: 'sony-xperia-summer', brand: 'Sony Xperia',         title: 'Chase the sun',     role: 'Direction, stills',    year: '2023',        img: '/case-studies/sony-xperia-summer/gallery/xp-01.jpg' },
  { slug: 'turnstile',          brand: 'Turnstile',           title: 'Built to be heard', role: 'Brand, campaign',      year: '2023',        img: '/case-studies/turnstile/bts/bts-01.jpg' },
  { slug: 'sony-flow-state',    brand: 'Sony',                title: 'Flow State',        role: 'Creative direction',   year: '2023',        img: '/case-studies/sony-flow-state/gallery/fs-01.jpg' },
  { slug: 'flashpoint',         brand: 'Flashpoint',          title: 'Shape the light',   role: 'Creative direction',   year: '2022',        img: '/case-studies/flashpoint/gallery/fp-01.jpg' },
  { slug: 'waffle-me-up',       brand: 'Waffle Me Up',        title: 'Worth the wait',    role: 'Brand, content',       year: '2023',        img: '/case-studies/waffle-me-up/gallery/wmu-01.jpg' },
  { slug: 'clothing-merch',     brand: 'Clothing & Merch',    title: 'Built to be worn',  role: 'Design, production',   year: '2023',        img: '/case-studies/clothing-merch/gallery/cm-01.jpg' },
];

// Pinned parent height = (N + 1) * 100vh so the track has room to scrub fully.
const pinH = (projects.length + 1) * 100;
---
<Base title="WORK — monuments">
  <main class="wk">

    <!-- INTRO -->
    <header class="wk-intro">
      <p class="wk-eyebrow fade">Selected work</p>
      <h1 class="wk-h1 split">Scroll the <em>reel.</em> Every frame earned its place.</h1>
      <p class="wk-lead fade">Eight rooms we built for brands that needed to be felt, not just seen. Keep scrolling, the gallery moves with you.</p>
      <span class="wk-cue fade" aria-hidden="true">Scroll <span class="wk-cue-line"></span></span>
    </header>

    <!-- PINNED HORIZONTAL-SCROLL GALLERY -->
    <section class="wk-pin" data-pin style={`height:${pinH}vh`}>
      <div class="wk-stage" data-stage>
        <div class="wk-track" data-track>
          {projects.map((p, i) => (
            <a
              class="wk-frame"
              data-frame
              href={`/work/${p.slug}`}
              style={`--tint:${i % 2 === 0 ? 'var(--accent)' : 'var(--accent-2)'}`}
              aria-label={`${p.brand} — ${p.title}`}
            >
              <span class="wk-ghost" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="wk-media">
                <img src={p.img} alt={`${p.brand} — ${p.title}`} loading={i < 2 ? 'eager' : 'lazy'} decoding="async" data-pimg />
                <span class="wk-scrim" aria-hidden="true"></span>
              </span>
              <span class="wk-info">
                <span class="wk-brand">{p.brand}</span>
                <span class="wk-title">{p.title}</span>
                <span class="wk-meta">{p.role} · {p.year}</span>
              </span>
              <span class="wk-idx" aria-hidden="true">{String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}</span>
            </a>
          ))}
        </div>
        <!-- scrub progress rail -->
        <span class="wk-rail" aria-hidden="true"><span class="wk-rail-fill" data-rail></span></span>
      </div>
    </section>

    <!-- INDEX with cursor-following preview -->
    <section class="wk-index" id="index" data-index>
      <p class="wk-eyebrow fade">The full list</p>
      <ul class="wk-list">
        {projects.map((p, i) => (
          <li class="fade">
            <a class="wk-row" href={`/work/${p.slug}`} data-row data-img={p.img}>
              <span class="wk-row-n">{String(i + 1).padStart(2, '0')}</span>
              <span class="wk-row-t">{p.brand} <em>{p.title}</em></span>
              <span class="wk-row-meta">{p.role} · {p.year}</span>
            </a>
          </li>
        ))}
      </ul>
      <span class="wk-peek" data-peek aria-hidden="true"><img data-peek-img src="" alt="" /></span>
    </section>

    <!-- CLOSER -->
    <section class="wk-end">
      <p class="wk-end-big split">Your brand belongs <em>in this reel.</em></p>
      <a class="wk-cta fade" href="/contact">Start a conversation <span aria-hidden="true">↗</span></a>
    </section>

    <BrandTicker />

  </main>
  <LabFx />
</Base>

<style>
  .wk { background: var(--bg); color: var(--fg); overflow-x: clip; }
  .wk-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }

  /* ---------- INTRO ---------- */
  .wk-intro {
    position: relative; z-index: 1; min-height: 86vh;
    display: flex; flex-direction: column; justify-content: flex-end;
    max-width: var(--wrap); margin: 0 auto; padding: 168px var(--pad) 9vh;
  }
  .wk-h1 {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(44px, 7.4vw, 124px); line-height: 1; letter-spacing: -0.03em;
    max-width: 16ch; margin: 22px 0 0;
  }
  .wk-h1 em, .wk-end-big em, .wk-row-t em { font-style: italic; color: var(--accent); }
  .wk-lead {
    margin-top: 34px; max-width: 46ch; font-weight: 300;
    font-size: clamp(16px, 1.5vw, 21px); line-height: 1.5;
    color: rgb(var(--fg-rgb) / 0.72);
  }
  .wk-cue {
    margin-top: 44px; display: inline-flex; align-items: center; gap: 14px;
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgb(var(--fg-rgb) / 0.6);
  }
  .wk-cue-line { display: inline-block; width: 64px; height: 1px; background: var(--accent); transform-origin: left; animation: wkCue 2.4s ease-in-out infinite; }
  @keyframes wkCue { 0%, 100% { transform: scaleX(0.3); opacity: 0.4; } 50% { transform: scaleX(1); opacity: 1; } }

  /* ---------- PINNED HORIZONTAL GALLERY ---------- */
  .wk-pin { position: relative; }
  .wk-stage {
    position: sticky; top: 0; height: 100vh; overflow: hidden;
    display: flex; align-items: center; background: var(--bg);
  }
  .wk-track {
    display: flex; align-items: center; gap: clamp(28px, 3.6vw, 72px);
    padding: 0 clamp(28px, 6vw, 120px); height: 100%;
    will-change: transform;
  }
  .wk-frame {
    position: relative; flex: 0 0 auto;
    width: clamp(320px, 64vw, 920px); height: min(76vh, 760px);
    border-radius: 8px; overflow: hidden;
    text-decoration: none; color: var(--fg);
    background: var(--deep);
    transform: translateY(0) scale(1);
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .wk-frame:hover { transform: translateY(-12px) scale(1.012); box-shadow: 0 40px 90px -40px rgba(0,0,0,0.7); }

  /* ghost project number, sits behind the media */
  .wk-ghost {
    position: absolute; z-index: 0; top: -0.18em; left: -0.04em;
    font-family: 'Inter', sans-serif; font-weight: 500;
    font-size: clamp(180px, 30vw, 460px); line-height: 1; letter-spacing: -0.04em;
    color: rgb(var(--fg-rgb) / 0.06); pointer-events: none;
  }

  .wk-media { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
  .wk-media img {
    width: 100%; height: 124%; object-fit: cover; display: block;
    transform: translateY(var(--py, -12%)); will-change: transform;
  }
  /* brand-color scrim, frame-tinted */
  .wk-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgb(var(--ink-rgb) / 0.78), rgb(var(--ink-rgb) / 0.05) 52%),
      linear-gradient(140deg, color-mix(in srgb, var(--tint) 32%, transparent), transparent 46%);
    mix-blend-mode: normal;
  }

  .wk-info {
    position: absolute; z-index: 2; left: clamp(20px, 2.6vw, 42px); right: clamp(20px, 2.6vw, 42px);
    bottom: clamp(20px, 2.6vw, 40px);
    display: flex; flex-direction: column; gap: 6px;
  }
  .wk-brand { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.82); }
  .wk-title {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(30px, 3.4vw, 60px); line-height: 1.06; letter-spacing: -0.03em;
    padding-bottom: 0.06em;
  }
  .wk-meta { font-size: 13px; font-weight: 300; color: rgb(var(--fg-rgb) / 0.72); margin-top: 4px; }
  .wk-idx {
    position: absolute; z-index: 2; top: clamp(18px, 2.2vw, 30px); right: clamp(18px, 2.2vw, 30px);
    font-size: 12px; letter-spacing: 0.18em; color: rgb(var(--fg-rgb) / 0.6);
  }

  /* scrub progress rail along the bottom of the stage */
  .wk-rail {
    position: absolute; z-index: 3; left: clamp(28px, 6vw, 120px); right: clamp(28px, 6vw, 120px);
    bottom: clamp(22px, 3vh, 40px); height: 2px; background: rgb(var(--fg-rgb) / 0.14); border-radius: 2px;
  }
  .wk-rail-fill { display: block; height: 100%; width: 0%; background: var(--accent); border-radius: 2px; }

  /* ---------- INDEX ---------- */
  .wk-index { position: relative; max-width: var(--wrap); margin: 0 auto; padding: clamp(110px, 14vw, 180px) var(--pad) 40px; }
  .wk-list { list-style: none; margin: 30px 0 0; padding: 0; }
  .wk-row {
    position: relative; display: grid; grid-template-columns: 60px 1fr auto; align-items: baseline; gap: 28px;
    padding: 26px 6px; color: var(--fg); text-decoration: none;
    border-top: 1px solid rgb(var(--fg-rgb) / 0.13);
    transition: padding-left 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
  }
  .wk-list li:last-child .wk-row { border-bottom: 1px solid rgb(var(--fg-rgb) / 0.13); }
  .wk-row:hover { padding-left: 22px; }
  .wk-row-n { font-size: 12px; letter-spacing: 0.18em; color: rgb(var(--fg-rgb) / 0.45); }
  .wk-row-t {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(22px, 2.6vw, 40px); letter-spacing: -0.02em; line-height: 1.1;
  }
  .wk-row-meta { font-size: 13px; color: rgb(var(--fg-rgb) / 0.5); white-space: nowrap; }

  /* cursor-following preview image */
  .wk-peek {
    position: fixed; z-index: 60; top: 0; left: 0; width: 260px; aspect-ratio: 3/2;
    border-radius: 5px; overflow: hidden; pointer-events: none;
    opacity: 0; transform: translate(-50%, -50%) scale(0.9) rotate(-2deg);
    transition: opacity 0.28s ease, transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 30px 70px -30px rgba(0,0,0,0.8);
  }
  .wk-peek.live { opacity: 1; transform: translate(-50%, -50%) scale(1) rotate(-2deg); }
  .wk-peek img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ---------- CLOSER ---------- */
  .wk-end {
    min-height: 56vh; display: flex; flex-direction: column; gap: 40px;
    align-items: center; justify-content: center; text-align: center;
    padding: 60px var(--pad) clamp(80px, 11vw, 130px);
  }
  .wk-end-big {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(34px, 5.2vw, 78px); letter-spacing: -0.025em; line-height: 1.08;
    max-width: 18ch;
  }
  .wk-cta {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--bg); background: var(--accent);
    padding: 18px 32px; border-radius: 999px; text-decoration: none;
    transition: gap 0.3s ease, transform 0.3s ease, filter 0.3s ease;
  }
  .wk-cta:hover { gap: 18px; transform: translateY(-2px); filter: brightness(1.08); }

  /* ---------- word-reveal masks (type-clip safe) ---------- */
  .wk :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .wk :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .wk :global(.split.on .wi) { transform: none; }

  /* ---------- responsive ---------- */
  @media (max-width: 820px) {
    .wk-frame { width: 84vw; height: 64vh; }
    .wk-row { grid-template-columns: 44px 1fr; gap: 16px; }
    .wk-row-meta { grid-column: 2; }
    .wk-peek { display: none; }
  }

  /* ---------- reduced motion: collapse to a clean vertical stack ---------- */
  @media (prefers-reduced-motion: reduce) {
    .wk-pin { height: auto !important; }
    .wk-stage { position: static; height: auto; display: block; }
    .wk-track {
      flex-direction: column; height: auto; gap: clamp(20px, 4vw, 48px);
      transform: none !important; padding: 6vh var(--pad);
      max-width: var(--wrap); margin: 0 auto;
    }
    .wk-frame { width: 100%; height: auto; aspect-ratio: 16/10; transform: none !important; }
    .wk-frame:hover { transform: none !important; box-shadow: none; }
    .wk-media img { transform: none !important; height: 100%; }
    .wk-rail { display: none; }
    .wk-cue-line { animation: none; }
    .wk :global(.split .wi) { transform: none !important; transition: none !important; }
  }
</style>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clamp01 = (v) => Math.min(1, Math.max(0, v));

  // --- word-split util for the masked headings ---
  const splitWords = (root, counter) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1) splitWords(node, counter);
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));
  const io = new IntersectionObserver(
    (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); } }),
    { threshold: 0.3 }
  );
  document.querySelectorAll('.split, .fade').forEach((el) => io.observe(el));

  if (!reduced) {
    // ===========================================================
    // HORIZONTAL-SCROLL GALLERY
    // Vertical scroll progress p through the pinned parent drives
    // translateX = -(p * (trackWidth - viewportWidth)). rAF, reversible.
    // ===========================================================
    const pin = document.querySelector('[data-pin]');
    const stage = document.querySelector('[data-stage]');
    const track = document.querySelector('[data-track]');
    const rail = document.querySelector('[data-rail]');
    const imgs = [...document.querySelectorAll('[data-pimg]')];

    let maxX = 0;
    let vw = innerWidth;
    const measure = () => {
      vw = stage ? stage.clientWidth : innerWidth;
      maxX = track ? Math.max(0, track.scrollWidth - vw) : 0;
    };
    measure();
    addEventListener('resize', () => { measure(); onScroll(); }, { passive: true });
    // re-measure once images have settled (gives the track its true width)
    addEventListener('load', () => { measure(); onScroll(); });

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        if (pin && track) {
          const r = pin.getBoundingClientRect();
          const span = pin.offsetHeight - innerHeight;
          const p = clamp01(-r.top / (span || 1));
          const x = -(p * maxX);
          track.style.transform = `translate3d(${x}px, 0, 0)`;
          if (rail) rail.style.width = (p * 100).toFixed(2) + '%';

          // per-frame inner-image parallax: each image drifts at a rate offset
          // from its position in the viewport, so media travels slower than the
          // frame it rides in.
          imgs.forEach((img) => {
            const fr = img.getBoundingClientRect();
            const center = fr.left + fr.width / 2;
            const off = (center - vw / 2) / vw; // -1..1 across the viewport
            img.style.setProperty('--py', `${-12 + off * -8}%`);
          });
        }
        ticking = false;
      });
    };
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ===========================================================
    // INDEX cursor-following preview
    // ===========================================================
    const peek = document.querySelector('[data-peek]');
    const peekImg = document.querySelector('[data-peek-img]');
    const rows = [...document.querySelectorAll('[data-row]')];
    if (peek && peekImg && matchMedia('(pointer: fine)').matches) {
      let px = 0, py = 0, tx = 0, ty = 0, raf = 0, active = false;
      const follow = () => {
        px += (tx - px) * 0.18;
        py += (ty - py) * 0.18;
        peek.style.left = px + 'px';
        peek.style.top = py + 'px';
        raf = requestAnimationFrame(follow);
        if (!active && Math.abs(tx - px) < 0.4 && Math.abs(ty - py) < 0.4) { cancelAnimationFrame(raf); raf = 0; }
      };
      rows.forEach((row) => {
        row.addEventListener('pointerenter', () => {
          const src = row.getAttribute('data-img');
          if (src && peekImg.getAttribute('src') !== src) peekImg.setAttribute('src', src);
          active = true; peek.classList.add('live');
          if (!raf) follow();
        });
        row.addEventListener('pointermove', (e) => { tx = e.clientX; ty = e.clientY; if (!raf) follow(); });
        row.addEventListener('pointerleave', () => { active = false; peek.classList.remove('live'); });
      });
    }
  }
</script>
