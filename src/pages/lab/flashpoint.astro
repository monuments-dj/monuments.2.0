---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import Lightbox from '../../components/Lightbox.astro';
import NextProject from '../../components/NextProject.astro';

// === /lab/flashpoint — TEST PAGE ===
// A light-forward lab case study for the Flashpoint rebrand (Adorama's photography-gear
// label). Brand is teal + orange on white, so the assets (packaging + print mockups)
// float as cards on a --paper ground; --fp-teal / --fp-orange are brand-literal accents.
// Beats: hero, the brief (services + lead), the IMAGINE / ILLUMINATE / CREATE concept,
// the system gallery (mockups, parallax drift), the work spanned, credits, then a DARK
// next-project scroller closer into This Moment (the pattern from sony-this-moment).
// Copy = the real /work/flashpoint case-study text, de-em-dashed, restructured. Motion =
// split/fade reveals + drift parallax + the scroll-fill rail. Tokenized for LabFx reskin.

const gallery = Array.from({ length: 8 }, (_, i) => `/case-studies/flashpoint/gallery/fp-${String(i + 1).padStart(2, '0')}.jpg`);
const services = ['Brand Identity', 'Logo Design', 'Brand Positioning', 'Packaging Design', 'Product Design', 'Messaging'];
const spanned = [
  'A fresh brand image and sharper messaging.',
  'A redesigned website built for a better experience.',
  'Revamped packaging that carries the new identity.',
  'Out-of-home campaigns with real presence on the street.',
];
const credits = [
  { k: 'Agency', v: 'Art of Visuals' },
  { k: 'Client', v: 'Adorama' },
  { k: 'Art Director', v: 'Dannie Nicholson' },
  { k: 'Creative Direction', v: 'DJ Ramirez' },
];
---
<Base title="Flashpoint, the Lab">
  <main class="fp">
    <!-- HERO -->
    <header class="fp-hero">
      <div class="fp-hero-frames" aria-hidden="true">
        <figure class="fp-float fp-float-a" data-drift="7"><img src={gallery[0]} alt="" loading="eager" decoding="async" /></figure>
        <figure class="fp-float fp-float-b" data-drift="11"><img src={gallery[3]} alt="" loading="eager" decoding="async" /></figure>
      </div>
      <div class="fp-hero-inner">
        <a class="fp-back" href="/lab" data-cursor="Back">&larr; The Lab</a>
        <p class="fp-eyebrow fade"><span class="fp-mark" aria-hidden="true">+</span>Case study &middot; Full rebrand</p>
        <h1 class="fp-h1 split">Flashpoint</h1>
        <p class="fp-tag fade">Imagine. Illuminate. <em>Create.</em></p>
        <p class="fp-meta fade">A full rebrand for Adorama's photography-gear label. Identity, packaging, product, and messaging, pulled into one voice.</p>
      </div>
      <div class="fp-cue fade" data-cursor="Scroll" aria-hidden="true"><span>Scroll</span><i></i></div>
    </header>

    <!-- THE BRIEF: services + lead -->
    <section class="fp-brief">
      <aside class="fp-brief-side">
        <h2 class="fp-brief-h split">Built to work. Made to <em>last.</em></h2>
        <ul class="fp-services">{services.map((s) => <li class="fade">{s}</li>)}</ul>
      </aside>
      <div class="fp-brief-body">
        <p class="fp-lead fade">Flashpoint, a private label under Adorama, makes top-quality lighting and photography gear at prices that work for pros and enthusiasts alike. The reputation was strong, but the brand had drifted out of step with a fast-moving industry.</p>
        <p class="fp-body fade">As Creative Director, DJ led the project alongside his team at Art of Visuals. Together they rebuilt Flashpoint's identity into a modern, cohesive image that put the brand back where it belongs: a trusted leader in photography.</p>
      </div>
    </section>

    <!-- CONCEPT: IMAGINE / ILLUMINATE / CREATE -->
    <section class="fp-concept" data-concept>
      <p class="fp-kicker fade"><span class="fp-mark" aria-hidden="true">+</span>The idea</p>
      <h2 class="fp-concept-head">
        <span class="fp-word" data-cw>Imagine</span>
        <span class="fp-word" data-cw>Illuminate</span>
        <span class="fp-word" data-cw>Create</span>
      </h2>
      <p class="fp-concept-sub fade">The objective was simple to say and hard to earn: make Flashpoint synonymous with innovation, quality, and value. A top-to-bottom effort, a fresh brand image, sharper messaging, and a visual identity that carries across every surface, from the box on the shelf to the billboard on the street.</p>
    </section>

    <!-- THE SYSTEM: the mockups, floating -->
    <section class="fp-system">
      <div class="fp-sys-head">
        <p class="fp-kicker fade"><span class="fp-mark" aria-hidden="true">+</span>The system</p>
        <h2 class="fp-sys-title split">One voice, every <em>surface.</em></h2>
      </div>
      <div class="fp-grid">
        {gallery.map((src, i) => (
          <figure class={`fp-cell fp-cell-${i % 5} fade`} data-drift={3 + (i % 3) * 2}>
            <a href={src} data-lb-full={src} data-lb-group="fp" data-cursor="View" aria-label="Open image">
              <img src={src} alt="" loading="lazy" decoding="async" />
            </a>
          </figure>
        ))}
      </div>
    </section>

    <!-- THE WORK SPANNED -->
    <section class="fp-spanned">
      <p class="fp-kicker fade"><span class="fp-mark" aria-hidden="true">+</span>The work spanned</p>
      <ol class="fp-span-list">
        {spanned.map((s, i) => (
          <li class="fp-span fade">
            <span class="fp-span-n">0{i + 1}</span>
            <span class="fp-span-t">{s}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- CREDITS -->
    <section class="fp-credits">
      <dl class="fp-cred-list">
        {credits.map((c) => (
          <div class="fp-cred fade"><dt>{c.k}</dt><dd>{c.v}</dd></div>
        ))}
      </dl>
    </section>

    <!-- NEXT PROJECT — reusable hand-off: growing media cluster + scroll-to-next -->
    <NextProject
      href="/lab/sony-this-moment"
      name="This Moment"
      tag="Sony · Brand film"
      accent="#16a3ab"
      poster="/case-studies/sony-this-moment/gallery/tm-04.jpg"
      photos={["/case-studies/sony-this-moment/gallery/tm-02.jpg", "/case-studies/sony-this-moment/gallery/tm-07.jpg"]}
    />

    <Lightbox />
  </main>
  <LabFx />
</Base>

<style>
  .fp { --fp-teal: #16a3ab; --fp-orange: #f0612a; background: var(--paper); color: var(--ink); overflow-x: clip; }
  .fp em { font-style: italic; color: var(--fp-teal); }
  .fp-mark { color: var(--fp-orange); font-weight: 500; margin-right: 20px; }
  .fp-eyebrow, .fp-kicker { display: inline-flex; align-items: baseline; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.72); margin: 0; }

  /* ---------- HERO ---------- */
  .fp-hero { position: relative; min-height: 100vh; min-height: 100svh; display: flex; align-items: center; overflow: hidden; padding: 16vh 0 12vh; }
  .fp-hero-inner { position: relative; z-index: 3; max-width: var(--wrap, 1300px); margin: 0 auto; padding: 0 var(--pad); width: 100%; }
  .fp-hero-inner::before { content: ''; position: absolute; inset: -6vh -10%; z-index: -1; pointer-events: none; background: radial-gradient(120% 84% at 38% 50%, color-mix(in srgb, var(--paper) 88%, transparent) 0%, color-mix(in srgb, var(--paper) 55%, transparent) 46%, transparent 78%); }
  .fp-back { display: inline-block; margin-bottom: clamp(20px, 4vh, 40px); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.55); text-decoration: none; transition: color 0.25s ease; }
  .fp-back:hover { color: var(--fp-teal); }
  .fp-h1 { font-family: 'Inter', sans-serif; font-weight: 700; font-size: clamp(56px, 13vw, 220px); line-height: 0.9; letter-spacing: -0.05em; margin: 14px 0 0; text-transform: uppercase; }
  .fp-tag { margin: clamp(18px, 2.4vw, 30px) 0 0; font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(22px, 3vw, 44px); letter-spacing: -0.02em; color: var(--ink); }
  .fp-meta { margin: 26px 0 0; max-width: 50ch; font-size: clamp(15px, 1.3vw, 18px); line-height: 1.7; font-weight: 300; color: rgb(var(--ink-rgb) / 0.66); }

  .fp-hero-frames { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .fp-float { position: absolute; margin: 0; border-radius: 10px; overflow: hidden; box-shadow: 0 40px 90px rgb(var(--ink-rgb) / 0.18); will-change: transform; }
  .fp-float img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fp-float-a { right: 4vw; top: 16vh; width: clamp(280px, 36vw, 560px); aspect-ratio: 3/2; }
  .fp-float-b { right: 30vw; bottom: 10vh; width: clamp(160px, 18vw, 300px); aspect-ratio: 4/3; }
  @media (max-width: 900px) { .fp-hero-frames { opacity: 0.16; } .fp-float-b { display: none; } }

  .fp-cue { position: absolute; left: 50%; bottom: 24px; transform: translateX(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 8px; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.5); }
  .fp-cue i { width: 1px; height: 34px; background: linear-gradient(var(--fp-teal), transparent); animation: fpCue 1.8s ease-in-out infinite; transform-origin: top; }
  @keyframes fpCue { 0%,100% { transform: scaleY(0.4); opacity: 0.4; } 50% { transform: scaleY(1); opacity: 1; } }

  /* ---------- shared section frame ---------- */
  .fp-brief, .fp-concept, .fp-system, .fp-spanned, .fp-credits { max-width: var(--wrap, 1300px); margin: 0 auto; padding: clamp(80px, 12vw, 160px) var(--pad); }

  /* ---------- BRIEF ---------- */
  .fp-brief { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(36px, 6vw, 100px); align-items: start; }
  .fp-brief-h { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(26px, 3vw, 44px); line-height: 1.1; letter-spacing: -0.025em; }
  .fp-services { list-style: none; margin: clamp(28px, 3vw, 44px) 0 0; padding: 0; }
  .fp-services li { font-size: 14px; letter-spacing: 0.02em; color: rgb(var(--ink-rgb) / 0.7); padding: 11px 0; border-top: 1px solid rgb(var(--ink-rgb) / 0.12); }
  .fp-lead { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(20px, 2.1vw, 30px); line-height: 1.4; letter-spacing: -0.015em; margin: 0; }
  .fp-body { margin: 26px 0 0; max-width: 56ch; font-size: clamp(15px, 1.2vw, 17px); line-height: 1.72; font-weight: 300; color: rgb(var(--ink-rgb) / 0.72); }

  /* ---------- CONCEPT ---------- */
  .fp-concept { text-align: center; }
  .fp-concept-head { display: flex; flex-direction: column; align-items: center; gap: clamp(4px, 1vh, 14px); margin: clamp(28px, 4vw, 54px) 0; font-family: 'Inter', sans-serif; font-weight: 600; font-size: clamp(48px, 11vw, 168px); line-height: 0.94; letter-spacing: -0.04em; text-transform: uppercase; }
  .fp-word { color: rgb(var(--ink-rgb) / 0.16); transition: color 0.6s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1); transform: translateY(0.18em); }
  .fp-word.on { transform: translateY(0); }
  .fp-word.lit:nth-child(1) { color: var(--fp-orange); }
  .fp-word.lit:nth-child(2) { color: var(--fp-teal); }
  .fp-word.lit:nth-child(3) { color: var(--ink); }
  .fp-concept-sub { max-width: 64ch; margin: 0 auto; font-size: clamp(15px, 1.3vw, 18px); line-height: 1.74; font-weight: 300; color: rgb(var(--ink-rgb) / 0.68); }

  /* ---------- SYSTEM (mockup gallery) ---------- */
  .fp-sys-head { max-width: 640px; margin-bottom: clamp(40px, 5vw, 72px); }
  .fp-sys-title { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(30px, 4.4vw, 64px); line-height: 1.04; letter-spacing: -0.03em; margin-top: 14px; }
  .fp-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: clamp(14px, 1.6vw, 26px); }
  .fp-cell { margin: 0; border-radius: 8px; overflow: hidden; background: rgb(var(--ink-rgb) / 0.04); box-shadow: 0 22px 50px rgb(var(--ink-rgb) / 0.12); will-change: transform; }
  .fp-cell a { display: block; }
  .fp-cell img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s cubic-bezier(0.16,1,0.3,1); }
  .fp-cell:hover img { transform: scale(1.04); }
  /* a varied editorial layout across a 6-col grid */
  .fp-cell-0 { grid-column: span 4; aspect-ratio: 16/10; }
  .fp-cell-1 { grid-column: span 2; aspect-ratio: 3/4; }
  .fp-cell-2 { grid-column: span 2; aspect-ratio: 3/4; }
  .fp-cell-3 { grid-column: span 4; aspect-ratio: 16/10; }
  .fp-cell-4 { grid-column: span 3; aspect-ratio: 4/3; }
  .fp-cell:nth-child(6) { grid-column: span 3; aspect-ratio: 4/3; }
  .fp-cell:nth-child(7) { grid-column: span 3; aspect-ratio: 4/3; }
  .fp-cell:nth-child(8) { grid-column: span 3; aspect-ratio: 4/3; }

  /* ---------- SPANNED ---------- */
  .fp-span-list { list-style: none; margin: clamp(24px, 3vw, 40px) 0 0; padding: 0; }
  .fp-span { display: grid; grid-template-columns: 64px 1fr; gap: clamp(18px, 3vw, 44px); align-items: baseline; padding: clamp(24px, 2.6vw, 36px) 6px; border-top: 1px solid rgb(var(--ink-rgb) / 0.12); }
  .fp-span:last-child { border-bottom: 1px solid rgb(var(--ink-rgb) / 0.12); }
  .fp-span-n { font-size: 14px; letter-spacing: 0.14em; color: var(--fp-teal); font-variant-numeric: tabular-nums; }
  .fp-span-t { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(20px, 2.4vw, 34px); line-height: 1.2; letter-spacing: -0.02em; color: var(--ink); }

  /* ---------- CREDITS ---------- */
  .fp-cred-list { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(20px, 3vw, 50px); }
  .fp-cred dt { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.5); }
  .fp-cred dd { margin: 10px 0 0; font-family: 'Inter', sans-serif; font-size: clamp(16px, 1.5vw, 21px); letter-spacing: -0.01em; color: var(--ink); }

  /* ---------- reveals ---------- */
  .fp :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .fp :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .fp :global(.split.on .wi) { transform: none; }
  .fp .fade { opacity: 0; transform: translateY(16px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1); }
  .fp .fade.on { opacity: 1; transform: none; }

  /* ---------- responsive ---------- */
  @media (max-width: 860px) {
    .fp-brief { grid-template-columns: 1fr; gap: 36px; }
    .fp-grid { grid-template-columns: repeat(2, 1fr); }
    .fp-cell-0, .fp-cell-1, .fp-cell-2, .fp-cell-3, .fp-cell-4,
    .fp-cell:nth-child(6), .fp-cell:nth-child(7), .fp-cell:nth-child(8) { grid-column: span 1; aspect-ratio: 4/3; }
    .fp-cred-list { grid-template-columns: 1fr 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fp-cue i { animation: none; }
    .fp :global(.split .wi) { transform: none !important; transition: none !important; }
    .fp .fade { opacity: 1 !important; transform: none !important; }
    .fp-word { transform: none !important; }
    .fp-float { transform: none !important; }
  }
</style>

<script>
  // word splitter (line-safe, descender-safe clip)
  const splitWords = (root: Node, counter: { n: number }) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !(node as Element).closest('svg')) {
        splitWords(node, counter);
      }
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));

  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // on-enter reveals
  const io = new IntersectionObserver((es) => es.forEach((e) => {
    if (e.isIntersecting) { (e.target as HTMLElement).classList.add('on'); io.unobserve(e.target); }
  }), { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.split, .fade').forEach((el) => io.observe(el));

  // concept triad: each word slides up + lights in its brand colour, staggered
  const cw = [...document.querySelectorAll('[data-cw]')] as HTMLElement[];
  const cio = new IntersectionObserver((es) => es.forEach((e) => {
    if (e.isIntersecting) {
      cw.forEach((w, i) => setTimeout(() => { w.classList.add('on', 'lit'); }, i * 220));
      cio.disconnect();
    }
  }), { threshold: 0.5 });
  if (cw.length) cio.observe(cw[0].parentElement as Element);

  // subtle parallax drift on the floating frames + gallery cells
  const drifts = [...document.querySelectorAll('[data-drift]')] as HTMLElement[];
  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      drifts.forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.bottom < 0 || r.top > innerHeight) return;
        const c = (r.top + r.height / 2 - innerHeight / 2) / innerHeight;
        const v = Number(el.dataset.drift || 6);
        el.style.transform = `translateY(${c * -v * 6}px)`;
      });
      ticking = false;
    });
  };
  if (!reduced) {
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
