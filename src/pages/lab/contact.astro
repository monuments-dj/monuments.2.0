---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import FloatingHand from '../../components/FloatingHand.astro';

// === CONTACT V2 — /lab/contact ===
// Modern, fresh, easy (DJ's words on the reference menus). One giant email
// link as the hero move, a short "what to expect," socials, and the patches
// finally escaping the menu: three draggable badges to toss around (idea 9).
// CTA language per the brand doc: start a conversation, never "hire a crew."
---
<Base title="Contact — monuments">
  <main class="ct2">

    <!-- HERO: the email IS the page -->
    <header class="ct2-hero">
      <FloatingHand side="right" top="20vh" />
      <p class="ct2-eyebrow fade">Contact</p>
      <h1 class="ct2-h1 split">Let's start <em>a conversation.</em></h1>
      <a class="ct2-mail" href="mailto:monuments.cc@gmail.com" data-mail>
        <span class="ct2-mail-t">monuments.cc<wbr>@gmail.com</span>
        <svg class="ct2-stroke" viewBox="0 0 600 18" preserveAspectRatio="none" aria-hidden="true"><path d="M6 12 C140 4, 380 16, 594 7" /></svg>
      </a>
      <p class="ct2-sub fade">No form. No funnel. Tell us what you're trying to move and a human writes back.</p>
    </header>

    <!-- EXPECT -->
    <section class="ct2-expect">
      <div class="ct2-expect-grid">
        <div class="ct2-card fade">
          <span class="ct2-card-n">01</span>
          <h2 class="ct2-card-t">Within a day</h2>
          <p class="ct2-card-d">A real reply from a real person. Not an autoresponder, ever.</p>
        </div>
        <div class="ct2-card fade">
          <span class="ct2-card-n">02</span>
          <h2 class="ct2-card-t">One honest read</h2>
          <p class="ct2-card-d">If we're not right for it, we'll say so and point you somewhere good.</p>
        </div>
        <div class="ct2-card fade">
          <span class="ct2-card-n">03</span>
          <h2 class="ct2-card-t">Then the work</h2>
          <p class="ct2-card-d">A conversation, a clear brief, and a number. No mystery, no maze.</p>
        </div>
      </div>
    </section>

    <!-- SOCIALS + PLAY -->
    <section class="ct2-low">
      <div class="ct2-socials">
        <p class="ct2-eyebrow fade">Elsewhere</p>
        <ul class="ct2-soc-list">
          <li class="fade"><a href="https://www.instagram.com/monuments.cc/" target="_blank" rel="noopener">Instagram <span aria-hidden="true">↗</span></a></li>
          <li class="fade"><a href="https://www.tiktok.com/@monuments.cc" target="_blank" rel="noopener">TikTok <span aria-hidden="true">↗</span></a></li>
          <li class="fade"><a href="https://www.linkedin.com/" target="_blank" rel="noopener">LinkedIn <span aria-hidden="true">↗</span></a></li>
        </ul>
      </div>
      <p class="ct2-hint fade" aria-hidden="true">PS the badges move. Nothing here is allowed to be boring.</p>
    </section>

    <!-- Escaped patches (decorative, draggable) -->
    <div class="ct2-patches" aria-hidden="true">
      <span class="ct2-patch p1" data-patch>IDAHO</span>
      <span class="ct2-patch p2" data-patch>NO RISK<br>NO STORY</span>
      <span class="ct2-patch p3" data-patch>GOOD AT<br>CAMERA STUFF</span>
    </div>

  </main>
  <LabFx />
</Base>

<style>
  .ct2 { position: relative; background: var(--black); color: var(--white); overflow-x: clip; }
  .ct2-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }

  .ct2-hero { position: relative; min-height: 78vh; display: flex; flex-direction: column; justify-content: center; max-width: var(--wrap); margin: 0 auto; padding: 170px var(--pad) 60px; }
  .ct2-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(40px, 5.6vw, 84px); line-height: 1.02; letter-spacing: -0.03em; margin-top: 20px; }
  .ct2-h1 em { font-style: italic; color: var(--accent); }
  .ct2-mail { position: relative; width: fit-content; margin-top: 6vh; color: var(--white); text-decoration: none; }
  .ct2-mail-t { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(30px, 5.6vw, 86px); letter-spacing: -0.035em; line-height: 1; word-break: break-word; }
  .ct2-mail:hover .ct2-mail-t { color: var(--accent); transition: color 0.25s; }
  .ct2-stroke { position: absolute; left: 0; bottom: -14px; width: 100%; height: 16px; overflow: visible; }
  .ct2-stroke path { fill: none; stroke: var(--accent); stroke-width: 4; stroke-linecap: round; stroke-dasharray: 640; stroke-dashoffset: var(--moff, 640); transition: stroke-dashoffset 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s; }
  .ct2-mail.on .ct2-stroke path { --moff: 0; }
  .ct2-sub { margin-top: 7vh; max-width: 480px; font-size: 15px; line-height: 1.7; font-weight: 300; color: rgb(var(--fg-rgb) / 0.7); }

  .ct2-expect { background: var(--white); color: var(--ink); padding: clamp(90px, 11vw, 150px) 0; }
  .ct2-expect-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 3vw, 40px); max-width: var(--wrap); margin: 0 auto; padding: 0 var(--pad); }
  .ct2-card { border-top: 1px solid rgb(var(--ink-rgb) / 0.2); padding-top: 18px; }
  .ct2-card-n { font-size: 12px; letter-spacing: 0.18em; color: rgb(var(--ink-rgb) / 0.4); }
  .ct2-card-t { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 21px; margin-top: 12px; }
  .ct2-card-d { margin-top: 10px; font-size: 14.5px; line-height: 1.65; font-weight: 300; color: rgb(var(--ink-rgb) / 0.72); }

  .ct2-low { max-width: var(--wrap); margin: 0 auto; padding: clamp(80px, 10vw, 130px) var(--pad); display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; }
  .ct2-soc-list { list-style: none; margin: 22px 0 0; padding: 0; display: flex; gap: clamp(24px, 4vw, 56px); }
  .ct2-soc-list a { font-family: 'Inter', sans-serif; font-size: clamp(18px, 1.8vw, 24px); color: var(--white); text-decoration: none; opacity: 0.8; transition: opacity 0.2s; }
  .ct2-soc-list a:hover { opacity: 1; }
  .ct2-hint { font-size: 12px; letter-spacing: 0.06em; color: rgb(var(--fg-rgb) / 0.4); max-width: 240px; text-align: right; }

  .ct2-patches { position: absolute; inset: 0; pointer-events: none; z-index: 5; }
  .ct2-patch { position: absolute; pointer-events: auto; cursor: grab; user-select: none; display: grid; place-items: center; text-align: center; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 11px; letter-spacing: 0.12em; line-height: 1.5; padding: 18px 16px; border-radius: 999px; transform: rotate(var(--pr, -6deg)); box-shadow: 0 10px 26px rgba(0,0,0,0.45), inset 0 0 0 3px rgb(var(--fg-rgb) / 0.25); }
  .ct2-patch:active { cursor: grabbing; }
  .p1 { top: 22vh; right: 12vw; background: var(--deep); color: var(--paper); --pr: 7deg; }
  .p2 { top: 52vh; right: 22vw; background: var(--warm-deep); color: var(--paper); --pr: -8deg; }
  .p3 { top: 36vh; right: 5vw; background: var(--deep); color: var(--paper); --pr: 4deg; }

  .ct2 :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .ct2 :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .ct2 :global(.split.on .wi) { transform: none; }

  @media (max-width: 860px) {
    .ct2-expect-grid { grid-template-columns: 1fr; }
    .ct2-low { flex-direction: column; align-items: flex-start; }
    .ct2-hint { text-align: left; }
    .ct2-patches { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ct2 :global(.split .wi) { transform: none !important; transition: none !important; }
    .ct2-stroke path { stroke-dashoffset: 0; }
  }
</style>

<script>
  // split
  const splitWords = (root: Node, counter: { n: number }) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !(node as Element).closest('svg')) splitWords(node, counter);
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('on'); io.unobserve(e.target); } }), { threshold: 0.35 });
  document.querySelectorAll('.split').forEach((el) => io.observe(el));

  // email marker stroke draws on load
  const mail = document.querySelector('[data-mail]');
  if (mail) setTimeout(() => mail.classList.add('on'), 600);

  // draggable patches w/ a little throw physics (desktop)
  if (matchMedia('(pointer: fine)').matches && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('[data-patch]').forEach((p) => {
      const el = p as HTMLElement;
      let dragging = false, ox = 0, oy = 0, x = 0, y = 0, vx = 0, vy = 0, raf = 0;
      const apply = () => { el.style.translate = `${x}px ${y}px`; };
      el.addEventListener('pointerdown', (e) => {
        dragging = true; el.setPointerCapture(e.pointerId);
        ox = e.clientX - x; oy = e.clientY - y;
        cancelAnimationFrame(raf); vx = 0; vy = 0;
      });
      el.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const nx = e.clientX - ox, ny = e.clientY - oy;
        vx = nx - x; vy = ny - y; x = nx; y = ny; apply();
      });
      const release = () => {
        if (!dragging) return;
        dragging = false;
        const glide = () => {
          vx *= 0.94; vy *= 0.94; x += vx; y += vy; apply();
          if (Math.abs(vx) > 0.3 || Math.abs(vy) > 0.3) raf = requestAnimationFrame(glide);
        };
        raf = requestAnimationFrame(glide);
      };
      el.addEventListener('pointerup', release);
      el.addEventListener('pointercancel', release);
    });
  }
</script>
