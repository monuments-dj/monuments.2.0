---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import FloatingHand from '../../components/FloatingHand.astro';

// === AI LAB — /lab/ai — direction 1, pinned-scene build ===
// Audit → automate → deploy for non-technical service businesses.
// Motion model = the measured reference laws (REFERENCES.md "motion map"):
// pinned scenes, scroll-scrubbed + reversible composition, sheet-over handoffs,
// media slower than type. Scenes: ERA (white, statement → WILD stamp cascade →
// payoff) and QUESTIONS (black, two questions trading the stage).
// Copy = DJ's positioning: $5k audit, going-wild era framing. Voice: studio "we",
// plain-spoken, no em dashes, no buzzwords (see memory: monuments-copy).

const services = [
  {
    key: 'audit',
    n: '01',
    title: 'Audit',
    tilt: -3,
    price: '$5,000 flat',
    lede: "A complete read of your business: the brand, the tools, the busywork. You get a map of what AI can actually do for you, and what it can't. Plain English, two weeks.",
    items: ['Brand and tech-stack review', 'Opportunity map', 'Competitor scan', 'Tool recommendations', 'A roadmap you can act on'],
  },
  {
    key: 'automate',
    n: '02',
    title: 'Automate',
    tilt: 2,
    price: null,
    lede: "The busywork goes away. Intake, content, reporting, follow-ups: we build the systems that handle whatever's been eating your week.",
    items: ['Workflow automation', 'Content systems', 'Client communications', 'Internal tools'],
  },
  {
    key: 'deploy',
    n: '03',
    title: 'Deploy',
    tilt: -2,
    price: null,
    lede: "We don't hand you a login and vanish. Your team gets trained, everything gets documented, and you keep a direct line to the director.",
    items: ['Team training', 'Documentation', 'Support retainer', 'Quarterly reviews'],
  },
];

// Directed campaign work for the proof strip (stills from campaigns we led).
const proof = [
  '/case-studies/blue-cross/gallery/bci-02.jpg',
  '/case-studies/sony-this-moment/gallery/tm-09.jpg',
  '/case-studies/blue-cross/gallery/bci-18.jpg',
  '/case-studies/sony-this-moment/gallery/tm-05.jpg',
  '/case-studies/blue-cross/gallery/bci-13.jpg',
];
const stamps = [0, 1, 2, 3, 4, 5, 6];
---
<Base title="AI, without the overwhelm — monuments">

  <!-- KINETIC LOAD INTRO — stacks and multiplies, curtain lifts into the page. -->
  <div class="ai-intro" id="aiIntro" aria-hidden="true">
    <div class="ai-intro-stack">
      <span class="ai-intro-eyebrow">the tools just went</span>
      <span class="ai-intro-word" style="--i:0">WILD</span>
      <span class="ai-intro-word" style="--i:1">WILD</span>
      <span class="ai-intro-word" style="--i:2">WILD</span>
      <span class="ai-intro-word" style="--i:3">WILD</span>
      <span class="ai-intro-word" style="--i:4">WILD</span>
    </div>
  </div>

  <main class="ai-page">

    <!-- HERO -->
    <header class="ai-hero">
      <FloatingHand side="right" top="14vh" />
      <p class="ai-eyebrow fade">AI audits · automation · deployment</p>
      <h1 class="ai-h1 split">Where's your brand now, and <em>where could it be?</em></h1>
      <p class="ai-lede fade">AI for businesses that don't have time to become AI businesses. We audit what you've got, build what's missing, and train your people to run it.</p>
      <a class="ai-cta fade" href="/contact">Book an audit <span aria-hidden="true">↗</span></a>
    </header>

    <!-- SCENE 1 — THE ERA (pinned, white). Scroll composes:
         statement lights word by word → exits up → "That era just ended." lands
         over a scroll-driven WILD stamp cascade → payoff line. Reversible. -->
    <section class="scn scn-era" data-scene="era">
      <div class="scn-stage scn-stage-era">
        <p class="era-s1 scrubwords">For twenty years, this stuff was gatekept. Custom software cost six figures. Good design needed a dev team. Automation was for companies with an IT department.</p>
        <div class="era-s2">
          <div class="wild-field" aria-hidden="true">
            {stamps.map((i) => (
              <span class="wild-stamp" style={`--s:${i}`}>WILD</span>
            ))}
          </div>
          <p class="era-ended">That era just ended.</p>
        </div>
        <p class="era-s3 ai-era-body">New tools ship every week and nobody sends a memo. Keeping up is a full-time job. Good news: it's ours. You run your business. We'll keep it modern.</p>
      </div>
    </section>

    <!-- SCENE 2 — THE QUESTIONS (pinned, black). Q1 lands word by word, holds,
         exits up while Q2 rises from below. Slides in OVER the era stage. -->
    <section class="scn scn-q" data-scene="q">
      <div class="scn-stage scn-stage-q">
        <h2 class="q q1">What are you <em>leaving on the table?</em></h2>
        <h2 class="q q2">Is your brand <em>getting left behind?</em></h2>
      </div>
    </section>

    <!-- Everything after the scenes rides above them (sheet-over handoff). -->
    <div class="ai-after">

      <!-- SERVICES — tilted cards (lusion-pattern, monuments-flavored) -->
      <section class="ai-sv">
        <div class="ai-sv-head fade">
          <p class="ai-eyebrow">How it works</p>
          <h2 class="ai-sv-h">Audit. Automate. Deploy.</h2>
        </div>
        <div class="ai-cards" data-cards>
          {services.map((s, ci) => (
            <article class="ai-card" data-key={s.key} style={`--tilt:${s.tilt}deg; --ci:${ci};`}>
              <div class="ai-card-top">
                <span class="ai-card-n">{s.n}</span>
                <h3 class="ai-card-t">{s.title}</h3>
                {s.price && <span class="ai-card-price">{s.price}</span>}
              </div>
              <p class="ai-card-lede">{s.lede}</p>
              <ul class="ai-card-list">
                {s.items.map((i) => <li>{i}</li>)}
              </ul>
              <span class="ai-card-mirror" aria-hidden="true">{s.title}</span>
            </article>
          ))}
        </div>
      </section>

      <!-- WHO IT'S FOR -->
      <section class="ai-who">
        <div class="ai-who-inner">
          <p class="ai-eyebrow fade">Who this is for</p>
          <p class="ai-who-big split">CPAs. Agencies. Service businesses. You're great at the work. The tech shouldn't be your second job.</p>
          <p class="ai-era-body fade">Creative direction is our trade: take in a flood of input, filter it, make the call. That's exactly the skill this moment needs. We'll wrangle the tools so you never have to open them.</p>
        </div>
      </section>

      <!-- PROOF — this site is the demo -->
      <section class="ai-proof">
        <div class="ai-proof-head">
          <p class="ai-eyebrow fade">Proof, not promises</p>
          <h2 class="ai-proof-h split">This site is the demo.</h2>
          <p class="ai-era-body fade">Version one of this site took six months by hand. The one you're looking at was rebuilt with AI in a fraction of that, and it's better. Same eye. Faster hands. That's the offer.</p>
        </div>
        <div class="ai-strip" data-strip>
          {proof.map((src) => (
            <img src={src} alt="Monuments campaign work" loading="lazy" />
          ))}
        </div>
        <p class="ai-strip-cap fade">Sony. Blue Cross. Intel. Big campaigns, directed with the old tools. Imagine what we'll do with the new ones.</p>
      </section>

      <!-- CTA -->
      <section class="ai-end">
        <p class="ai-end-big split">Let's see what you're leaving on the table.</p>
        <a class="ai-cta ai-cta-big fade" href="/contact">Book the audit <span aria-hidden="true">↗</span></a>
        <p class="ai-end-small fade">$5,000. Two weeks. Plain English. And if there's nothing there, we'll tell you that too.</p>
      </section>

    </div>

  </main>
  <LabFx />
</Base>

<style>
  .ai-page { background: var(--black); color: var(--white); overflow-x: clip; }
  .ai-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.45); }

  /* INTRO */
  .ai-intro { position: fixed; inset: 0; z-index: 3000; background: var(--white); display: flex; align-items: center; justify-content: center; transition: transform 0.7s cubic-bezier(0.76, 0, 0.24, 1); }
  .ai-intro.lift { transform: translateY(-100%); }
  .ai-intro.gone { display: none; }
  .ai-intro-stack { display: flex; flex-direction: column; align-items: center; line-height: 0.82; }
  .ai-intro-eyebrow { font-size: clamp(13px, 1.4vw, 18px); letter-spacing: 0.3em; text-transform: uppercase; color: var(--ink); margin-bottom: 3vh; opacity: 0; animation: aiFadeIn 0.5s ease 0.15s forwards; }
  .ai-intro-word { font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(70px, 13vw, 190px); letter-spacing: -0.03em; color: var(--ink); clip-path: inset(-12% -4% 100% -4%); animation: aiWordIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) calc(0.25s + var(--i) * 0.12s) forwards; }
  .ai-intro-word:nth-child(odd) { color: var(--accent); }
  @keyframes aiWordIn { to { clip-path: inset(-12% -4% -18% -4%); } }
  @keyframes aiFadeIn { to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .ai-intro { display: none; } }

  /* SPLIT — word-mask entrance for non-scene display copy */
  .ai-page :global(.split .w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .ai-page :global(.split .wi) { display: inline-block; transform: translateY(135%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); will-change: transform; }
  .ai-page :global(.split.on .wi) { transform: none; }

  /* HERO */
  .ai-hero { position: relative; min-height: 86vh; display: flex; flex-direction: column; justify-content: center; max-width: var(--wrap); margin: 0 auto; padding: 160px var(--pad) 80px; }
  .ai-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(44px, 7.2vw, 104px); line-height: 1.02; letter-spacing: -0.03em; max-width: 14ch; margin-top: 26px; transition: transform 0.3s ease-out; will-change: transform; }
  .ai-h1 em { font-style: italic; color: var(--accent); }
  .ai-lede { margin-top: 34px; max-width: 520px; font-size: 16px; line-height: 1.7; font-weight: 300; color: rgb(var(--fg-rgb) / 0.78); }
  .ai-cta { display: inline-flex; align-items: center; gap: 10px; margin-top: 44px; width: fit-content; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--black); background: var(--white); padding: 18px 30px; border-radius: 999px; text-decoration: none; transition: gap 0.3s ease, transform 0.3s ease; }
  .ai-cta:hover { gap: 18px; transform: translateY(-2px); }

  /* ===== PINNED SCENES ===== */
  .scn { position: relative; }
  .scn-stage { position: sticky; top: 0; height: 100vh; overflow: hidden; display: flex; align-items: center; justify-content: center; }

  /* Scene 1 — ERA. 340vh parent: 140vh of scrub + 100vh handoff window. */
  .scn-era { height: 340vh; z-index: 1; }
  .scn-stage-era { background: var(--white); color: var(--ink); }
  .era-s1 { position: absolute; max-width: 21ch; padding: 0 var(--pad); font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(28px, 3.6vw, 52px); line-height: 1.16; letter-spacing: -0.02em; text-align: center; will-change: transform, opacity; }
  .era-s1 :global(.wi) { transform: none !important; transition: opacity 0.18s linear; opacity: 0.14; }
  .era-s2 { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; will-change: opacity; }
  .era-ended { position: relative; z-index: 2; font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(44px, 6.5vw, 110px); letter-spacing: -0.03em; color: var(--accent); will-change: transform; text-shadow: 0 0 24px rgb(var(--fg-rgb) / 0.85); }
  .wild-field { position: absolute; inset: 0; z-index: 1; }
  .wild-stamp { position: absolute; left: calc(6% + var(--s) * 12%); top: calc(10% + var(--s) * 11%); font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(40px, 5vw, 84px); letter-spacing: -0.03em; color: rgb(var(--ink-rgb) / 0.08); transform: scale(0.7) rotate(calc((var(--s) - 3) * 1.6deg)); opacity: 0; transition: opacity 0.22s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .wild-stamp:nth-child(odd) { color: color-mix(in srgb, var(--accent) 16%, transparent); }
  .wild-stamp.on { opacity: 1; transform: scale(1) rotate(calc((var(--s) - 3) * 1.6deg)); }
  .era-s3 { position: absolute; bottom: 12vh; left: 50%; transform: translateX(-50%); max-width: 560px; padding: 0 var(--pad); text-align: center; opacity: 0; will-change: opacity; }
  .ai-era-body { font-size: 16px; line-height: 1.75; font-weight: 300; color: rgb(var(--ink-rgb) / 0.75); }

  /* Scene 2 — QUESTIONS. Slides over the era stage; services slides over this. */
  .scn-q { height: 360vh; z-index: 2; margin-top: -100vh; }
  .scn-stage-q { background: var(--black); }
  .q { position: absolute; font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(38px, 6vw, 88px); line-height: 1.05; letter-spacing: -0.025em; text-align: center; max-width: 16ch; padding: 0 var(--pad); will-change: transform, opacity; }
  .q em { font-style: italic; color: var(--accent); }
  .q :global(.w) { display: inline-block; overflow: clip; overflow-clip-margin: 0.22em; vertical-align: top; padding: 0.1em 0.14em; margin: -0.1em -0.14em; }
  .q :global(.wi) { display: inline-block; transform: translateY(135%); transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1); will-change: transform; }
  .q :global(.wi.on) { transform: none; }

  /* Post-scene content rides OVER the pinned stages (sheet-over handoff). */
  .ai-after { position: relative; z-index: 3; margin-top: -100vh; background: var(--black); }

  /* SERVICES */
  .ai-sv { max-width: var(--wrap); margin: 0 auto; padding: clamp(90px, 11vw, 150px) var(--pad); }
  .ai-sv-h { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(36px, 5vw, 72px); letter-spacing: -0.025em; margin-top: 18px; }
  .ai-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 2.6vw, 36px); margin-top: clamp(48px, 6vw, 80px); }
  .ai-card { position: relative; background: var(--white); color: var(--ink); border-radius: 14px; padding: clamp(28px, 2.8vw, 42px); overflow: hidden; display: flex; flex-direction: column; min-height: 480px; will-change: transform, opacity; transform-style: preserve-3d;
    /* pre-reveal: dropped + faded, deals itself in on scroll */
    opacity: 0; transform: translateY(72px) rotate(calc(var(--tilt) * 2)) scale(0.95);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--ci) * 0.12s), opacity 0.6s ease calc(var(--ci) * 0.12s), box-shadow 0.45s ease; }
  .ai-card.shown { opacity: 1; transform: rotate(var(--tilt)); }
  .ai-card:hover { box-shadow: 0 24px 60px rgba(0,0,0,0.35); }

  /* DEPLOY fold-and-fly: once the section is done, the Deploy card folds into a
     paper airplane (clip-path morph + content fades) and zips off the top-right. */
  .ai-card.flyoff { pointer-events: none; animation: deployFold 2.4s cubic-bezier(0.45, 0, 0.18, 1) forwards; box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    /* nose-to-tail crease so the folded card reads as paper, not a bird */
    background-image: linear-gradient(to bottom, transparent calc(50% - 0.8px), rgb(var(--ink-rgb) / 0.18) calc(50% - 0.8px), rgb(var(--ink-rgb) / 0.18) calc(50% + 0.8px), transparent calc(50% + 0.8px)); }
  .ai-card.flyoff > * { opacity: 0; transition: opacity 0.25s ease; }
  /* Paper-airplane fold: the two FRONT corners collapse into a nose (right) +
     a center notch (left); the two BACK corners stay, so it reads as a dart.
     Same 4 vertices throughout so it folds cleanly instead of morphing wildly. */
  @keyframes deployFold {
    0%   { clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%); transform: rotate(var(--tilt)); }
    22%  { clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%); transform: rotate(var(--tilt)) scale(0.97); }
    44%  { clip-path: polygon(0% 0%, 100% 24%, 58% 50%, 0% 100%); transform: rotate(-3deg) scale(0.8); }
    60%  { clip-path: polygon(0% 0%, 100% 50%, 26% 50%, 0% 100%); transform: rotate(8deg) scale(0.56) translateY(-6px); }
    72%  { clip-path: polygon(0% 0%, 100% 50%, 26% 50%, 0% 100%); transform: rotate(14deg) scale(0.48) translate(28px, -20px); }
    100% { clip-path: polygon(0% 0%, 100% 50%, 26% 50%, 0% 100%); transform: translate(126vw, -92vh) rotate(24deg) scale(0.15); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-card { opacity: 1; transform: rotate(var(--tilt)); transition: none; }
    .ai-card.flyoff { animation: none; }
  }
  .ai-card-top { display: flex; align-items: baseline; gap: 14px; }
  .ai-card-n { font-size: 12px; letter-spacing: 0.18em; color: rgb(var(--ink-rgb) / 0.4); }
  .ai-card-t { font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(26px, 2.6vw, 38px); letter-spacing: -0.02em; }
  .ai-card-price { margin-left: auto; font-size: 13px; font-weight: 500; color: var(--accent); white-space: nowrap; }
  .ai-card-lede { margin-top: 18px; font-size: 14.5px; line-height: 1.65; font-weight: 300; color: rgb(var(--ink-rgb) / 0.8); }
  .ai-card-list { list-style: none; margin: 22px 0 56px; padding: 0; }
  .ai-card-list li { font-size: 14px; padding: 11px 0; border-bottom: 1px dotted rgb(var(--ink-rgb) / 0.25); }
  .ai-card-list li:last-child { border-bottom: 0; }
  .ai-card-mirror { position: absolute; left: 50%; bottom: 14px; transform: translateX(-50%) rotate(180deg); font-family: 'Inter', sans-serif; font-weight: 500; font-size: 20px; letter-spacing: -0.02em; color: rgb(var(--ink-rgb) / 0.22); }

  /* WHO */
  .ai-who { background: var(--c-slate); }
  .ai-who-inner { max-width: var(--wrap); margin: 0 auto; padding: clamp(100px, 13vw, 170px) var(--pad); }
  .ai-who-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(28px, 4vw, 56px); line-height: 1.15; letter-spacing: -0.02em; max-width: 22ch; margin-top: 22px; }
  .ai-who .ai-era-body { color: rgb(var(--fg-rgb) / 0.7); }

  /* PROOF */
  .ai-proof { padding: clamp(100px, 12vw, 160px) 0; }
  .ai-proof-head { max-width: var(--wrap); margin: 0 auto; padding: 0 var(--pad); }
  .ai-proof-h { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(36px, 5.4vw, 76px); letter-spacing: -0.025em; margin-top: 18px; }
  .ai-proof .ai-era-body { color: rgb(var(--fg-rgb) / 0.7); }
  .ai-strip { display: flex; gap: 14px; margin-top: clamp(48px, 6vw, 72px); padding: 0 var(--pad); overflow: hidden; }
  .ai-strip img { width: clamp(220px, 24vw, 360px); aspect-ratio: 3/2; object-fit: cover; border-radius: 4px; flex: 0 0 auto; will-change: transform; }
  .ai-strip-cap { max-width: var(--wrap); margin: 28px auto 0; padding: 0 var(--pad); font-size: 13px; letter-spacing: 0.04em; color: rgb(var(--fg-rgb) / 0.5); }

  /* END CTA */
  .ai-end { min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 80px var(--pad); }
  .ai-end-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(34px, 5vw, 72px); letter-spacing: -0.025em; line-height: 1.08; max-width: 18ch; }
  .ai-cta-big { margin-top: 48px; }
  .ai-end-small { margin-top: 26px; font-size: 14px; font-weight: 300; color: rgb(var(--fg-rgb) / 0.55); }

  @media (max-width: 900px) {
    .ai-cards { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
    .ai-card { min-height: 0; }
  }

  /* Reduced motion: no pinning, no scrubbing; scenes read as plain sections. */
  @media (prefers-reduced-motion: reduce) {
    .ai-page :global(.split .wi), .q :global(.wi) { transform: none !important; transition: none !important; }
    .scn { height: auto !important; margin-top: 0 !important; }
    .scn-stage { position: static; height: auto; padding: 18vh var(--pad); flex-direction: column; gap: 8vh; }
    .era-s1, .era-s3, .q { position: static; opacity: 1 !important; transform: none !important; }
    .era-s1 :global(.wi) { opacity: 1 !important; }
    .era-s2 { position: static; opacity: 1 !important; inset: auto; }
    .wild-field { display: none; }
    .ai-after { margin-top: 0; }
  }
</style>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = matchMedia('(pointer: fine)').matches;

  // --- Load intro ---
  const intro = document.getElementById('aiIntro');
  if (intro && !reduced) {
    setTimeout(() => intro.classList.add('lift'), 1750);
    setTimeout(() => intro.classList.add('gone'), 2600);
  } else if (intro) {
    intro.classList.add('gone');
  }

  // --- Word splitter (entrance .split + scene-driven .scrubwords/.q) ---
  const splitWords = (root, counter) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        node.textContent.split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', counter.n++);
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1) {
        splitWords(node, counter);
      }
    });
  };
  document.querySelectorAll('.split, .scrubwords, .q').forEach((el) => splitWords(el, { n: 0 }));

  // Entrance reveals for .split only (scenes drive their own words).
  const splitIO = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('on'); splitIO.unobserve(e.target); } });
  }, { threshold: 0.35 });
  document.querySelectorAll('.split').forEach((el) => splitIO.observe(el));

  // --- Pinned-scene engine: progress = how far through the parent we've
  //     scrolled, finishing one viewport early (that last 100vh is the
  //     sheet-over handoff window). Everything below is driven by p, so it
  //     scrubs forward AND backward. ---
  const clamp01 = (v) => Math.min(1, Math.max(0, v));
  const phase = (p, a, b) => clamp01((p - a) / (b - a));

  const eraScene = document.querySelector('[data-scene="era"]');
  const eraS1 = eraScene && eraScene.querySelector('.era-s1');
  const eraS1Words = eraS1 ? [...eraS1.querySelectorAll('.wi')] : [];
  const eraS2 = eraScene && eraScene.querySelector('.era-s2');
  const eraEnded = eraScene && eraScene.querySelector('.era-ended');
  const eraStamps = eraScene ? [...eraScene.querySelectorAll('.wild-stamp')] : [];
  const eraS3 = eraScene && eraScene.querySelector('.era-s3');

  const qScene = document.querySelector('[data-scene="q"]');
  const q1 = qScene && qScene.querySelector('.q1');
  const q2 = qScene && qScene.querySelector('.q2');
  const q1Words = q1 ? [...q1.querySelectorAll('.wi')] : [];
  const q2Words = q2 ? [...q2.querySelectorAll('.wi')] : [];

  const strip = document.querySelector('[data-strip]');
  const stripImgs = strip ? [...strip.querySelectorAll('img')] : [];

  const sceneP = (el) => {
    const r = el.getBoundingClientRect();
    return clamp01(-r.top / (el.offsetHeight - innerHeight * 2));
  };

  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      // SCENE 1: ERA
      if (eraScene) {
        const p = sceneP(eraScene);
        // s1: words light up over p 0.02-0.30, block exits up 0.36-0.52
        const lit = phase(p, 0.02, 0.3) * eraS1Words.length * 1.1;
        eraS1Words.forEach((w, i) => { w.style.opacity = Math.max(0.14, Math.min(1, lit - i)); });
        const exit = phase(p, 0.36, 0.52);
        eraS1.style.opacity = String(1 - exit);
        eraS1.style.transform = `translateY(${exit * -90}px)`;
        // s2: "ended" lands 0.40-0.55; stamps cascade one by one 0.46-0.78
        const land = phase(p, 0.4, 0.55);
        eraS2.style.opacity = String(land);
        eraEnded.style.transform = `scale(${0.92 + land * 0.08})`;
        const k = Math.floor(phase(p, 0.46, 0.78) * (eraStamps.length + 0.99));
        eraStamps.forEach((s, i) => s.classList.toggle('on', i < k));
        // s3: payoff line 0.80-0.95
        eraS3.style.opacity = String(phase(p, 0.8, 0.95));
      }
      // SCENE 2: QUESTIONS
      if (qScene) {
        const p = sceneP(qScene);
        const q1in = phase(p, 0.04, 0.28);
        q1Words.forEach((w, i) => w.classList.toggle('on', q1in * q1Words.length * 1.15 > i));
        const q1out = phase(p, 0.46, 0.62);
        q1.style.transform = `translateY(${q1out * -55}vh)`;
        q1.style.opacity = String(1 - q1out);
        const q2in = phase(p, 0.52, 0.78);
        q2.style.transform = `translateY(${(1 - q2in) * 45}vh)`;
        q2.style.opacity = String(Math.min(1, q2in * 2));
        q2Words.forEach((w, i) => w.classList.toggle('on', phase(p, 0.56, 0.8) * q2Words.length * 1.15 > i));
      }
      // Proof strip: layered drift, each frame at its own rate.
      if (strip) {
        const r = strip.getBoundingClientRect();
        const sp = Math.min(1.2, Math.max(0, 1 - r.top / innerHeight));
        stripImgs.forEach((img, i) => { img.style.transform = `translateX(${sp * -(90 + i * 46)}px)`; });
      }
      ticking = false;
    });
  };
  if (!reduced) {
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // --- Services cards: deal in on scroll (staggered .shown); once you scroll
  //     past, the Deploy card folds into a paper airplane and zips off. ---
  const svCards = [...document.querySelectorAll('.ai-card')];
  const deployCard = svCards.find((c) => c.getAttribute('data-key') === 'deploy');
  const cardsWrap = document.querySelector('[data-cards]');
  if (!reduced) {
    const cardIO = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('shown'); cardIO.unobserve(e.target); } });
    }, { threshold: 0.3 });
    svCards.forEach((c) => cardIO.observe(c));

    if (cardsWrap && deployCard) {
      let flown = false;
      const onCardsScroll = () => {
        const r = cardsWrap.getBoundingClientRect();
        if (!flown && r.bottom < innerHeight * 0.6 && deployCard.classList.contains('shown')) { deployCard.classList.add('flyoff'); flown = true; }
        else if (flown && r.bottom > innerHeight * 0.9) { deployCard.classList.remove('flyoff'); flown = false; }
      };
      addEventListener('scroll', onCardsScroll, { passive: true });
      onCardsScroll();
    }
  } else {
    svCards.forEach((c) => c.classList.add('shown'));
  }

  // --- Pointer-reactive layer (desktop only) ---
  if (!reduced && finePointer) {
    document.querySelectorAll('.ai-card').forEach((card) => {
      const base = card.style.getPropertyValue('--tilt') || '0deg';
      card.addEventListener('pointerenter', () => {
        card.style.transition = 'transform 0.12s ease-out, box-shadow 0.45s ease';
      });
      card.addEventListener('pointermove', (e) => {
        if (card.classList.contains('flyoff')) return;
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `perspective(900px) rotateY(${px * 7}deg) rotateX(${py * -7}deg) translateY(-6px)`;
      });
      card.addEventListener('pointerleave', () => {
        card.style.transition = 'transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.45s ease';
        card.style.transform = `rotate(${base})`;
      });
    });
    document.querySelectorAll('.ai-cta').forEach((cta) => {
      cta.addEventListener('pointermove', (e) => {
        const r = cta.getBoundingClientRect();
        const dx = e.clientX - (r.left + r.width / 2);
        const dy = e.clientY - (r.top + r.height / 2);
        cta.style.transform = `translate(${dx * 0.18}px, ${dy * 0.3}px)`;
      });
      cta.addEventListener('pointerleave', () => { cta.style.transform = ''; });
    });
    const h1 = document.querySelector('.ai-h1');
    const hero = document.querySelector('.ai-hero');
    if (h1 && hero) {
      hero.addEventListener('pointermove', (e) => {
        const px = e.clientX / innerWidth - 0.5;
        const py = e.clientY / innerHeight - 0.5;
        h1.style.transform = `translate(${px * -14}px, ${py * -10}px)`;
      });
      hero.addEventListener('pointerleave', () => { h1.style.transform = ''; });
    }
  }
</script>
