---
import Base from '../../layouts/Base.astro';

// === ABOUT V2 — /lab/about ===
// exoape-studio pacing + tinywins generosity, on the existing approved copy.
// One pinned scene (the credo), drifting media, marker accents, team tiles
// (placeholder headshots still pending), mission-work texture band per the
// Website Context doc. About is allowed personal voice; pitch lines stay "we".

const stats = [
  { n: '10+', l: 'years in the hard rooms' },
  { n: '1M+', l: 'people reached by the work' },
  { n: '8', l: 'global brands and counting' },
  { n: '2', l: 'cities: Los Angeles and Boise' },
];
---
<Base title="About — monuments">
  <main class="ab2">

    <!-- HERO -->
    <header class="ab2-hero">
      <figure class="ab2-hero-img a" data-drift="7"><img src="/galaxy/gx-07.jpg" alt="" loading="eager" /></figure>
      <figure class="ab2-hero-img b" data-drift="11"><img src="/galaxy/gx-18.jpg" alt="" loading="eager" /></figure>
      <div class="ab2-hero-inner">
        <p class="ab2-eyebrow fade">About Monuments</p>
        <h1 class="ab2-h1 split">A decade in <em>the hard rooms.</em></h1>
        <p class="ab2-lead fade">Rooms where the brief was wrong, the timeline was tight, and the stakes were real. We learned to love those rooms.</p>
      </div>
    </header>

    <!-- STATS -->
    <section class="ab2-stats">
      {stats.map((s) => (
        <div class="ab2-stat fade">
          <span class="ab2-stat-n">{s.n}</span>
          <span class="ab2-stat-l">{s.l}</span>
        </div>
      ))}
    </section>

    <!-- WHO (cream chapter) -->
    <section class="ab2-who">
      <div class="ab2-cols">
        <p class="ab2-kicker fade">Who we are</p>
        <div class="ab2-col">
          <p class="ab2-big split">A creative-led studio run by CD <em>DJ Ramirez</em>, based between Los Angeles and Boise.</p>
          <p class="ab2-body fade">We plug in at the senior level: strategy, creative direction, integrated content. For brands that want to show up in culture and mean it, and for the agencies that serve them. DJ leads as creative director. Tess keeps the operation moving. A trusted network of makers comes in when the work calls for it.</p>
        </div>
      </div>
    </section>

    <!-- PINNED CREDO SCENE (dark, the two-rabbits + the point) -->
    <section class="ab2-credo scn" data-scene="credo">
      <div class="scn-stage ab2-credo-stage">
        <figure class="ab2-credo-bg" data-drift="5"><img src="/galaxy/gx-22.jpg" alt="" loading="lazy" /></figure>
        <div class="ab2-credo-copy">
          <p class="ab2-credo-line" data-cwords>I shoot but I'm not a shooter. I direct but it's not the point. The point is <em>the story.
            <svg class="ab2-stroke" viewBox="0 0 300 14" preserveAspectRatio="none" aria-hidden="true"><path d="M5 9 C70 4, 180 12, 295 6" /></svg>
          </em></p>
          <p class="ab2-credo-sub">The moment. Always has been.</p>
        </div>
      </div>
    </section>

    <!-- TEAM (rides over the credo stage) -->
    <div class="ab2-after">
      <section class="ab2-team">
        <p class="ab2-kicker fade">The team</p>
        <div class="ab2-team-grid">
          <article class="ab2-person fade">
            <div class="ab2-person-ph" data-mono="DJ" aria-label="Portrait of DJ Ramirez, placeholder"></div>
            <h3 class="ab2-person-name">DJ Ramirez</h3>
            <p class="ab2-person-role">Founder · Creative Director</p>
            <p class="ab2-person-bio">Leads every engagement at the senior level: strategy, creative direction, the thinking. A decade of campaigns for brands and agencies that wanted to mean something.</p>
          </article>
          <article class="ab2-person fade">
            <div class="ab2-person-ph alt" data-mono="T" aria-label="Portrait of Tess, placeholder"></div>
            <h3 class="ab2-person-name">Tess</h3>
            <p class="ab2-person-role">Operations</p>
            <p class="ab2-person-bio">Keeps the operation moving so the creative can stay creative. The reason timelines hold and the work actually ships.</p>
          </article>
        </div>
      </section>

      <!-- RANGE (mission-work texture, per the brand doc: texture, never the lead) -->
      <section class="ab2-range">
        <div class="ab2-cols">
          <p class="ab2-kicker fade">The range</p>
          <div class="ab2-col">
            <p class="ab2-body fade">The work has carried us across the US and far past it: documentary and mission projects in Nepal, Uganda, and Europe. It shows up in how we tell stories at home: with patience, with respect for the subject, and with a low tolerance for fake.</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="ab2-end">
        <p class="ab2-end-big split">Bring us the <em>hard room.</em></p>
        <a class="ab2-cta fade" href="/contact">Start a conversation <span aria-hidden="true">↗</span></a>
      </section>
    </div>

  </main>
</Base>

<style>
  .ab2 { background: var(--black); color: var(--white); overflow-x: clip; }
  .ab2-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgba(252,252,252,0.5); }
  .ab2-kicker { font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #e0322d; }

  /* HERO */
  .ab2-hero { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; }
  .ab2-hero-inner { position: relative; z-index: 2; max-width: var(--wrap); margin: 0 auto; padding: 0 var(--pad); width: 100%; }
  .ab2-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(46px, 7.4vw, 116px); line-height: 1; letter-spacing: -0.03em; max-width: 12ch; margin-top: 20px; }
  .ab2-h1 em, .ab2-big em, .ab2-end-big em { font-style: italic; color: var(--accent); }
  .ab2-lead { margin-top: 30px; max-width: 480px; font-size: 16px; line-height: 1.7; font-weight: 300; color: rgba(252,252,252,0.78); }
  .ab2-hero-img { position: absolute; margin: 0; border-radius: 4px; overflow: hidden; opacity: 0.55; }
  .ab2-hero-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ab2-hero-img.a { right: 6vw; top: 12vh; width: clamp(220px, 24vw, 420px); aspect-ratio: 3/4; }
  .ab2-hero-img.b { right: 24vw; bottom: 8vh; width: clamp(160px, 17vw, 300px); aspect-ratio: 4/3; }

  /* STATS */
  .ab2-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; max-width: var(--wrap); margin: 0 auto; padding: clamp(70px, 9vw, 120px) var(--pad); }
  .ab2-stat { display: flex; flex-direction: column; gap: 10px; border-top: 1px solid rgba(252,252,252,0.18); padding-top: 16px; }
  .ab2-stat-n { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(38px, 4.6vw, 68px); letter-spacing: -0.03em; line-height: 1; }
  .ab2-stat-l { font-size: 13px; font-weight: 300; color: rgba(252,252,252,0.6); }

  /* WHO */
  .ab2-who { background: var(--white); color: #141519; padding: clamp(100px, 13vw, 170px) 0; }
  .ab2-cols { display: grid; grid-template-columns: 200px 1fr; gap: clamp(28px, 5vw, 80px); max-width: min(1080px, 94vw); margin: 0 auto; padding: 0 var(--pad); align-items: start; }
  .ab2-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(28px, 3.6vw, 52px); line-height: 1.16; letter-spacing: -0.02em; max-width: 22ch; }
  .ab2-who .ab2-body { color: rgba(20,21,25,0.78); }
  .ab2-body { margin-top: 28px; max-width: 56ch; font-size: 16px; line-height: 1.75; font-weight: 300; color: rgba(252,252,252,0.75); }

  /* CREDO */
  .scn { position: relative; }
  .scn-stage { position: sticky; top: 0; height: 100vh; overflow: hidden; }
  .ab2-credo { height: 280vh; z-index: 2; }
  .ab2-credo-stage { background: var(--black); display: flex; align-items: center; justify-content: center; }
  .ab2-credo-bg { position: absolute; inset: -6%; margin: 0; opacity: 0.32; }
  .ab2-credo-bg img { width: 100%; height: 100%; object-fit: cover; }
  .ab2-credo-copy { position: relative; z-index: 2; text-align: center; padding: 0 var(--pad); }
  .ab2-credo-line { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(30px, 4.4vw, 64px); line-height: 1.18; letter-spacing: -0.02em; max-width: 24ch; }
  .ab2-credo-line em { font-style: italic; color: var(--accent); position: relative; white-space: nowrap; }
  .ab2-credo-line :global(.w) { display: inline-block; overflow: hidden; vertical-align: top; }
  .ab2-credo-line :global(.wi) { display: inline-block; transform: translateY(115%); transition: transform 0.5s cubic-bezier(0.16,1,0.3,1); }
  .ab2-credo-line :global(.wi.on) { transform: none; }
  .ab2-stroke { position: absolute; left: 0; bottom: -10px; width: 100%; height: 12px; overflow: visible; }
  .ab2-stroke path { fill: none; stroke: #e0322d; stroke-width: 3; stroke-linecap: round; stroke-dasharray: 320; stroke-dashoffset: var(--soff, 320); }
  .ab2-credo-sub { margin-top: 3vh; font-size: 14px; letter-spacing: 0.08em; color: rgba(252,252,252,0.6); opacity: var(--subo, 0); transition: opacity 0.4s ease; }

  .ab2-after { position: relative; z-index: 3; margin-top: -100vh; background: var(--black); }

  /* TEAM */
  .ab2-team { max-width: var(--wrap); margin: 0 auto; padding: clamp(100px, 12vw, 160px) var(--pad) 60px; }
  .ab2-team-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px, 4vw, 60px); margin-top: 40px; }
  .ab2-person-ph { aspect-ratio: 4/5; border-radius: 6px; background: linear-gradient(145deg, #1b2630, #0d0f14); display: grid; place-items: center; position: relative; overflow: hidden; }
  .ab2-person-ph.alt { background: linear-gradient(145deg, #2a2118, #0d0f14); }
  .ab2-person-ph::after { content: attr(data-mono); font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(60px, 8vw, 120px); letter-spacing: -0.04em; color: rgba(252,252,252,0.14); }
  .ab2-person-name { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 20px; margin-top: 18px; }
  .ab2-person-role { font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(252,252,252,0.55); margin-top: 6px; }
  .ab2-person-bio { margin-top: 12px; font-size: 14.5px; line-height: 1.65; font-weight: 300; color: rgba(252,252,252,0.7); max-width: 46ch; }

  /* RANGE */
  .ab2-range { background: var(--c-slate); padding: clamp(90px, 11vw, 140px) 0; }
  .ab2-range .ab2-body { margin-top: 0; }

  /* END */
  .ab2-end { min-height: 56vh; display: flex; flex-direction: column; gap: 40px; align-items: center; justify-content: center; text-align: center; padding: 70px var(--pad); }
  .ab2-end-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(34px, 5vw, 72px); letter-spacing: -0.025em; }
  .ab2-cta { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--black); background: var(--white); padding: 18px 30px; border-radius: 999px; text-decoration: none; transition: gap 0.3s ease, transform 0.3s ease; }
  .ab2-cta:hover { gap: 18px; transform: translateY(-2px); }

  .ab2 :global(.split .w) { display: inline-block; overflow: hidden; vertical-align: top; }
  .ab2 :global(.split .wi) { display: inline-block; transform: translateY(115%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .ab2 :global(.split.on .wi) { transform: none; }

  @media (max-width: 860px) {
    .ab2-stats { grid-template-columns: 1fr 1fr; }
    .ab2-cols { grid-template-columns: 1fr; gap: 18px; }
    .ab2-team-grid { grid-template-columns: 1fr; }
    .ab2-hero-img.b { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ab2-credo { height: auto; }
    .scn-stage { position: static; height: auto; padding: 16vh var(--pad); }
    .ab2-after { margin-top: 0; }
    .ab2-credo-line :global(.wi) { transform: none !important; transition: none !important; }
    .ab2-stroke path { stroke-dashoffset: 0; }
    .ab2-credo-sub { opacity: 1; }
    .ab2 :global(.split .wi) { transform: none !important; transition: none !important; }
    [data-drift] { transform: none !important; }
  }
</style>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clamp01 = (v: number) => Math.min(1, Math.max(0, v));
  const phase = (p: number, a: number, b: number) => clamp01((p - a) / (b - a));

  const splitWords = (root: Node, counter: { n: number }) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !(node as Element).closest('svg')) {
        splitWords(node, counter);
      }
    });
  };
  document.querySelectorAll('.split, [data-cwords]').forEach((el) => splitWords(el, { n: 0 }));
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('on'); io.unobserve(e.target); } }), { threshold: 0.35 });
  document.querySelectorAll('.split').forEach((el) => io.observe(el));

  const credo = document.querySelector('[data-scene="credo"]') as HTMLElement;
  const cWords = credo ? [...credo.querySelectorAll('.wi')] : [];
  const stroke = credo && (credo.querySelector('.ab2-stroke path') as SVGPathElement | null);
  const sub = credo && (credo.querySelector('.ab2-credo-sub') as HTMLElement | null);
  const drifts = [...document.querySelectorAll('[data-drift]')] as HTMLElement[];

  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      if (credo) {
        const r = credo.getBoundingClientRect();
        const p = clamp01(-r.top / (credo.offsetHeight - innerHeight * 2));
        cWords.forEach((w, i) => (w as HTMLElement).classList.toggle('on', phase(p, 0.05, 0.55) * cWords.length * 1.1 > i));
        if (stroke) stroke.style.setProperty('--soff', String(320 * (1 - phase(p, 0.58, 0.82))));
        if (sub) sub.style.setProperty('--subo', String(phase(p, 0.72, 0.9)));
      }
      drifts.forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.bottom < 0 || r.top > innerHeight) return;
        const c = (r.top + r.height / 2 - innerHeight / 2) / innerHeight;
        const v = Number(el.dataset.drift || 6);
        el.style.transform = `translateY(${c * -v * 6}px)`;
      });
      ticking = false;
    });
  };
  if (!reduced) {
    addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  } else {
    cWords.forEach((w) => (w as HTMLElement).classList.add('on'));
  }
</script>
