---
import Base from '../../layouts/Base.astro';

// MOTION LAB — FIND YOUR FLOW credits section. Two scroll-reactive variants
// stacked for A/B. Pick one → it becomes the real WorkCredits component, then
// this sandbox gets deleted. Credits data borrowed from Sony — This Moment.
const credits = [
  { k: 'Agency', v: 'Art of Visuals' },
  { k: 'Production', v: 'MGX Creative' },
  { k: 'Client', v: 'Sony Audio' },
  { k: 'Director', v: 'Daniel Malikyar' },
  { k: 'Creative Direction', v: 'DJ Ramirez' },
  { k: 'Stills', v: 'Claire LeJune' },
];
const ringText = 'FIND · YOUR · FLOW · FIND · YOUR · FLOW · FIND · YOUR · FLOW · ';
---
<Base title="FIND YOUR FLOW — motion lab — monuments">
  <main class="fyf-lab">
    <header class="fyf-lab-head">
      <h1>FIND YOUR FLOW — motion options</h1>
      <p>Scroll through both. Pick the one that feels right and I'll bake it into the real component.</p>
    </header>

    <!-- VARIANT A — Scroll-dial -->
    <section class="fyf-block" data-fyf="dial">
      <span class="fyf-tag">A · Scroll-dial — ring spin tracks scroll velocity</span>
      <div class="fyf-row">
        <div class="fyf-ring-wrap">
          <svg class="fyf-ring" data-ring="dial" viewBox="0 0 240 240" aria-hidden="true">
            <defs><path id="fyfPathA" d="M120,120 m-88,0 a88,88 0 1,1 176,0 a88,88 0 1,1 -176,0" /></defs>
            <text class="fyf-ring-text"><textPath href="#fyfPathA" startOffset="0">{ringText}</textPath></text>
          </svg>
        </div>
        <div class="fyf-credits">
          {credits.map((c) => (
            <div class="fyf-cred-row"><span class="fyf-cred-k">{c.k}:</span> <span class="fyf-cred-v">{c.v}</span></div>
          ))}
        </div>
      </div>
    </section>

    <!-- VARIANT B — Draw-in seal -->
    <section class="fyf-block" data-fyf="seal">
      <span class="fyf-tag">B · Draw-in seal — ring + stroke draw on as it enters, slow drift, hover the card</span>
      <div class="fyf-row">
        <div class="fyf-ring-wrap">
          <svg class="fyf-ring fyf-ring--seal" viewBox="0 0 240 240" aria-hidden="true">
            <defs><path id="fyfPathB" d="M120,120 m-88,0 a88,88 0 1,1 176,0 a88,88 0 1,1 -176,0" /></defs>
            <circle class="fyf-stroke" cx="120" cy="120" r="96" />
            <text class="fyf-ring-text"><textPath href="#fyfPathB" startOffset="0">{ringText}</textPath></text>
          </svg>
        </div>
        <div class="fyf-credits fyf-credits--reveal">
          {credits.map((c) => (
            <div class="fyf-cred-row"><span class="fyf-cred-k">{c.k}:</span> <span class="fyf-cred-v">{c.v}</span></div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <style>
    .fyf-lab-head { background: #0d0f14; color: var(--white); max-width: var(--wrap); margin: 0 auto; padding: clamp(80px, 11vw, 150px) var(--pad) 0; }
    .fyf-lab-head h1 { font-family: 'Inter', sans-serif; font-weight: 600; font-size: clamp(28px, 4vw, 46px); letter-spacing: -0.02em; }
    .fyf-lab-head p { margin-top: 12px; color: rgba(240,238,233,0.6); font-size: 15px; }

    .fyf-block { background: #0d0f14; color: var(--white); padding: clamp(70px, 9vw, 120px) var(--pad); }
    .fyf-tag { display: block; max-width: var(--wrap); margin: 0 auto 40px; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
    .fyf-row { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(30px, 5vw, 70px); align-items: center; max-width: var(--wrap); margin: 0 auto; }
    .fyf-ring-wrap { display: flex; justify-content: center; align-items: center; }
    .fyf-ring { width: clamp(240px, 26vw, 340px); height: clamp(240px, 26vw, 340px); overflow: visible; transform-origin: center; }
    .fyf-ring-text { fill: var(--white); font-family: 'Inter', sans-serif; font-weight: 500; font-size: 15px; letter-spacing: 3px; text-transform: uppercase; }

    .fyf-credits { background: var(--white); color: #141519; border-radius: 2px; padding: clamp(20px, 2.4vw, 32px) clamp(28px, 3.4vw, 46px); }
    .fyf-cred-row { font-size: clamp(15px, 1.4vw, 18px); line-height: 1; padding: 15px 0; border-bottom: 1px solid rgba(20,21,25,0.08); }
    .fyf-cred-row:last-child { border-bottom: 0; }
    .fyf-cred-k { font-weight: 600; }
    .fyf-cred-v { color: rgba(20,21,25,0.7); }

    /* Variant B — draw-in seal */
    .fyf-ring--seal .fyf-ring-text { opacity: 0; transition: opacity 1.1s ease 0.3s; }
    .fyf-block.is-in .fyf-ring--seal .fyf-ring-text { opacity: 1; }
    .fyf-stroke { fill: none; stroke: var(--accent); stroke-width: 2; stroke-dasharray: 605; stroke-dashoffset: 605; transition: stroke-dashoffset 1.5s cubic-bezier(.16,1,.3,1) 0.1s; }
    .fyf-block.is-in .fyf-stroke { stroke-dashoffset: 0; }
    .fyf-block.is-in .fyf-ring--seal { animation: fyfDrift 46s linear infinite; }
    @keyframes fyfDrift { to { transform: rotate(360deg); } }

    .fyf-credits--reveal .fyf-cred-row { position: relative; opacity: 0.55; transition: opacity .35s ease, padding-left .35s ease; }
    .fyf-credits--reveal:hover .fyf-cred-row { opacity: 0.85; }
    .fyf-credits--reveal .fyf-cred-row::before { content: ''; position: absolute; left: 0; top: 50%; width: 0; height: 2px; background: var(--accent); transform: translateY(-50%); transition: width .3s ease; }
    .fyf-credits--reveal .fyf-cred-row:hover { opacity: 1; padding-left: 16px; }
    .fyf-credits--reveal .fyf-cred-row:hover::before { width: 10px; }

    @media (prefers-reduced-motion: reduce) {
      .fyf-block.is-in .fyf-ring--seal { animation: none; }
      .fyf-stroke { transition: none; stroke-dashoffset: 0; }
      .fyf-ring--seal .fyf-ring-text { transition: none; opacity: 1; }
    }
    @media (max-width: 820px) { .fyf-row { grid-template-columns: 1fr; gap: 44px; } }
  </style>

  <script>
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('is-in'); });
      }, { threshold: 0.3 });
      document.querySelectorAll('.fyf-block').forEach((b) => io.observe(b));

      const dial = document.querySelector('[data-ring="dial"]');
      if (dial && !reduce) {
        let rot = 0;
        const loop = () => {
          const v = (window.lenis && typeof window.lenis.velocity === 'number') ? window.lenis.velocity : 0;
          rot += 0.05 + v * 0.35;
          dial.style.transform = 'rotate(' + rot.toFixed(2) + 'deg)';
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);
      }
    })();
  </script>
</Base>
