  .ds-4 { left: 88px; background: var(--accent);   border-radius: 999px; width: 32px; animation-delay: 0.15s; }
  .ds-5 { left: 20px; bottom: 48px; background: var(--accent-2); border-radius: 3px; animation-delay: 0.4s; }
  .ds-6 { left: 70px; bottom: 48px; background: var(--ink); border-radius: 50%; animation-delay: 0.6s; }
  @keyframes dDrop { 0% { transform: translateY(-120px); opacity: 0; } 20%,100% { transform: translateY(0); opacity: 0.92; } }

  /* theme: animated reskin swatches (a sample of the picker presets) */
  .d-theme { display: flex; flex-wrap: wrap; gap: 10px; }
  .d-theme .dt { width: 30px; height: 30px; border-radius: 50%; border: 1px solid rgb(var(--ink-rgb) / 0.2); animation: dThemeP 4s ease-in-out infinite; }
  .dt-1 { background: radial-gradient(circle at 50% 50%, #ff3b2e 0 44%, #0c0b0a 46% 100%); animation-delay: 0s; }
  .dt-2 { background: radial-gradient(circle at 50% 50%, #ff3b2e 0 44%, #000000 46% 100%); animation-delay: 0.2s; }
  .dt-3 { background: radial-gradient(circle at 50% 50%, #5768ff 0 44%, #0a0b12 46% 100%); animation-delay: 0.4s; }
  .dt-4 { background: radial-gradient(circle at 50% 50%, #d3261c 0 44%, #f4efe6 46% 100%); animation-delay: 0.6s; }
  .dt-5 { background: radial-gradient(circle at 50% 50%, #5b6cff 0 44%, #0e1014 46% 100%); animation-delay: 0.8s; }
  .dt-6 { background: radial-gradient(circle at 50% 50%, #ffb224 0 44%, #0b110d 46% 100%); animation-delay: 1s; }
  .dt-7 { background: radial-gradient(circle at 50% 50%, #b9450f 0 44%, #f3ece1 46% 100%); animation-delay: 1.2s; }
  .dt-8 { background: radial-gradient(circle at 50% 50%, #ff3b2e 0 44%, #050505 46% 100%); animation-delay: 1.4s; }
  @keyframes dThemeP { 0%,100% { transform: scale(1); } 50% { transform: scale(1.12); } }

