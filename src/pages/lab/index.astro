  /* --- block demos --- */
  /* cursor: a lagging disc chasing a dot */
  .d-cursor { position: relative; width: 100%; height: 100%; }
  .d-cursor-disc { position: absolute; left: 30%; top: 50%; width: 56px; height: 56px; margin: -28px 0 0 -28px; border-radius: 50%; background: rgb(var(--ink-rgb) / 0.12); border: 1px solid rgb(var(--ink-rgb) / 0.3); display: flex; align-items: center; justify-content: center; animation: dcDisc 3.4s cubic-bezier(0.5,0,0.2,1) infinite; }
  .d-cursor-disc i { font-style: normal; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); }
  .d-cursor-dot { position: absolute; left: 30%; top: 50%; width: 5px; height: 5px; margin: -2.5px 0 0 -2.5px; border-radius: 50%; background: var(--accent); animation: dcDot 3.4s cubic-bezier(0.5,0,0.2,1) infinite; }
