  /* ---------- EXPERIMENT TILES ---------- */
  .lab-exp { position: relative; }
  .lab-tiles { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .lab-tile { position: relative; border-top: 1px solid rgb(var(--ink-rgb) / 0.1); }
  .lab-tile:last-child { border-bottom: 1px solid rgb(var(--ink-rgb) / 0.1); }
  .lab-tile-main { display: grid; grid-template-columns: 64px 1fr auto; gap: clamp(18px, 3vw, 44px); align-items: center; padding: clamp(34px, 3.6vw, 48px) 8px clamp(34px, 3.6vw, 48px) 6px; text-decoration: none; color: var(--ink); position: relative; transition: padding-left 0.4s cubic-bezier(0.16,1,0.3,1); overflow: hidden; }
  /* accent wash that sweeps in on hover */
  .lab-tile-main::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgb(var(--ink-rgb) / 0.05), transparent 70%); transform: translateX(-100%); transition: transform 0.55s cubic-bezier(0.16,1,0.3,1); z-index: 0; }
  .lab-tile-main:hover::before { transform: translateX(0); }
  .lab-tile-main:hover { padding-left: 22px; }
  .lab-tile-n { position: relative; z-index: 1; font-size: 13px; letter-spacing: 0.16em; color: rgb(var(--ink-rgb) / 0.4); font-feature-settings: 'tnum'; }
  .lab-tile-body { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 8px; }
  .lab-tile-tag { font-size: 10.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
  .lab-tile-t { position: relative; width: fit-content; font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(26px, 3.4vw, 50px); letter-spacing: -0.025em; line-height: 1.02; }
  .lab-tile:hover .lab-stroke path { stroke-dashoffset: 0; }
  .lab-tile-d { max-width: 64ch; font-size: clamp(13.5px, 1vw, 15px); line-height: 1.6; font-weight: 300; color: rgb(var(--ink-rgb) / 0.6); }
  .lab-tile-go { position: relative; z-index: 1; font-size: clamp(22px, 2.4vw, 34px); color: rgb(var(--ink-rgb) / 0.3); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), color 0.3s ease; }
  .lab-tile-main:hover .lab-tile-go { color: var(--accent); transform: translate(6px, -6px); }

  /* cursor-following preview image (one shared element, src swapped on hover) */
  .lab-prev { position: absolute; top: 0; left: 0; z-index: 4; width: clamp(220px, 22vw, 320px); aspect-ratio: 4/3; border-radius: 8px; overflow: hidden; pointer-events: none; opacity: 0; transform: translate(-50%, -50%) scale(0.92); transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.16,1,0.3,1); box-shadow: 0 24px 60px rgb(var(--ink-rgb) / 0.18); border: 1px solid rgb(var(--ink-rgb) / 0.12); will-change: transform, opacity; }
  .lab-prev img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lab-prev::after { content: 'View'; position: absolute; left: 10px; bottom: 8px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--paper); background: rgb(var(--ink-rgb) / 0.55); padding: 4px 9px; border-radius: 999px; backdrop-filter: blur(4px); }
  .lab-exp.prev-on .lab-prev { opacity: 1; transform: translate(-50%, -50%) scale(1); }

  .lab-vs { position: absolute; right: 8px; bottom: clamp(20px, 2.6vw, 30px); z-index: 2; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.5); text-decoration: none; white-space: nowrap; transition: color 0.25s ease; }
  a.lab-vs:hover { color: var(--accent); }
