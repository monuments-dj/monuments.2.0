  .lab-list li:last-child { border-bottom: 1px solid rgb(var(--ink-rgb) / 0.1); }
  .lab-row:hover { padding-left: 16px; }
  .lab-row-n { font-size: 12px; letter-spacing: 0.18em; color: rgb(var(--ink-rgb) / 0.4); }
  .lab-row-t { position: relative; width: fit-content; font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(18px, 1.9vw, 26px); letter-spacing: -0.02em; color: var(--ink); text-decoration: none; }
  .lab-row:hover .lab-stroke path { stroke-dashoffset: 0; }
  .lab-row-d { font-size: 14px; line-height: 1.6; font-weight: 300; color: rgb(var(--ink-rgb) / 0.58); max-width: 52ch; }
  /* "Built this session" index */
