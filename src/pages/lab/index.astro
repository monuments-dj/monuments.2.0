<script>
  // Word splitter (line-safe, descender-safe per the type-clip rules).
  const splitWords = (root: Node, counter: { n: number }) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !(node as Element).closest('svg')) {
        splitWords(node, counter);
      }
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));

  // On-enter reveals (split + fade).
  const io = new IntersectionObserver((es) => es.forEach((e) => {
    if (e.isIntersecting) { (e.target as HTMLElement).classList.add('on'); io.unobserve(e.target); }
  }), { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.split, .fade').forEach((el) => io.observe(el));

  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Hero strip: subtle per-frame scroll parallax (media travels slower than type).
  const heroFrames = [...document.querySelectorAll('.lab-hero-frame')];
  let hTick = false;
  const onHeroScroll = () => {
    if (hTick) return;
    hTick = true;
    requestAnimationFrame(() => {
      const y = scrollY;
      heroFrames.forEach((f) => {
        const sp = Number((f as HTMLElement).dataset.hspeed || 0.5);
        (f as HTMLElement).style.transform = `translateY(${y * sp * -0.10}px)`;
      });
      hTick = false;
    });
  };
  if (!reduced && heroFrames.length) {
    addEventListener('scroll', onHeroScroll, { passive: true });
    onHeroScroll();
  }

  // Experiment tiles: a shared preview image that follows the cursor and fades
  // in on hover, swapping to that page's representative real frame.
  const exp = document.querySelector('.lab-exp') as HTMLElement | null;
  const prev = exp ? exp.querySelector('.lab-prev') as HTMLElement | null : null;
  const prevImg = prev ? prev.querySelector('img') as HTMLImageElement | null : null;
  const fineHover = matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (exp && prev && prevImg && fineHover) {
    let px = 0, py = 0, cx = 0, cy = 0, raf = 0, active = false;
    const loop = () => {
      cx += (px - cx) * 0.18;
      cy += (py - cy) * 0.18;
      prev.style.left = cx + 'px';
      prev.style.top = cy + 'px';
      if (active || Math.abs(px - cx) > 0.3 || Math.abs(py - cy) > 0.3) {
        raf = requestAnimationFrame(loop);
      } else { raf = 0; }
    };
    const tiles = [...exp.querySelectorAll('.lab-tile-main')] as HTMLElement[];
    tiles.forEach((tile) => {
      tile.addEventListener('pointerenter', (e) => {
        if ((e as PointerEvent).pointerType === 'touch') return;
        const src = tile.dataset.prev;
        if (src && prevImg.getAttribute('src') !== src) prevImg.src = src;
        const r = exp.getBoundingClientRect();
        px = (e as PointerEvent).clientX - r.left;
        py = (e as PointerEvent).clientY - r.top;
        cx = px; cy = py; // snap on first enter so it doesn't fly across
        active = true;
        exp.classList.add('prev-on');
        if (!raf) raf = requestAnimationFrame(loop);
      });
      tile.addEventListener('pointermove', (e) => {
        const r = exp.getBoundingClientRect();
        px = (e as PointerEvent).clientX - r.left;
        py = (e as PointerEvent).clientY - r.top;
        if (!raf) raf = requestAnimationFrame(loop);
      }, { passive: true });
      tile.addEventListener('pointerleave', () => {
        active = false;
        exp.classList.remove('prev-on');
      });
    });
  }

  // --- Ticker playground: live speed + invert controls drive both tickers ---
  (function () {
    const lab = document.querySelector('[data-ticklab]');
    if (!lab) return;
    const stack = lab.querySelector('[data-tl-stack]');
    const tickers = stack ? [...stack.querySelectorAll('.brand-ticker')] : [];
    const range = lab.querySelector('[data-tl-speed]');
    const speedVal = lab.querySelector('[data-tl-speedval]');
    if (range) {
      const apply = () => {
        const v = range.value;
        tickers.forEach((t) => { t.dataset.speed = v; });
        if (speedVal) speedVal.textContent = v;
      };
      range.addEventListener('input', apply);
      apply();
    }
    const sizeRange = lab.querySelector('[data-tl-size]');
    const sizeVal = lab.querySelector('[data-tl-sizeval]');
    if (sizeRange) {
      const applySize = () => {
        const v = sizeRange.value;
        tickers.forEach((t) => { t.style.setProperty('--bt-size', v + 'px'); });
        if (sizeVal) sizeVal.textContent = v;
      };
      sizeRange.addEventListener('input', applySize);
      applySize();
    }
    // Invert swaps each ticker's tone (white-on-dark <-> black-on-light) so both
    // stay readable; toggling the tone class lets BrandTicker's own scoped styles
    // do the work (a parent style can't reach into the scoped component).
    const setInvert = (on) => {
      tickers.forEach((t, i) => {
        const base = i === 0 ? 'black' : 'white';
        const tone = on ? (base === 'white' ? 'black' : 'white') : base;
        t.classList.remove('bt-white', 'bt-black');
        t.classList.add('bt-' + tone);
      });
    };
    lab.querySelectorAll('[data-tl-invert]').forEach((btn) => {
      btn.addEventListener('click', () => {
        setInvert(btn.getAttribute('data-tl-invert') === 'on');
        lab.querySelectorAll('[data-tl-invert]').forEach((b) => b.classList.toggle('on', b === btn));
      });
    });
  })();
</script>
