  .lab-card-demo { position: relative; height: 168px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: radial-gradient(120% 140% at 50% 0%, rgb(var(--ink-rgb) / 0.04), transparent 70%); border-bottom: 1px solid rgb(var(--ink-rgb) / 0.06); border-radius: 13px 13px 0 0; }
