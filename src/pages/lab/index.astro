---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';
import BrandTicker from '../../components/BrandTicker.astro';
import FloatingHand from '../../components/FloatingHand.astro';
import ShapePile from '../../components/ShapePile.astro';
import PatternLibrary from '../../components/PatternLibrary.astro';
import BrandWorld from '../../components/BrandWorld.astro';
import CreditsBar from '../../components/CreditsBar.astro';

// === THE LAB (/lab) ===
// Public-facing Laboratory showcase: proof the studio is ahead of the market.
// Every v2 page is an experiment tile (with a compare link to its live
// counterpart); a "building blocks" rack shows off the shipped toys; ShapePile
// + CTA close it out. Tokenized end to end so the LabFx selector re-skins it.

// The v2 set: bold experiment tiles. Each links to the new build; "compare"
// links to what it would replace. Originals stay untouched until promoted.
// `prev` is a representative real frame that fades in, cursor-following, on hover.
const v2 = [
  { href: '/lab/know-vape',     vs: null, t: 'Know Vape',     tag: 'Emmy series',  prev: '/case-studies/know-vape/gallery/hero.jpg',           d: "Emmy-winning anti-vaping film series for Idaho Public Television. Big Tobacco vs Idaho teens, told straight." },
  { href: '/lab/buck-the-quo',  vs: null, t: 'Buck the Quo',  tag: 'Experiential', prev: '/case-studies/buck-the-quo/gallery/future-sign.jpg', d: "Experiential campaign for Idaho teens. The More In Store activation, 18,000 conversations, top Rocky Awards." },
  { href: '/lab/adorama-music', vs: null, t: 'Adorama Music', tag: 'Brand film',   prev: '/case-studies/adorama-music/gallery/am-01.jpg',      d: "The film that launched Adorama Music. Garage to studio to stage, 160M impressions, a Shorty finalist." },
  { href: '/lab/art-of-visuals', vs: null, t: 'Art of Visuals', tag: 'Agency growth', prev: '/case-studies/art-of-visuals/gallery/xm5-01.jpg',   d: "The business story: I led creative as the agency grew revenue ~4x. Sony, Xperia, the work that scaled it." },
  { href: '/lab/dw-drums', vs: null, t: 'DW Drums', tag: 'Campaign', prev: '/case-studies/dw-drums/gallery/face-off.jpg', d: "Split-screen campaign for DWe electronic drums. Engineer approved, drummer tested, torn down the middle." },
  { href: '/lab/home',       vs: '/',                t: 'Homepage',       tag: 'Tilt hero',      prev: '/case-studies/sony-this-moment/gallery/tm-01.jpg', d: "SIGHT SOUND EMOTION tilt hero, the red floating hand, a scroll-velocity ticker, parallax work scenes." },
  { href: '/lab/work',       vs: '/work',            t: 'Work index',     tag: 'Portal scroll',  prev: '/case-studies/blue-cross/gallery/bci-02.jpg',       d: "Horizontal-scroll gallery with a cursor-driven preview index. The work takes over the viewport." },
  { href: '/lab/blue-cross', vs: '/work/blue-cross', t: 'Case study',     tag: 'Editorial',      prev: '/case-studies/blue-cross/gallery/bci-10.jpg',       d: "Editorial chapters, a pinned insight scene, and a portal hand-off into the next project." },
  { href: '/lab/ai',         vs: null,               t: 'AI systems',     tag: 'New offer',      prev: '/case-studies/sony-flow-state/gallery/fs-01.jpg',   d: "Audit. Automate. Deploy. The consulting offer, with the word-cascade moment in full." },
  { href: '/lab/about',      vs: '/about',           t: 'About',          tag: 'Pinned credo',   prev: '/gallery/full/p-020.jpg',                           d: "Builds monuments, not moments. A drifting photo wall, billions reached, a pinned credo scene." },
  { href: '/lab/services',   vs: '/services',        t: 'Services',       tag: 'Tilted cards',   prev: '/case-studies/flashpoint/gallery/fp-01.jpg',        d: "The real capabilities, agency and production, plus the AI systems block on tilted cards." },
  { href: '/lab/contact',    vs: '/contact',         t: 'Contact',        tag: 'Email as page',  prev: '/case-studies/clothing-merch/gallery/cm-01.jpg',    d: "The email is the page. Badges escaped the menu. Modern, fast, almost nothing to click." },
];

// Hero montage: four real campaign stills that float beside the title on a
// light ground (no scrim now; the frames read at full opacity). Each frame gets
// its own parallax rate via data-hspeed; the strip duplicates for a seamless
// loop. Curated mix across the real case-study galleries.
const heroStrip = [
  { src: '/case-studies/sony-this-moment/gallery/tm-04.jpg',   sp: 0.5 },
  { src: '/case-studies/blue-cross/gallery/bci-14.jpg',        sp: 0.8 },
  { src: '/case-studies/flashpoint/gallery/fp-01.jpg',         sp: 0.65 },
  { src: '/case-studies/sony-flow-state/gallery/fs-01.jpg',    sp: 0.85 },
];

// Shipped building blocks: the toys, as labeled interactive cards. Each card's
// `demo` key drives a tiny live demo rendered in markup below.
const blocks = [
  { demo: 'cursor', t: 'Contextual cursor', d: "A lagging disc that swaps its label by context: View, Scroll, Explore. Reads data attributes off whatever it touches." },
  { demo: 'weave',  t: 'Weaving line',      d: "An organic thread that draws itself down a page edge in time with scroll. Ties a long page together." },
  { demo: 'ticker', t: 'Brand ticker',      d: "A logo marquee that drifts on its own and speeds up with scroll velocity. Hover to pause, click to leave." },
  { demo: 'hand',   t: 'Floating hand',     d: "The red signature mark. Idle-bobs, then deploys and parallaxes as it enters view. The studio's tell." },
  { demo: 'pile',   t: 'Shape pile',        d: "Brand-colored shapes that fall and pile up at a section floor as it scrolls in. Playful, never a game." },
  { demo: 'theme',  t: 'Theme selector',    d: "Eight presets reskin the whole page live from tokens, each one contrast-checked by a color tool. Try the swatches in the corner; nothing is hardcoded." },
];

// Selected work: lighter case studies for range (not flagship deep-dives). New
// hiring-portfolio entries live here so the reel doesn't turn into a dump.
const selectedWork = [
  { href: '/lab/donut-zumiez', t: 'Donut × Zumiez', tag: 'Launch films', d: "2023 collab drop. I directed the launch films for a car-culture brand and a streetwear retailer, films + merch as one release." },
  { href: '/lab/ac-boise', t: 'AC Boise', tag: 'Kit reveal', d: "“This kit is Boise.” A USL League One kit reveal with Hummel and Against, directed to be posted and worn." },
  { href: '/work/sony-this-moment', t: 'Sony · This Moment', tag: 'Launch film', d: "One of the Sony launch campaigns. The live case study on the production site." },
  { href: '/work/sony-flow-state', t: 'Sony · Flow State', tag: 'Launch film', d: "Sony flow-state launch work. Live case study on the production site." },
];

// The older experiments: kept as a quieter "also in progress" row.
const experiments = [
  { href: '/lab/fearless', t: 'Fearless (draft)', d: "Scaffolded case-study page, awaiting DJ's content + assets. Structure is ready to fill." },
  { href: '/lab/flashpoint', t: 'Flashpoint case study', d: "A light-forward rebrand page: the Imagine / Illuminate / Create concept, floating mockups, scroller hand-off." },
  { href: '/lab/project-detail', t: 'Project-detail slider', d: "A pinned horizontal chapter slider in the Lusion of_the_oak style. The newest pattern." },
  { href: '/lab/find-your-flow', t: 'Find Your Flow ring',  d: "Three credits-ring motion options, awaiting a final pick." },
  { href: '/lab/work-kit',       t: 'Work component kit',   d: "Self-contained work-page parts. The seed of the site-factory." },
  { href: '/work-preview/sony-this-moment', t: 'CMS pipeline proof', d: "Sony This Moment, rendered from Keystatic content end to end." },
];

// Everything built in the 2026-06-14 session, indexed up top so it is easy to find.
// On-this-page items deep-link to the live element; the rest link to their page.
const sessionWork = [
  { href: '/lab/project-detail', t: 'Project-detail slider', tag: 'New page', d: "Pinned horizontal chapter slider, Lusion of_the_oak style." },
  { href: '/lab/flashpoint', t: 'Flashpoint case study', tag: 'New page', d: "Light-forward rebrand page: the Imagine / Illuminate / Create concept." },
  { href: '/lab/sony-this-moment', t: 'Next-project hand-off', tag: 'Component', d: "Growing media preview + scroll-to-next, at the bottom of the case studies." },
  { href: '/lab#brand', t: 'Brand system, integrated', tag: 'On this page', d: "The brand book woven into the lab: wordmark, palette, symbol family, eye-sun, voice." },
  { href: '/lab#photo-galleries', t: 'Photo galleries', tag: 'On this page', d: "Pattern-library element: justified / masonry / grid + the lightbox." },
  { href: '/lab#next-project', t: 'Next-project handoff element', tag: 'On this page', d: "Pattern-library element: the exoape grow-and-handoff." },
  { href: '/', t: 'Play / Reel reveal', tag: 'Homepage', d: "Promoted to the production homepage. Scroll down to the showreel." },
  { href: '/', t: 'Metallic M loader', tag: 'Homepage', d: "The new intro loader. Open the home in a fresh tab to catch it." },
];
---
<Base title="The Lab, monuments">
  <main class="lab">
    <!-- HERO -->
    <header class="lab-hero">
      <!-- drifting strip of real work stills, floating on the light ground -->
      <div class="lab-hero-strip" aria-hidden="true">
        <div class="lab-hero-track">
          {[...heroStrip, ...heroStrip].map((f) => (
            <figure class="lab-hero-frame" data-hspeed={f.sp}>
              <img src={f.src} alt="" loading="eager" decoding="async" />
            </figure>
          ))}
        </div>
      </div>
      <FloatingHand side="right" top="16vh" />
      <div class="lab-hero-inner">
        <p class="lab-eyebrow fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>The lab</p>
        <h1 class="lab-h1 split">Where we test <em>what's next.</em></h1>
        <p class="lab-lead fade">This is the open workbench. We build the studio's own pages here first, in public, with the emerging web tech and AI we then bring to client work. If something is bleeding into the future, it shows up on this page before it ships anywhere else.</p>
        <div class="lab-meta fade">
          <span><b>{v2.length}</b> live experiments</span>
          <span><b>{blocks.length}</b> shipped building blocks</span>
          <span><b>8</b> themes, reskinned live</span>
        </div>
      </div>
      <div class="lab-scrollcue fade" data-cursor="Scroll" aria-hidden="true"><span>Scroll</span><i></i></div>
    </header>

    <!-- CREDITS BAR: simplified, full-width, ships on every work/case-study page -->
    <section class="lab-sec lab-credits-pick" id="credits">
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>On every page</p>
        <h2 class="lab-sec-title split">The project <em>credits bar.</em></h2>
        <p class="lab-sec-sub fade">Simplified and full-width. The agency, my role, and the other creators, on one black band. This is the version that ships on every work + case-study page.</p>
      </div>
    </section>
    <CreditsBar />

    <!-- BUILT THIS SESSION — quick index of everything new, so it's easy to find -->
    <section class="lab-sec lab-session" id="this-session">
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Built this session</p>
        <h2 class="lab-sec-title split">Everything from <em>today,</em> in one place.</h2>
        <p class="lab-sec-sub fade">Quick links to all the new work, so nothing gets lost. June 14.</p>
      </div>
      <ul class="lab-list">
        {sessionWork.map((p, i) => (
          <li class="lab-row fade">
            <span class="lab-row-n">{String(i + 1).padStart(2, '0')}</span>
            <a class="lab-row-t" href={p.href} data-cursor="View">
              {p.t}
              <svg class="lab-stroke sm" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
            </a>
            <span class="lab-row-d"><span class="lab-session-tag">{p.tag}</span>{p.d}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- BRAND WORLD — the brand book (v0.8) integrated into the lab as a dark band -->
    <BrandWorld />

    <!-- BRAND TICKER -->
    <div class="lab-ticker-band"><BrandTicker tone="black" /></div>

    <!-- THE EXPERIMENTS -->
    <section class="lab-sec lab-exp">
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>The experiments</p>
        <h2 class="lab-sec-title split">Seven pages, rebuilt from <em>nothing.</em></h2>
        <p class="lab-sec-sub fade">Open the title to see the new build. Open compare to see the live page it would replace. Nothing goes live until we call it.</p>
      </div>

      <ul class="lab-tiles">
        {v2.map((p, i) => (
          <li class="lab-tile fade">
            <a class="lab-tile-main" href={p.href} data-cursor="View" data-prev={p.prev} aria-label={`Open the ${p.t} experiment`}>
              <span class="lab-tile-n">{String(i + 1).padStart(2, '0')}</span>
              <span class="lab-tile-body">
                <span class="lab-tile-tag">{p.tag}</span>
                <span class="lab-tile-t">
                  {p.t}
                  <svg class="lab-stroke" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
                </span>
                <span class="lab-tile-d">{p.d}</span>
              </span>
              <span class="lab-tile-go" aria-hidden="true">↗</span>
            </a>
            {p.vs
              ? <a class="lab-vs" href={p.vs} data-cursor="Compare">compare live <span aria-hidden="true">→</span></a>
              : <span class="lab-vs lab-vs-new">new page</span>}
          </li>
        ))}
      </ul>

      <!-- shared cursor-following preview: image fades in on tile hover -->
      <div class="lab-prev" aria-hidden="true"><img alt="" decoding="async" /></div>
    </section>

    <!-- SELECTED WORK: lighter case studies for range -->
    <section class="lab-sec lab-selected" id="selected-work">
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Selected work</p>
        <h2 class="lab-sec-title split">More of the <em>range.</em></h2>
        <p class="lab-sec-sub fade">Shorter cuts, not deep-dives. Enough to show the reach across sport, streetwear, and brand.</p>
      </div>
      <ul class="lab-list">
        {selectedWork.map((p, i) => (
          <li class="lab-row fade">
            <span class="lab-row-n">{String(i + 1).padStart(2, '0')}</span>
            <a class="lab-row-t" href={p.href} data-cursor="View">
              {p.t}
              <svg class="lab-stroke sm" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
            </a>
            <span class="lab-row-d"><span class="lab-session-tag">{p.tag}</span>{p.d}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- BUILDING BLOCKS: the toys -->
    <section class="lab-sec lab-blocks">
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Shipped building blocks</p>
        <h2 class="lab-sec-title split">The toys, out of the <em>box.</em></h2>
        <p class="lab-sec-sub fade">Every page above is assembled from these. Built once, reused everywhere. Poke at them.</p>
      </div>

      <div class="lab-grid">
        {blocks.map((b) => (
          <article class={`lab-card fade card-${b.demo}`} data-cursor="Explore">
            <div class="lab-card-demo" aria-hidden="true">
              {b.demo === 'cursor' && (
                <div class="d-cursor"><span class="d-cursor-disc"><i>View</i></span><span class="d-cursor-dot"></span></div>
              )}
              {b.demo === 'weave' && (
                <svg class="d-weave" viewBox="0 0 120 200" preserveAspectRatio="none" fill="none" aria-hidden="true"><path d="M60 4 C 10 40, 110 76, 60 112 C 12 148, 108 176, 60 196" /></svg>
              )}
              {b.demo === 'ticker' && (
                <div class="d-ticker"><div class="d-ticker-row"><b>SONY</b><b>INTEL</b><b>MSI</b><b>LEXAR</b><b>SONY</b><b>INTEL</b><b>MSI</b><b>LEXAR</b></div></div>
              )}
              {b.demo === 'hand' && (
                <svg class="d-hand" viewBox="0 0 200 240" aria-hidden="true"><path fill="var(--accent)" d="M52 232 C44 232 38 226 38 218 L38 150 C28 150 22 142 22 132 L22 96 C22 88 28 82 36 82 C44 82 50 88 50 96 L50 122 L56 122 L56 40 C56 32 62 26 70 26 C78 26 84 32 84 40 L84 116 L90 116 L90 22 C90 14 96 8 104 8 C112 8 118 14 118 22 L118 116 L124 116 L124 34 C124 26 130 20 138 20 C146 20 152 26 152 34 L152 124 L158 124 L162 96 C164 86 172 80 181 82 C189 84 194 92 192 101 L182 158 C176 198 150 232 108 232 Z"/></svg>
              )}
              {b.demo === 'pile' && (
                <div class="d-pile"><span class="ds ds-1"></span><span class="ds ds-2"></span><span class="ds ds-3"></span><span class="ds ds-4"></span><span class="ds ds-5"></span><span class="ds ds-6"></span></div>
              )}
              {b.demo === 'theme' && (
                <div class="d-theme"><span class="dt dt-1"></span><span class="dt dt-2"></span><span class="dt dt-3"></span><span class="dt dt-4"></span><span class="dt dt-5"></span><span class="dt dt-6"></span><span class="dt dt-7"></span><span class="dt dt-8"></span></div>
              )}
            </div>
            <div class="lab-card-text">
              <h3 class="lab-card-t">{b.t}</h3>
              <p class="lab-card-d">{b.d}</p>
            </div>
          </article>
        ))}
      </div>

      <p class="lab-blocks-note fade">Want the selector? It's living bottom-left of this page. Click a swatch and the whole thing reskins from tokens, no reload.</p>
    </section>

    <!-- TICKER PLAYGROUND: light + dark, with live speed + tone controls -->
    <section class="lab-sec lab-ticklab" data-ticklab>
      <div class="lab-sec-head">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>The logo ticker, tuned live</p>
        <h2 class="lab-sec-title split">Light or dark, <em>your tempo.</em></h2>
        <p class="lab-sec-sub fade">Both tones, side by side. Drag the speed and flip the invert to tune the strip that runs on every page.</p>
      </div>

      <div class="tl-controls fade">
        <label class="tl-field">
          <span class="tl-field-l">Speed <b data-tl-speedval>40</b> px/s</span>
          <input class="tl-range" type="range" min="0" max="140" value="40" step="2" data-tl-speed aria-label="Ticker speed" />
        </label>
        <label class="tl-field">
          <span class="tl-field-l">Logo size <b data-tl-sizeval>30</b> px</span>
          <input class="tl-range" type="range" min="14" max="66" value="30" step="2" data-tl-size aria-label="Logo size" />
        </label>
        <div class="tl-seg" role="group" aria-label="Tone">
          <button class="tl-seg-btn on" type="button" data-tl-invert="off">Black on light</button>
          <button class="tl-seg-btn" type="button" data-tl-invert="on">White on dark</button>
        </div>
      </div>

      <div class="tl-stack" data-tl-stack>
        <div class="tl-card"><BrandTicker tone="black" speed={40} /></div>
        <div class="tl-card"><BrandTicker tone="white" speed={40} /></div>
      </div>
    </section>

    <!-- PATTERN LIBRARY (inline; lives on the hub, no separate click-through) -->
    <PatternLibrary />

    <!-- ALSO IN PROGRESS -->
    <section class="lab-sec lab-more">
      <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Also on the bench</p>
      <ul class="lab-list">
        {experiments.map((p, i) => (
          <li class="lab-row fade">
            <span class="lab-row-n">x{i + 1}</span>
            <a class="lab-row-t" href={p.href} data-cursor="View">
              {p.t}
              <svg class="lab-stroke sm" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
            </a>
            <span class="lab-row-d">{p.d}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- CTA + SHAPE PILE -->
    <section class="lab-end">
      <FloatingHand side="left" top="8vh" />
      <div class="lab-end-inner">
        <p class="lab-kicker fade"><span class="lab-kicker-mark" aria-hidden="true">+</span>Seen enough?</p>
        <p class="lab-end-big split">This is the edge we build from. <em>Let's build yours.</em></p>
        <a class="lab-cta fade" href="/contact" data-mag data-cursor="Let's talk">Start a conversation <span aria-hidden="true">↗</span></a>
      </div>
      <ShapePile count={30} height="clamp(220px, 30vh, 360px)" />
    </section>

  </main>
  <LabFx />
</Base>

<style>
  .lab { background: var(--paper); color: var(--ink); overflow-x: clip; }
  /* Kicker label: small caps next to the accent "+" marker. Default tone is the
     light-band ink; dark bands (reel, .lab-end) re-tint the label to fg below. */
  .lab-eyebrow,
  .lab-kicker { display: inline-flex; align-items: baseline; gap: 22px; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(var(--ink-rgb) / 0.75); }
  .lab-eyebrow { letter-spacing: 0.24em; }
  .lab-kicker-mark { color: var(--accent); font-weight: 500; }
  .lab-h1 em, .lab-sec-title em, .lab-end-big em { font-style: italic; color: var(--accent); }

  /* ---------- HERO (dark) ---------- */
  .lab-hero { position: relative; min-height: 96vh; display: flex; align-items: center; overflow: hidden; padding: 16vh 0 12vh; background: var(--bg); color: var(--fg); }
  .lab-hero .lab-eyebrow { color: rgb(var(--fg-rgb) / 0.72); }
  .lab-hero-inner { position: relative; z-index: 3; max-width: var(--wrap); margin: 0 auto; padding: 0 var(--pad); width: 100%; }
  /* soft dark scrim so the light headline reads cleanly over the floating frames */
  .lab-hero-inner::before { content: ''; position: absolute; inset: -5vh -8%; z-index: -1; pointer-events: none;
    background: radial-gradient(120% 86% at 44% 46%, color-mix(in srgb, var(--bg) 88%, transparent) 0%, color-mix(in srgb, var(--bg) 60%, transparent) 42%, transparent 78%); }
  .lab-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(46px, 8vw, 128px); line-height: 1; letter-spacing: -0.035em; margin-top: 22px; padding-bottom: 0.12em; }
  .lab-lead { margin-top: 30px; max-width: 56ch; font-size: clamp(16px, 1.4vw, 19px); line-height: 1.72; font-weight: 300; color: rgb(var(--fg-rgb) / 0.72); }
  .lab-meta { margin-top: 36px; display: flex; flex-wrap: wrap; gap: clamp(20px, 3vw, 44px); font-size: 13px; font-weight: 300; letter-spacing: 0.02em; color: rgb(var(--fg-rgb) / 0.55); }
  .lab-meta b { font-weight: 500; color: var(--accent); font-size: 15px; }

  /* floating montage strip of real stills (dark ground now, soft drop shadow for depth) */
  .lab-hero-strip { position: absolute; inset: 0; z-index: 1; overflow: hidden; pointer-events: none; -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); }
  .lab-hero-track { position: absolute; top: 50%; left: 0; display: flex; gap: clamp(40px, 4vw, 80px); width: max-content; transform: translateY(-50%); animation: labDrift 70s linear infinite; will-change: transform; }
  .lab-hero-frame { position: relative; margin: 0; flex: 0 0 auto; width: clamp(220px, 26vw, 360px); aspect-ratio: 4/3; border-radius: 10px; overflow: hidden; opacity: 1; box-shadow: 0 28px 64px rgb(0 0 0 / 0.55); will-change: transform; }
  .lab-hero-frame:nth-child(even) { aspect-ratio: 3/4; align-self: flex-start; margin-top: clamp(-30px, -4vw, -10px); }
  .lab-hero-frame img { width: 100%; height: 118%; object-fit: cover; display: block; }
  @keyframes labDrift { from { transform: translate(0, -50%); } to { transform: translate(-50%, -50%); } }

  .lab-scrollcue { position: absolute; left: 50%; bottom: 24px; transform: translateX(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 8px; font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--fg-rgb) / 0.5); }
