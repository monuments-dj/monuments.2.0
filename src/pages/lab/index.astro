  .d-pile .ds { position: absolute; bottom: 26px; width: 20px; height: 20px; animation: dDrop 3.6s cubic-bezier(0.5,0,0.3,1) infinite; }
  .ds-1 { left: 6px;  background: var(--accent);   border-radius: 50%; animation-delay: 0s; }
  .ds-2 { left: 34px; background: var(--accent-2); border-radius: 3px; animation-delay: 0.25s; }
