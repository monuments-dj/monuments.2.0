  .lab-sec-sub { margin-top: 22px; max-width: 54ch; font-size: clamp(15px, 1.2vw, 17px); line-height: 1.7; font-weight: 300; color: rgb(var(--ink-rgb) / 0.66); }

  /* shared marker stroke */
