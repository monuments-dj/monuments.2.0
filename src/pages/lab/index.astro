  .lab-end-inner { position: relative; z-index: 2; max-width: var(--wrap); margin: 0 auto; padding: 0 var(--pad); text-align: center; display: flex; flex-direction: column; align-items: center; gap: 30px; }
  .lab-end-big { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(34px, 5.6vw, 86px); letter-spacing: -0.03em; line-height: 1.04; max-width: 16ch; padding-bottom: 0.1em; }
  .lab-cta { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--bg); background: var(--accent); padding: 18px 32px; border-radius: 999px; text-decoration: none; transition: gap 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease; box-shadow: 0 14px 40px rgb(var(--ink-rgb) / 0.2); }
