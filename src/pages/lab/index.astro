---
import Base from '../../layouts/Base.astro';
import LabFx from '../../components/LabFx.astro';

// === THE LAB INDEX — /lab ===
// DJ's hub for everything in progress: the v2 pages (with their current
// counterparts for instant A/B), plus the older experiments. Bookmark this.

const v2 = [
  { href: '/lab/home',       vs: '/',                 t: 'Homepage v2',       d: 'Pinned hero, marker circle, brand worlds, ticker, showreel kept.' },
  { href: '/lab/work',       vs: '/work',             t: 'Work portals',      d: 'Projects grow to full-bleed and hand off, exoape-style.' },
  { href: '/lab/blue-cross', vs: '/work/blue-cross',  t: 'Blue Cross, reimagined', d: 'Editorial chapters, pinned insight, portal next-project.' },
  { href: '/lab/ai',         vs: null,                t: 'AI systems',        d: 'Audit. Automate. Deploy. The $5k offer, WILD cascade and all.' },
  { href: '/lab/about',      vs: '/about',            t: 'About v2',          d: 'Hard rooms, pinned credo, team tiles, the range.' },
  { href: '/lab/services',   vs: '/services',         t: 'Services v2',       d: 'CD-first rows, marker underlines, the AI block.' },
  { href: '/lab/contact',    vs: '/contact',          t: 'Contact v2',        d: 'The email is the page. Badges escaped the menu.' },
];

const experiments = [
  { href: '/lab/find-your-flow', t: 'Find Your Flow ring', d: 'Three credits-ring motion options, still awaiting a pick.' },
  { href: '/lab/work-kit',       t: 'Work component kit',  d: 'Self-contained work-page components, the site-factory seed.' },
  { href: '/work-preview/sony-this-moment', t: 'CMS pipeline proof', d: 'Sony This Moment rendered from Keystatic content.' },
];
---
<Base title="The Lab — monuments">
  <main class="lb">

    <header class="lb-head">
      <p class="lb-eyebrow fade">The lab</p>
      <h1 class="lb-h1 split">Work in progress, <em>on purpose.</em></h1>
      <p class="lb-lead fade">Every v2 page lives here until it's promoted. Click the title for the new version; click compare to see what it replaces. Originals stay untouched until you call it.</p>
    </header>

    <section class="lb-sec">
      <p class="lb-kicker fade">The v2 set · built 2026-06-12</p>
      <ul class="lb-list">
        {v2.map((p, i) => (
          <li class="lb-row fade">
            <span class="lb-n">{String(i + 1).padStart(2, '0')}</span>
            <a class="lb-t" href={p.href}>
              {p.t}
              <svg class="lb-stroke" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
            </a>
            <span class="lb-d">{p.d}</span>
            {p.vs
              ? <a class="lb-vs" href={p.vs}>compare <span aria-hidden="true">→</span></a>
              : <span class="lb-vs lb-vs-new">new page</span>}
          </li>
        ))}
      </ul>
    </section>

    <section class="lb-sec">
      <p class="lb-kicker fade">Experiments</p>
      <ul class="lb-list">
        {experiments.map((p, i) => (
          <li class="lb-row lb-row-x fade">
            <span class="lb-n">x{i + 1}</span>
            <a class="lb-t lb-t-sm" href={p.href}>
              {p.t}
              <svg class="lb-stroke" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4 8 C60 4, 150 10, 296 5" /></svg>
            </a>
            <span class="lb-d">{p.d}</span>
          </li>
        ))}
      </ul>
    </section>

    <p class="lb-foot fade">Rollback safety: every page above is its own commit. Nothing replaces a live page until you promote it.</p>

  </main>
  <LabFx />
</Base>

<style>
  .lb { background: var(--black); color: var(--white); min-height: 100vh; overflow-x: clip; }
  .lb-eyebrow { font-size: 12px; letter-spacing: 0.24em; text-transform: uppercase; color: rgba(252,252,252,0.5); }
  .lb-kicker { font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #e0322d; }

  .lb-head { max-width: var(--wrap); margin: 0 auto; padding: 170px var(--pad) 7vh; }
  .lb-h1 { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(40px, 6vw, 92px); line-height: 1; letter-spacing: -0.03em; margin-top: 20px; }
  .lb-h1 em { font-style: italic; color: var(--accent); }
  .lb-lead { margin-top: 26px; max-width: 540px; font-size: 15px; line-height: 1.7; font-weight: 300; color: rgba(252,252,252,0.72); }

  .lb-sec { max-width: var(--wrap); margin: 0 auto; padding: 5vh var(--pad) 4vh; }
  .lb-list { list-style: none; margin: 22px 0 0; padding: 0; }
  .lb-row { display: grid; grid-template-columns: 48px minmax(220px, 0.5fr) 1fr auto; gap: 24px; align-items: baseline; padding: 22px 6px; border-top: 1px solid rgba(252,252,252,0.13); transition: padding-left 0.35s cubic-bezier(0.16,1,0.3,1); }
  .lb-list li:last-child { border-bottom: 1px solid rgba(252,252,252,0.13); }
  .lb-row:hover { padding-left: 18px; }
  .lb-n { font-size: 12px; letter-spacing: 0.18em; color: rgba(252,252,252,0.4); }
  .lb-t { position: relative; width: fit-content; font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(20px, 2.2vw, 30px); letter-spacing: -0.02em; color: var(--white); text-decoration: none; }
  .lb-t-sm { font-size: clamp(17px, 1.8vw, 23px); }
  .lb-stroke { position: absolute; left: 0; bottom: -5px; width: 100%; height: 9px; overflow: visible; }
  .lb-stroke path { fill: none; stroke: #e0322d; stroke-width: 2.5; stroke-linecap: round; stroke-dasharray: 320; stroke-dashoffset: 320; transition: stroke-dashoffset 0.5s cubic-bezier(0.16,1,0.3,1); }
  .lb-row:hover .lb-stroke path { stroke-dashoffset: 0; }
  .lb-d { font-size: 14px; line-height: 1.6; font-weight: 300; color: rgba(252,252,252,0.6); max-width: 52ch; }
  .lb-vs { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(252,252,252,0.55); text-decoration: none; white-space: nowrap; transition: color 0.2s; }
  a.lb-vs:hover { color: var(--white); }
  .lb-vs-new { color: #e0322d; }

  .lb-foot { max-width: var(--wrap); margin: 0 auto; padding: 6vh var(--pad) 14vh; font-size: 13px; font-weight: 300; color: rgba(252,252,252,0.45); }

  .lb :global(.split .w) { display: inline-block; overflow: hidden; vertical-align: top; }
  .lb :global(.split .wi) { display: inline-block; transform: translateY(115%); transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--wd) * 0.04s); }
  .lb :global(.split.on .wi) { transform: none; }

  @media (max-width: 860px) {
    .lb-row { grid-template-columns: 36px 1fr; }
    .lb-d { grid-column: 2; }
    .lb-vs { grid-column: 2; }
  }
  @media (prefers-reduced-motion: reduce) {
    .lb :global(.split .wi) { transform: none !important; transition: none !important; }
  }
</style>

<script>
  const splitWords = (root: Node, counter: { n: number }) => {
    [...root.childNodes].forEach((node) => {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        (node.textContent || '').split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
          const w = document.createElement('span'); w.className = 'w';
          const wi = document.createElement('span'); wi.className = 'wi';
          wi.style.setProperty('--wd', String(counter.n++));
          wi.textContent = part;
          w.appendChild(wi); frag.appendChild(w);
        });
        node.replaceWith(frag);
      } else if (node.nodeType === 1 && !(node as Element).closest('svg')) splitWords(node, counter);
    });
  };
  document.querySelectorAll('.split').forEach((el) => splitWords(el, { n: 0 }));
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('on'); io.unobserve(e.target); } }), { threshold: 0.35 });
  document.querySelectorAll('.split').forEach((el) => io.observe(el));
</script>
